<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CLO_5> rdf:type owl:NamedIndividual ,
                                                                      <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome> ;
                                                             <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasContent> <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Basic_business_principles_and_organizational_structure.> ;
                                                             <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasDomain> <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#C2_Understand> ;
