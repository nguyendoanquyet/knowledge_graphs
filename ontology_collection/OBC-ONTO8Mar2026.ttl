@prefix : <http://www.semanticweb.org/ami/ontologies/2024/10/OBC-ONTO#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/ami/ontologies/2024/10/OBC-ONTO#> .

<http://www.semanticweb.org/ami/ontologies/2024/10/OBC-ONTO> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#belongsToCurr
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#belongsToCurr> rdf:type owl:ObjectProperty ;
                                                                     owl:inverseOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPEO> ;
                                                                     rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramEducationalObjective> ;
                                                                     rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#belongsToSP
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#belongsToSP> rdf:type owl:ObjectProperty ;
                                                                   owl:inverseOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCurriculum> ;
                                                                   rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> ;
                                                                   rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#StudyProgram> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#coveredInCourse
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#coveredInCourse> rdf:type owl:ObjectProperty ;
                                                                       owl:inverseOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#coversContent> ;
                                                                       rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#SubjectMatter> ;
                                                                       rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#coversContent
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#coversContent> rdf:type owl:ObjectProperty ;
                                                                     rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> ;
                                                                     rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#SubjectMatter> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCLO
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCLO> rdf:type owl:ObjectProperty ;
                                                              owl:inverseOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#includedInCourse> ;
                                                              rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> ;
                                                              rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasContent
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasContent> rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCourse
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCourse> rdf:type owl:ObjectProperty ;
                                                                 owl:inverseOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#includedInCurr> ;
                                                                 rdf:type owl:InverseFunctionalProperty ;
                                                                 rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> ;
                                                                 rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCriteria
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCriteria> rdf:type owl:ObjectProperty ;
                                                                   rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Criteria> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCurriculum
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasCurriculum> rdf:type owl:ObjectProperty ;
                                                                     rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#StudyProgram> ;
                                                                     rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasDomain
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasDomain> rdf:type owl:ObjectProperty ;
                                                                 rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> ;
                                                                 rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningDomain> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasKnowledgeCategory
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasKnowledgeCategory> rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPEO
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPEO> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> ;
                                                              rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramEducationalObjective> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPLO
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPLO> rdf:type owl:ObjectProperty ;
                                                              owl:inverseOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ploHasCourse> ;
                                                              rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> ;
                                                              rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramLearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPart
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPart> rdf:type owl:ObjectProperty ;
                                                               owl:inverseOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#partOf> ;
                                                               rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramEducationalObjective> ;
                                                               rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramLearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPerformance
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#hasPerformance> rdf:type owl:ObjectProperty ;
                                                                      rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#includedInCourse
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#includedInCourse> rdf:type owl:ObjectProperty ;
                                                                        rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome> ;
                                                                        rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#includedInCurr
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#includedInCurr> rdf:type owl:ObjectProperty ,
                                                                               owl:InverseFunctionalProperty ;
                                                                      rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> ;
                                                                      rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#mappedTo
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#mappedTo> rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#partOf
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#partOf> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> ;
                                                              rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ploHasCourse
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ploHasCourse> rdf:type owl:ObjectProperty ;
                                                                    rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramLearningOutcome> ;
                                                                    rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#referTo
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#referTo> rdf:type owl:ObjectProperty ;
                                                               rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> ;
                                                               rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#AccreditationOrganization> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#satisfies
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#satisfies> rdf:type owl:ObjectProperty ;
                                                                 rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome> ;
                                                                 rdfs:range <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#SubjectMatter> .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#accreditationName
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#accreditationName> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#accreditationScope
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#accreditationScope> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#action
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#action> rdf:type owl:DatatypeProperty ;
                                                              rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#awardedDegree
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#awardedDegree> rdf:type owl:DatatypeProperty ;
                                                                     rdfs:subPropertyOf owl:topDataProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#code
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#code> rdf:type owl:DatatypeProperty ;
                                                            rdfs:range rdfs:Literal ;
                                                            rdfs:comment "Identifier that uniquely identifies a course or a learning object" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#condition
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#condition> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#content
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#content> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#country
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#country> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#courseName
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#courseName> rdf:type owl:DatatypeProperty ;
                                                                  rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> ;
                                                                  rdfs:range xsd:string ;
                                                                  rdfs:comment "Official name of a course" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#credit
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#credit> rdf:type owl:DatatypeProperty ;
                                                              rdfs:range xsd:integer .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#criteria
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#criteria> rdf:type owl:DatatypeProperty ;
                                                                rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#curriculumName
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#curriculumName> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> ;
                                                                      rdfs:range xsd:string ;
                                                                      rdfs:comment "Official name of curriculum, example: Curriculum of Computer Science UI Year 2020" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#curriculumStartDate
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#curriculumStartDate> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#description
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#description> rdf:type owl:DatatypeProperty ;
                                                                   rdfs:range xsd:string ;
                                                                   rdfs:comment """Description of a concept such as:
* Course""" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#description_eng
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#description_eng> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#documentTitle
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#documentTitle> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#documentType
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#documentType> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#documentVersion
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#documentVersion> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#fieldOfApplication
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#fieldOfApplication> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#issuedBy
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#issuedBy> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#label
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#label> rdf:type owl:DatatypeProperty ;
                                                             rdfs:domain [ rdf:type owl:Class ;
                                                                           owl:unionOf ( <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome>
                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramEducationalObjective>
                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#ProgramLearningOutcome>
                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#SubjectMatter>
                                                                                       )
                                                                         ] ;
                                                             rdfs:range xsd:string ;
                                                             rdfs:comment "the name of a learning outcome or a topic or a content" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#nqfElement
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#nqfElement> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#nqfLevel
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#nqfLevel> rdf:type owl:DatatypeProperty ;
                                                                rdfs:range xsd:string .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#organizationWebsite
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#organizationWebsite> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#programMission
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#programMission> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#programName
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#programName> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#programVision
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#programVision> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#publishedYear
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#publishedYear> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#semester
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#semester> rdf:type owl:DatatypeProperty ;
                                                                rdfs:range xsd:integer .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#spName
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#spName> rdf:type owl:DatatypeProperty ;
                                                              rdfs:domain <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#StudyProgram> ;
                                                              rdfs:range xsd:string ;
                                                              rdfs:comment "Official name of Study Program" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#totalCredit
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#totalCredit> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#url
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#url> rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#AccreditationOrganization
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#AccreditationOrganization> rdf:type owl:Class .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#AffectiveDomain
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#AffectiveDomain> rdf:type owl:Class ;
                                                                       owl:equivalentClass [ rdf:type owl:Class ;
                                                                                             owl:oneOf ( <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#A1_Perceive>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#A2_React>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#A3_Conform>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#A4_Validate>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#A5_AffectiveJudge>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#A6_AffectiveCreate>
                                                                                                       )
                                                                                           ] ;
                                                                       rdfs:subClassOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningDomain> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CognitiveDomain
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CognitiveDomain> rdf:type owl:Class ;
                                                                       owl:equivalentClass [ rdf:type owl:Class ;
                                                                                             owl:oneOf ( <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#C1_Remember>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#C2_Understand>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#C3_Apply>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#C4_Analyse>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#C5_Evaluate>
                                                                                                         <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#C6_Create>
                                                                                                       )
                                                                                           ] ;
                                                                       rdfs:subClassOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningDomain> ;
                                                                       rdfs:comment "Cognitive domain refer to Revised Bloom Taxonomy (David Krathwohl, Lorin Anderson, 2001)" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Course> rdf:type owl:Class .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#CourseLearningOutcome> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Criteria
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Criteria> rdf:type owl:Class .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#Curriculum> rdf:type owl:Class ;
                                                                  rdfs:comment "A curriculum is a comprehensive plan that outlines all the courses, subjects, and educational experiences that students are expected to engage with during their academic journey" .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#KnowledgeCategory
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#KnowledgeCategory> rdf:type owl:Class .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningDomain
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningDomain> rdf:type owl:Class .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#LearningOutcome> rdf:type owl:Class .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#NQFAuthorityResponsibility
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#NQFAuthorityResponsibility> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.semanticweb.org/ami/ontologies/2024/0/OBC#NationalQualificationFramework> .


###  http://www.semanticweb.org/ami/ontologies/2024/0/OBC#NQFKnowledge
<http://www.semanticweb.org/ami/ontologies/2024/0/OBC#NQFKnowledge> rdf:type owl:Class ;
