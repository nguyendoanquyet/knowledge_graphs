@prefix : <file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#> .
@prefix bf: <http://id.loc.gov/ontologies/bibframe/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix cito: <http://purl.org/spar/cito/> .
@prefix dblp: <https://dblp.org/rdf/schema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix litre: <http://purl.org/spar/literal/> .
@prefix locid: <http://id.loc.gov/vocabulary/identifiers/> .
@prefix bibtex: <http://purl.org/net/nknouf/ns/bibtex#> .
@prefix locrel: <http://id.loc.gov/vocabulary/relators/> .
@prefix schema: <https://schema.org/> .
@prefix datacite: <http://purl.org/spar/datacite/> .
@base <file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#> .

<file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf> rdf:type owl:Ontology ;
                                                                 owl:versionIRI <https://dblp.org/rdf/schema-2024-06-14> ;
                                                                 dct:abstract "The dblp RDF schema is an ontology that models the semantic contents of the dblp computer science bibliography."@en ;
                                                                 dct:creator <https://dblp.org> ;
                                                                 dct:description "This ontology describes the RDF representation of the contents of the dblp computer science bibliography."@en ;
                                                                 dct:title "dblp RDF schema" ;
                                                                 owl:priorVersion <https://dblp.org/rdf/schema-2023-10-17> ;
                                                                 owl:versionInfo "Fri 14 Jun 2024" .

#################################################################
#    Annotation properties
#################################################################

###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#creatorName
:creatorName rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf wd:P2561 ,
                                foaf:name ,
                                schema:name .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#monthOfPublication
:monthOfPublication rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf wd:P2922 .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#primaryCreatorName
:primaryCreatorName rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf dbo:commonName .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#primaryStreamTitle
:primaryStreamTitle rdf:type owl:AnnotationProperty ;
                    rdfs:subPropertyOf dbo:commonName .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedBy
:publishedBy rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf dc:publisher .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedInBookChapter
:publishedInBookChapter rdf:type owl:AnnotationProperty ;
                        rdfs:subPropertyOf wd:P792 ,
                                           schema:position .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedInJournalVolume
:publishedInJournalVolume rdf:type owl:AnnotationProperty ;
                          rdfs:subPropertyOf wd:P478 ,
                                             schema:volumeNumber .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedInJournalVolumeIssue
:publishedInJournalVolumeIssue rdf:type owl:AnnotationProperty ;
                               rdfs:subPropertyOf wd:P433 ,
                                                  schema:issueNumber .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedInSeriesVolume
:publishedInSeriesVolume rdf:type owl:AnnotationProperty ;
                         rdfs:subPropertyOf wd:P478 ,
                                            schema:volumeNumber .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#streamTitle
:streamTitle rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf wd:P2561 ,
                                foaf:name ,
                                schema:name .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#title
:title rdf:type owl:AnnotationProperty ;
       rdfs:subPropertyOf dc:title ,
                          schema:name .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#webpage
:webpage rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf wd:P2699 ,
                            schema:url .


###  http://dbpedia.org/ontology/commonName
dbo:commonName rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/publisher
dc:publisher rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
dct:abstract rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dct:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dct:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dct:title rdf:type owl:AnnotationProperty .


###  http://www.wikidata.org/entity/P2561
wd:P2561 rdf:type owl:AnnotationProperty .


###  http://www.wikidata.org/entity/P2699
wd:P2699 rdf:type owl:AnnotationProperty .


###  http://www.wikidata.org/entity/P2922
wd:P2922 rdf:type owl:AnnotationProperty .


###  http://www.wikidata.org/entity/P433
wd:P433 rdf:type owl:AnnotationProperty .


###  http://www.wikidata.org/entity/P478
wd:P478 rdf:type owl:AnnotationProperty .


###  http://www.wikidata.org/entity/P792
wd:P792 rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/name
foaf:name rdf:type owl:AnnotationProperty .


###  https://schema.org/issueNumber
schema:issueNumber rdf:type owl:AnnotationProperty .


###  https://schema.org/name
schema:name rdf:type owl:AnnotationProperty .


###  https://schema.org/position
schema:position rdf:type owl:AnnotationProperty .


###  https://schema.org/url
schema:url rdf:type owl:AnnotationProperty .


###  https://schema.org/volumeNumber
schema:volumeNumber rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#gMonth
xsd:gMonth rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#archivedWebpage
:archivedWebpage rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :webpage ;
                 rdfs:domain :Entity ;
                 rdfs:range foaf:Document ;
                 rdfs:comment "The URL of an archived web page about this item, which may no longer be available in the web."@en ;
                 rdfs:label "archivedWebpage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#authorOf
:authorOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :creatorOf ;
          owl:inverseOf :authoredBy ;
          rdfs:domain :Creator ;
          rdfs:range :Publication ;
          rdfs:comment "The creator is the author of the publication."@en ;
          rdfs:label "authorOf"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#authoredBy
:authoredBy rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :createdBy ;
            rdfs:domain :Publication ;
            rdfs:range :Creator ;
            rdfs:comment "The publication is authored by the creator."@en ;
            rdfs:label "authoredBy"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#awardWebpage
:awardWebpage rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :webpage ;
              rdfs:domain :Creator ;
              rdfs:range foaf:Document ;
              rdfs:comment "The URL of a web page about an award received by this creator."@en ;
              rdfs:label "awardwebpage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#bibtexType
:bibtexType rdf:type owl:ObjectProperty ;
            rdfs:domain :Publication ;
            rdfs:range bibtex:Entry ;
            rdfs:comment "The bibtex type of the publication, e.g. book, inproceedings, etc."@en ;
            rdfs:label "bibtexType"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#coAuthorWith
:coAuthorWith rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :coCreatorWith ;
              rdf:type owl:SymmetricProperty ;
              rdfs:domain :Creator ;
              rdfs:range :Creator ;
              rdfs:comment "The creator is co-author with the other creator."@en ;
              rdfs:label "coAuthorWith"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#coCreatorWith
:coCreatorWith rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf foaf:knows ;
               rdf:type owl:SymmetricProperty ;
               rdfs:domain :Creator ;
               rdfs:range :Creator ;
               rdfs:comment "The creator is co-creator with the other creator."@en ;
               rdfs:label "coCreatorWith"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#coEditorWith
:coEditorWith rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :coCreatorWith ;
              rdf:type owl:SymmetricProperty ;
              rdfs:domain :Creator ;
              rdfs:range :Creator ;
              rdfs:comment "The creator is co-editor with the other creator."@en ;
              rdfs:label "coEditorWith"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#createdBy
:createdBy rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf dc:creator ,
                              foaf:maker ;
           owl:inverseOf :creatorOf ;
           rdfs:domain :Publication ;
           rdfs:range :Creator ;
           rdfs:comment "The publication is created by the creator."@en ;
           rdfs:label "createdBy"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#creatorOf
:creatorOf rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf foaf:made ;
           rdfs:domain :Creator ;
           rdfs:range :Publication ;
           rdfs:comment "The creator of the publication."@en ;
           rdfs:label "creatorOf"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#documentPage
:documentPage rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :webpage ;
              rdfs:domain :Publication ;
              rdfs:range foaf:Document ;
              rdfs:comment "The URL of the electronic edition of the publication."@en ;
              rdfs:label "documentPage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#doi
:doi rdf:type owl:ObjectProperty ;
     rdfs:subPropertyOf :identifier ;
     rdfs:domain :Publication ;
     rdfs:range xsd:anyUri ;
     rdfs:comment "A Digital Object Identifier."@en ;
     rdfs:label "doi"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#editedBy
:editedBy rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :createdBy ;
          owl:inverseOf :editorOf ;
          rdfs:domain :Publication ;
          rdfs:range :Creator ;
          rdfs:comment "The publication is edited by the creator."@en ;
          rdfs:label "editedBy"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#editorOf
:editorOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :creatorOf ;
          rdfs:domain :Creator ;
          rdfs:range :Publication ;
          rdfs:comment "The creator is the editor of the publication."@en ;
          rdfs:label "editorOf"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#hasSignature
:hasSignature rdf:type owl:ObjectProperty ;
              owl:inverseOf :signaturePublication ;
              rdfs:domain :Publication ;
              rdfs:range :Signature ;
              rdfs:comment "A signature that links this publication to an creator."@en ;
              rdfs:label "hasSignature"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#hasVersion
:hasVersion rdf:type owl:ObjectProperty ;
            owl:inverseOf :versionConcept ;
            rdfs:domain :Publication ;
            rdfs:range :VersionRelation ;
            rdfs:comment "The publication has a different, more specific (instance) publication as its version."@en ;
            rdfs:label "hasVersion"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#homepage
:homepage rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :webpage ;
          rdfs:domain :Creator ;
          rdfs:range foaf:Document ;
          rdfs:comment "The URL of an academic homepage of this creator."@en ;
          rdfs:label "homepage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#homonymousCreator
:homonymousCreator rdf:type owl:ObjectProperty ,
                            owl:SymmetricProperty ;
                   rdfs:domain :Creator ;
                   rdfs:range :Creator ;
                   rdfs:comment "This creator shares a homonymous name with the other creator."@en ;
                   rdfs:label "homonymousCreator"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#identifier
:identifier rdf:type owl:ObjectProperty ;
            rdfs:domain :Entity ;
            rdfs:range xsd:anyUri ;
            rdfs:comment "An abstract identifier."@en ;
            rdfs:label "identifier"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#indexPage
:indexPage rdf:type owl:ObjectProperty ;
           rdfs:domain :Stream ;
           rdfs:range foaf:Document ;
           rdfs:comment "The URL of the dblp stream index page for this stream."@en ;
           rdfs:label "indexPage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#isVersion
:isVersion rdf:type owl:ObjectProperty ;
           owl:inverseOf :versionInstance ;
           rdfs:domain :Publication ;
           rdfs:range :VersionRelation ;
           rdfs:comment "The publication is a version of another, more general (concept) publication."@en ;
           rdfs:label "isVersion"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#isVersionOf
:isVersionOf rdf:type owl:ObjectProperty ,
                      owl:TransitiveProperty ;
             rdfs:domain :Publication ;
             rdfs:range :Publication ;
             rdfs:comment "The publication is a version of another, more general (concept) publication."@en ;
             rdfs:label "isVersionOf"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#isbn
:isbn rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :identifier ;
      rdfs:domain :Publication ;
      rdfs:range xsd:anyUri ;
      rdfs:comment "An International Standard Book Number."@en ;
      rdfs:label "isbn"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#issn
:issn rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :identifier ;
      rdfs:domain :Stream ;
      rdfs:range xsd:anyUri ;
      rdfs:comment "An International Standard Serial Number."@en ;
      rdfs:label "issn"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#listedOnTocPage
:listedOnTocPage rdf:type owl:ObjectProperty ;
                 rdfs:domain :Publication ;
                 rdfs:range foaf:Document ;
                 rdfs:comment "The url of the dblp table of contents page listing this publication."@en ;
                 rdfs:label "listedOnTocPage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#omid
:omid rdf:type owl:ObjectProperty ;
      rdfs:subPropertyOf :identifier ;
      rdfs:domain :Publication ;
      rdfs:range xsd:anyUri ;
      rdfs:comment "An OpenCitations Meta Identifier."@en ;
      rdfs:label "omid"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#orcid
:orcid rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf :identifier ;
       rdfs:domain :Creator ;
       rdfs:range xsd:anyUri ;
       rdfs:comment "An Open Researcher and Contributor ID."@en ;
       rdfs:label "orcid"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#possibleActualCreator
:possibleActualCreator rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :homonymousCreator ;
                       owl:inverseOf :proxyAmbiguousCreator ;
                       rdfs:domain :AmbiguousCreator ;
                       rdfs:range :Creator ;
                       rdfs:comment "This ambiguous creator may be (or may be not) just a disambiguation proxy for the other creator. Further actual creator candidates are possible."@en ;
                       rdfs:label "possibleActualCreator"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#predecessorStream
:predecessorStream rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :relatedStream ;
                   owl:inverseOf :successorStream ;
                   rdfs:domain :Stream ;
                   rdfs:range :Stream ;
                   rdfs:comment "This stream is a predecessor of the other stream."@en ;
                   rdfs:label "predecessorStream"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#primaryDocumentPage
:primaryDocumentPage rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :documentPage ;
                     rdfs:domain :Publication ;
                     rdfs:range foaf:Document ;
                     rdfs:comment "The primary URL of the electronic edition of the publication."@en ;
                     rdfs:label "primaryDocumentPage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#primaryHomepage
:primaryHomepage rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :homepage ;
                 rdfs:domain :Creator ;
                 rdfs:range foaf:Document ;
                 rdfs:comment "The primary URL of an academic homepage of this creator."@en ;
                 rdfs:label "primaryHomepage"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#proxyAmbiguousCreator
:proxyAmbiguousCreator rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :homonymousCreator ;
                       rdfs:domain :Creator ;
                       rdfs:range :AmbiguousCreator ;
                       rdfs:comment "This creator (and any of her fellow homonymous creators) is also represented by the given ambiguous creator in cases where the authorship of a publication is undetermined."@en ;
                       rdfs:label "proxyAmbiguousCreator"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedAsPartOf
:publishedAsPartOf rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf wd:P1433 ,
                                      schema:isPartOf ;
                   rdf:type owl:TransitiveProperty ;
                   rdfs:domain :Publication ;
                   rdfs:range :Publication ;
                   rdfs:comment "The publication has been published as a part of the other publication."@en ;
                   rdfs:label "publishedAsPartOf"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedIn
:publishedIn rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf wd:P1433 ,
                                schema:isPartOf .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#publishedInStream
:publishedInStream rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf wd:P1433 ,
                                      schema:isPartOf ;
                   rdfs:domain :Publication ;
                   rdfs:range :Stream ;
                   rdfs:comment "The conference series, the journal, or the repository in which the publication has been published."@en ;
                   rdfs:label "publishedInStream"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#relatedStream
:relatedStream rdf:type owl:ObjectProperty ,
                        owl:SymmetricProperty ;
               rdfs:domain :Stream ;
               rdfs:range :Stream ;
               rdfs:comment "This stream is related to the other stream in some unspecified way."@en ;
               rdfs:label "relatedStream"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#signatureCreator
:signatureCreator rdf:type owl:ObjectProperty ;
                  rdfs:domain :Signature ;
                  rdfs:range :Creator ;
                  rdfs:comment "A linked creator of the publication."@en ;
                  rdfs:label "signatureCreator"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#signatureOrcid
:signatureOrcid rdf:type owl:ObjectProperty ;
                rdfs:domain :Signature ;
                rdfs:range xsd:anyUri ;
                rdfs:comment "An ORCID that links the publication to a creator."@en ;
                rdfs:label "signatureOrcid"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#signaturePublication
:signaturePublication rdf:type owl:ObjectProperty ;
                      rdfs:domain :Signature ;
                      rdfs:range :Publication ;
                      rdfs:comment "The publication of this signature."@en ;
                      rdfs:label "signaturePublication"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#subStream
:subStream rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :relatedStream ;
           owl:inverseOf :superStream ;
           rdfs:domain :Stream ;
           rdfs:range :Stream ;
           rdfs:comment "This stream is (or was) a part of the other stream."@en ;
           rdfs:label "subStream"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#successorStream
:successorStream rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :relatedStream ;
                 rdfs:domain :Stream ;
                 rdfs:range :Stream ;
                 rdfs:comment "This stream is a successor of the other stream."@en ;
                 rdfs:label "successorStream"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#superStream
:superStream rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :relatedStream ;
             rdfs:domain :Stream ;
             rdfs:range :Stream ;
             rdfs:comment "This stream has (or had) the other stream as a part."@en ;
             rdfs:label "superStream"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#versionConcept
:versionConcept rdf:type owl:ObjectProperty ;
                rdfs:domain :VersionRelation ;
                rdfs:range :Publication ;
                rdfs:comment "The linked general (concept) publication."@en ;
                rdfs:label "versionConcept"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#versionInstance
:versionInstance rdf:type owl:ObjectProperty ;
                 rdfs:domain :VersionRelation ;
                 rdfs:range :Publication ;
                 rdfs:comment "The linked specific (instance) publication version."@en ;
                 rdfs:label "versionInstance"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#versionUri
:versionUri rdf:type owl:ObjectProperty ;
            rdfs:domain :VersionRelation ;
            rdfs:range xsd:anyUri ;
            rdfs:comment "An (optional) URI of identifying the linked specific (instance) publication version."@en ;
            rdfs:label "versionUri"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#webpage
:webpage rdf:type owl:ObjectProperty ;
         rdfs:domain :Entity ;
         rdfs:range foaf:Document .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#wikidata
:wikidata rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :identifier ;
          rdfs:domain :Entity ;
          rdfs:range xsd:anyUri ;
          rdfs:comment "A wikidata item."@en ;
          rdfs:label "wikidata"@en .


###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#wikipedia
:wikipedia rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :webpage ;
           rdfs:domain :Entity ;
           rdfs:range foaf:Document ;
           rdfs:comment "The URL of an (English) Wikipedia article about this item."@en ;
           rdfs:label "wikipedia"@en .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:ObjectProperty .


###  http://www.wikidata.org/entity/P1433
wd:P1433 rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/knows
foaf:knows rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/made
foaf:made rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/maker
foaf:maker rdf:type owl:ObjectProperty .


###  https://schema.org/isPartOf
schema:isPartOf rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  file:/D:/knowledge_graphs/ontology_collection/DBPL-schema.rdf#affiliation
:affiliation rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :creatorNote ;
             rdfs:domain :Creator ;
             rdfs:range xsd:string ;
             rdfs:comment "A (past or present) affiliation of the creator. (Remark: This property currently just gives literal xsd:string values until institutions are modelled as proper entities.)"@en ;
