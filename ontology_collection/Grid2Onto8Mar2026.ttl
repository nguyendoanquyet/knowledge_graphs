#################################################################

###  http://www.semanticweb.org/emna.amdouni/ontologies/2023/0/RTEOntology#electrical_grid
:electrical_grid rdf:type owl:NamedIndividual ,
                          :Electrical_grid ;
                 :has_part :line_54_55_145 ,
                           :line_54_58_154 ,
                           :line_58_60_156 .


###  http://www.semanticweb.org/emna.amdouni/ontologies/2023/0/RTEOntology#issue_115
:issue_115 rdf:type owl:NamedIndividual ,
                    :Issue ;
           :has_measurement :rho_115 ;
           :is_associated_with :set_bus .


###  http://www.semanticweb.org/emna.amdouni/ontologies/2023/0/RTEOntology#issue_120
:issue_120 rdf:type owl:NamedIndividual ,
                    :Issue ;
           :has_measurement :rho_120 ;
           :is_associated_with :set_bus .


###  http://www.semanticweb.org/emna.amdouni/ontologies/2023/0/RTEOntology#issue_175
:issue_175 rdf:type owl:NamedIndividual ,
                    :Issue ;
           :has_measurement :rho_175 ;
           :is_associated_with :set_bus .


###  http://www.semanticweb.org/emna.amdouni/ontologies/2023/0/RTEOntology#issue_751
:issue_751 rdf:type owl:NamedIndividual ,
                    :Issue ;
           :has_measurement :rho_751 ;
           :is_associated_with :set_bus .


###  http://www.semanticweb.org/emna.amdouni/ontologies/2023/0/RTEOntology#issue_89
:issue_89 rdf:type owl:NamedIndividual ,
                   :Issue ;
          :has_measurement :rho_751 ;
          :is_associated_with :set_bus .


###  http://www.semanticweb.org/emna.amdouni/ontologies/2023/0/RTEOntology#line_54_55_145
