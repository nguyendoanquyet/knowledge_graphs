    <owl:members rdf:parseType="Collection">
      <owl:Class rdf:about="SinglePhasePowerBus"/>
      <owl:Class rdf:about="SplitPhasePowerBus"/>
      <owl:Class rdf:about="ThreePhasePowerBus"/>
    </owl:members>
