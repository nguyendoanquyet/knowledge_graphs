    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="tapChanger">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="VoltageProperty"/>
    <rdfs:domain rdf:resource="ElectricPowerTransformer"/>
    <rdfs:subPropertyOf rdf:resource="hasProperty"/>
    <rdfs:comment xml:lang="en">The Tap changer to change the voltage regulation of the transformer.</rdfs:comment>
    <rdfs:label xml:lang="en">tap Changer</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="TNResistance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricResistanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the resistance between its T and its N wires.</rdfs:comment>
    <rdfs:label xml:lang="en">T-to-N resistance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="incomingElectricEnergy">
    <vs:term_status>testing</vs:term_status>
    <rdfs:comment xml:lang="en">Links an electric energy system, or an electrical connection point, to the incoming electric energy.&#xD;
    (a) the sum of the electric energy that enter the system from the exterior, or&#xD;
    (b) the electric energy that enters the system through this connection point.</rdfs:comment>
    <rdfs:label>incoming electric energy</rdfs:label>
    <rdfs:domain rdf:parseType="Resource">
      <owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="ElectricPowerSystem"/>
        <owl:Class rdf:about="ElectricalConnectionPoint"/>
      </owl:unionOf>
    </rdfs:domain>
    <rdfs:subPropertyOf rdf:resource="electricEnergy"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:resource="ElectricEnergyProperty"/>
    <rdfs:subPropertyOf rdf:resource="hasProperty"/>
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="STReactance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricReactanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the reactance between its S and its T wires.</rdfs:comment>
    <rdfs:label xml:lang="en">S-to-T reactance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="phaseToNeutralSusceptance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricSusceptanceProperty"/>
    <rdfs:domain rdf:resource="SinglePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a single phase connection point to the susceptance between its phase and neutral wires.</rdfs:comment>
    <rdfs:label xml:lang="en">phase to neutral susceptance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="negativeWireCurrent">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="CurrentProperty"/>
    <rdfs:domain rdf:resource="DirectCurrentConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a direct current connection point to the current in its negative wire. By convention, the value is positive if it enters the system.&#xD;
&#xD;
  Please contact us in case this convention is incorrect.</rdfs:comment>
    <rdfs:label xml:lang="en">negative wire current</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="positiveToMidConductance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricConductanceProperty"/>
    <rdfs:domain rdf:resource="DirectCurrentConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricConductance"/>
    <rdfs:comment xml:lang="en">Links a direct current connection point to the conductance between its positive and its mid wires.</rdfs:comment>
    <rdfs:label xml:lang="en">positive to mid conductance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="activePower">
    <rdfs:range rdf:resource="ElectricPowerProperty"/>
    <rdfs:domain rdf:resource="AlternatingCurrentPowerProperty"/>
    <rdfs:comment xml:lang="en">Links an alternating current power property to its active part (i.e., the real part of the complex value).</rdfs:comment>
    <rdfs:subPropertyOf rdf:resource="electricPower"/>
    <rdfs:subPropertyOf rdf:resource="hasProperty"/>
    <rdfs:label xml:lang="en">active power</rdfs:label>
    <vs:term_status>testing</vs:term_status>
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <rdfs:subPropertyOf rdf:resource="real"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="importedActiveEnergy">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:domain rdf:resource="AlternatingCurrentPowerProperty"/>
    <rdfs:subPropertyOf rdf:resource="hasProperty"/>
    <rdfs:comment xml:lang="en">Links an alternating current power property to its imported active energy, often in Wh/10.</rdfs:comment>
    <rdfs:label xml:lang="en">imported active znergy</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="midToNegativeSusceptance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricSusceptanceProperty"/>
    <rdfs:domain rdf:resource="DirectCurrentConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricSusceptance"/>
    <rdfs:comment xml:lang="en">Links a direct current connection point to the susceptance between its mid and its negative wires.</rdfs:comment>
    <rdfs:label xml:lang="en">mid to negative susceptance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="incomingElectricPower">
    <rdfs:label>incoming electric power</rdfs:label>
    <rdfs:subPropertyOf rdf:resource="electricPower"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricPowerProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:parseType="Resource">
      <owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="ElectricPowerSystem"/>
        <owl:Class rdf:about="ElectricalConnectionPoint"/>
      </owl:unionOf>
    </rdfs:domain>
    <rdfs:comment xml:lang="en">Links an electric power system, or an electrical connection point, to the incoming electric power.&#xD;
    (a) the sum of the electric power that enter the system from the exterior, or&#xD;
    (b) the electric power that enters the system through this connection point.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <rdfs:subPropertyOf rdf:resource="hasProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="RNReactance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricReactanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the reactance between its R and its N wires.</rdfs:comment>
    <rdfs:label xml:lang="en">R-to-N reactance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="powerFactor">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:domain rdf:resource="AlternatingCurrentPowerProperty"/>
    <rdfs:subPropertyOf rdf:resource="electricPower"/>
    <rdfs:subPropertyOf rdf:resource="hasProperty"/>
    <rdfs:comment xml:lang="en">Links an alternating current power property to its power factor (i.e., the cosinus of the voltage with respect to current, unitless).</rdfs:comment>
    <rdfs:label xml:lang="en">power factor evaluation</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="neutralWireCurrent">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="CurrentProperty"/>
    <rdfs:domain rdf:resource="SinglePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a single phase connection point to the current in its neutral wire. By convention, the value is positive if it leaves the system.</rdfs:comment>
    <rdfs:label xml:lang="en">neutral wire current</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="positiveToMidResistance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricResistanceProperty"/>
    <rdfs:domain rdf:resource="DirectCurrentConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricResistance"/>
    <rdfs:comment xml:lang="en">Links a direct current connection point to the resistance between its positive and its mid wires.</rdfs:comment>
    <rdfs:label xml:lang="en">positive to mid resistance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="SNConductance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricConductanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the conductance between its S and its N wires.</rdfs:comment>
    <rdfs:label xml:lang="en">S-to-N conductance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="phaseToNeutralVoltage">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="VoltageProperty"/>
    <rdfs:domain rdf:parseType="Resource">
      <owl:unionOf rdf:parseType="Collection">
        <owl:Class rdf:about="SinglePhasePowerBus"/>
        <owl:Class rdf:about="SinglePhaseConnectionPoint"/>
      </owl:unionOf>
    </rdfs:domain>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a single phase power bus or a single phase connection point to the voltage between its phase and neutral wires.</rdfs:comment>
    <rdfs:label xml:lang="en">phase to neutral voltage</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="RNResistance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricResistanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the resistance between its R and its N wires.</rdfs:comment>
    <rdfs:label xml:lang="en">R-to-N resistance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="SNResistance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricResistanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the resistance between its S and its N wires.</rdfs:comment>
    <rdfs:label xml:lang="en">T-to-N resistance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="RNConductance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricConductanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the conductance between its R and its N wires.</rdfs:comment>
    <rdfs:label xml:lang="en">R-to-N conductance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
