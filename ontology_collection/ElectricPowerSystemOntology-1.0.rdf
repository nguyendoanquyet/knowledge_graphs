    <rdfs:subClassOf rdf:resource="DirectCurrentConnectionPoint"/>
    <rdfs:comment xml:lang="en">A two-wire direct current connection point is a connection point composed of two wires (potentialy plus the protective earth): &#xD;
     wire for the positive;&#xD;
     wire for the negative.</rdfs:comment>
    <rdfs:label xml:lang="en">Two-Wire Direct Current Connection Point</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="ElectricReactanceProperty">
