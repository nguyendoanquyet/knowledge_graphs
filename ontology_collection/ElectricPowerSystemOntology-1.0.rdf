    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricSusceptanceProperty"/>
    <rdfs:domain rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricCurrent"/>
    <rdfs:comment xml:lang="en">Links a three-phase connection point to the susceptance between its S and its N wires.</rdfs:comment>
    <rdfs:label xml:lang="en">S-to-N susceptance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="midToNegativeResistance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricResistanceProperty"/>
    <rdfs:domain rdf:resource="DirectCurrentConnectionPoint"/>
    <rdfs:subPropertyOf rdf:resource="electricResistance"/>
    <rdfs:comment xml:lang="en">Links a direct current connection point to the resistance between its mid and its negative wires.</rdfs:comment>
    <rdfs:label xml:lang="en">mid to negative resistance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:FunctionalProperty>
  <owl:FunctionalProperty rdf:about="positiveWireCurrent">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="CurrentProperty"/>
