      <owl:someValuesFrom rdf:resource="CurrentProperty"/>
      <owl:onProperty rdf:resource="evaluationOf"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="Evaluation"/>
    <rdfs:comment xml:lang="en">The class of evaluations for current properties.</rdfs:comment>
    <rdfs:label>Current Evaluation</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="ElectricPowerDistributionNetwork">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="ElectricPowerSystem"/>
    <rdfs:comment xml:lang="en"> Electric Power Distribution Network is a network used to distribute the electric power. &#xD;
                      Figure below shows the taxonomy of Electric Power Distribution Network according to the installation mode of Electric Line or cable.&#xD;
                       [![ElectricPowerDistributionNetworkTaxonomy](https://w3id.org/seas/ElectricPowerDistributionNetwork-1.png)](https://w3id.org/seas/ElectricPowerDistributionNetwork-1.png)&#xD;
                      </rdfs:comment>
    <rdfs:label xml:lang="en">Electric Power Distribution Network.</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="LowVoltageEvaluation">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="VoltageEvaluation"/>
    <rdfs:comment xml:lang="en">The voltage is Low according to IEC 60038.</rdfs:comment>
    <rdfs:label xml:lang="en">Low Voltage Evaluation</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="DirectCurrentConnection">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="ElectricalConnection"/>
    <rdfs:comment xml:lang="en">The class of electrical connections through which energy flows using direct current.</rdfs:comment>
    <rdfs:label xml:lang="en">Direct Current Connection</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="ElectricalConnectionPoint">
    <owl:disjointWith rdf:resource="ElectricPowerSystem"/>
    <rdfs:comment xml:lang="en">The class of electrical connection points of electric power systems, at which they may be electricaly connected to other systems.&#xD;
  For example, an electric vehicle service equipment may have three electric power connection points: two different kinds of plugs that enable to charge electric vehicles, and a three-phase power bus connection point to the grid:&#xD;
&#xD;
```&#xD;
  &lt;electric_vehicle&gt; a seas:ElectricPowerSystem ;&#xD;
    seas:connectsAt &lt;plug_high_voltage&gt; , &lt;normal_plug&gt; , &lt;three_phase_connection_point&gt; .&#xD;
  &lt;plug_high_voltage&gt; a seas:ElectricalConnectionPoint .&#xD;
  &lt;normal_plug&gt; a seas:ElectricalConnectionPoint .&#xD;
  &lt;three_phase_connection_point&gt; a seas:ElectricalConnectionPoint .&#xD;
```&#xD;
&#xD;
  Any system connected through an electrical connection is connected at one of its electrical connection points to the electrical connection:&#xD;
  if:&#xD;
&#xD;
```&#xD;
  &lt;system&gt; a seas:System .&#xD;
  &lt;system&gt; seas:connectedThrough &lt;connection&gt; .&#xD;
  &lt;connection&gt; a seas:ElectricalConnection .&#xD;
```&#xD;
&#xD;
  then there exists `_:connectionPoint` such that:&#xD;
&#xD;
```&#xD;
  _:connectionPoint a seas:ElectricalConnection Point ;&#xD;
    seas:connectionPointOf &lt;system&gt; ;&#xD;
    seas:connectsSystemAt &lt;connection&gt; .&#xD;
```&#xD;
&#xD;
  An electrical connection point describes an electric signal, and the electricity that enters/leaves the electric power system.&#xD;
  An electrical connection point only belongs to an electric power system, and connects it through electrical connections.&#xD;
  A connection point of an electric power system is not necessarily an electrical connection.</rdfs:comment>
    <rdfs:subClassOf rdf:parseType="Resource">
      <owl:allValuesFrom rdf:resource="ElectricPowerSystem"/>
      <owl:onProperty rdf:resource="connectionPointOf"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:parseType="Resource">
      <owl:someValuesFrom rdf:resource="Property"/>
      <owl:onProperty>
        <owl:ObjectProperty rdf:about="electricCurrent"/>
      </owl:onProperty>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="ConnectionPoint"/>
    <rdfs:subClassOf rdf:parseType="Resource">
      <owl:allValuesFrom rdf:resource="ElectricalConnection"/>
      <owl:onProperty rdf:resource="connectsSystemThrough"/>
    </rdfs:subClassOf>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:parseType="Resource">
      <owl:someValuesFrom rdf:resource="Property"/>
      <owl:onProperty>
        <owl:ObjectProperty rdf:about="voltage"/>
      </owl:onProperty>
    </rdfs:subClassOf>
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <rdfs:label xml:lang="en">Electrical Connection Point</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="AlternatingCurrentPowerProperty">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="ElectricPowerProperty"/>
    <rdfs:comment xml:lang="en">The class of electric power properties for alternating current.&#xD;
&#xD;
An alternating current power property cannot be directly quantified. One must quantify its individual power properties.</rdfs:comment>
    <rdfs:label>Alternating Current Power Property</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="ElectricReactanceEvaluation">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <owl:equivalentClass rdf:parseType="Resource">
      <owl:someValuesFrom rdf:resource="ElectricReactanceProperty"/>
      <owl:onProperty rdf:resource="evaluationOf"/>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:parseType="Resource">
      <owl:someValuesFrom rdf:resource="ElectricReactanceProperty"/>
      <owl:onProperty rdf:resource="evaluationOf"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="Evaluation"/>
    <rdfs:comment xml:lang="en">The class of evaluations for electric reactance properties.</rdfs:comment>
    <rdfs:label>Electric Reactance Evaluation</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="EfficiencyProperty">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="Property"/>
    <rdfs:comment xml:lang="en">Efficiency signifies a level of performance that describes a process that uses the lowest amount of inputs to create the greatest &#xD;
                amount of outputs. Efficiency relates to the use of all inputs in producing any given &#xD;
                output, including personal time and energy. Efficiency is a measurable concept that can be &#xD;
                determined by determining the ratio of useful output to total input. It minimizes the waste &#xD;
                of resources such as physical materials, energy and time, while successfully achieving the &#xD;
                desired output.</rdfs:comment>
    <rdfs:label>Efficiency Property</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="SinglePhaseConnectionPoint">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="AlternatingCurrentConnectionPoint"/>
    <rdfs:comment xml:lang="en">A single phase connection point is a connection point composed of two wires (plus the protective earth): &#xD;
&#xD;
- wire for the phase;&#xD;
- wire for the neutral.</rdfs:comment>
    <rdfs:label xml:lang="en">Single Phase Connection Point</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="ExtraHighVoltage">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="VoltageProperty"/>
    <rdfs:comment xml:lang="en">The voltage is Extra-High according to IEC 60038.</rdfs:comment>
    <rdfs:label xml:lang="en">Extra-High Voltage </rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="ElectricSusceptanceEvaluation">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <owl:equivalentClass rdf:parseType="Resource">
      <owl:someValuesFrom rdf:resource="ElectricSusceptanceProperty"/>
      <owl:onProperty rdf:resource="evaluationOf"/>
    </owl:equivalentClass>
    <rdfs:subClassOf rdf:parseType="Resource">
      <owl:someValuesFrom rdf:resource="ElectricSusceptanceProperty"/>
      <owl:onProperty rdf:resource="evaluationOf"/>
    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="Evaluation"/>
    <rdfs:comment xml:lang="en">The class of evaluations for electric susceptance properties.</rdfs:comment>
    <rdfs:label>Electric Susceptance Evaluation</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="ExtraHighVoltageEvaluation">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:subClassOf rdf:resource="VoltageEvaluation"/>
    <rdfs:comment xml:lang="en">The voltage is Extra-High according to IEC 60038.</rdfs:comment>
    <rdfs:label xml:lang="en">Extra-High Voltage Evaluation</rdfs:label>
  </owl:Class>
  <owl:ObjectProperty rdf:about="electricResistance">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>testing</vs:term_status>
    <rdfs:range rdf:resource="ElectricResistanceProperty"/>
    <rdfs:subPropertyOf rdf:resource="hasProperty"/>
    <rdfs:comment xml:lang="en">Links an electrical connection point to one of its resistance properties.&#xD;
&#xD;
