    <rdfs:comment xml:lang="en">A three-phase power bus is a connection composed of four wires (plus the protective earth): &#xD;
     wires R, S, T, for the phases;&#xD;
     wire N for the neutral.</rdfs:comment>
    <rdfs:label xml:lang="en">Three-Phase Power Bus</rdfs:label>
  </owl:Class>
