    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="Evaluation"/>
    <rdfs:comment xml:lang="en">The class of evaluations for voltage properties.</rdfs:comment>
    <rdfs:label>Voltage Evaluation</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://purl.org/vocommons/voaf#Vocabulary"/>
