    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="EfficiencyEvaluation"/>
    <rdfs:comment xml:lang="en">The class of evaluations for efficiency properties.</rdfs:comment>
    <rdfs:label>Charging Efficiency Evaluation</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="UndergroundElectricPowerDistributionNetwork">
