    <vs:term_status>stable</vs:term_status>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="connectsSystemInTriangleThrough"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="ThreePhaseConnectionPoint"/>
    <rdfs:domain rdf:resource="ThreePhasePowerBus"/>
    <rdfs:subPropertyOf rdf:resource="connectsSystemAt"/>
    <rdfs:comment xml:lang="en">Links a three-phase power bus to one of the three-phase connection points it connects with a triangle configuration.</rdfs:comment>
    <rdfs:label xml:lang="en">connects system in triangle at</rdfs:label>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="connectsSystemInTNAt">
    <rdfs:isDefinedBy rdf:resource="ElectricPowerSystemOntology"/>
    <vs:term_status>stable</vs:term_status>
