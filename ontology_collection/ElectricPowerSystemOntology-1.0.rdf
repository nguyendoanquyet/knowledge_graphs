    </rdfs:subClassOf>
    <rdfs:subClassOf rdf:resource="Evaluation"/>
    <rdfs:comment xml:lang="en">The class of evaluations for efficiency properties.</rdfs:comment>
    <rdfs:label>Efficiency Evaluation</rdfs:label>
  </owl:Class>
