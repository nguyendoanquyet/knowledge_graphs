###  https://w3id.org/ccso/ccso#PSY1501s1/PSY_BSc/SoC/Uoc
<https://w3id.org/ccso/ccso#PSY1501s1/PSY_BSc/SoC/Uoc> rdf:type owl:NamedIndividual ,
                                                                ccso:Syllabus ;
                                                       ccso:aimsToLO <https://w3id.org/ccso/ccso#PSY/LO_Acquire_basic_concepts_and_theories_in_Social_Psychology> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Be_aware_of_the_applications_and_implications_of_social_psychological_theory_for_the_explanation_of_real_life_phenomena> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Demonstrate_a_critical_awareness_of_the_relationship_between_theoretical_perspectives_and_research_methodologies_in_social_psychology> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Evaluate_critically_the_major_theoretical_frameworks_in_which_social_psychologists_have_described_and_explained_human_behavior> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Identify_and_evaluate_key_issues_and_controversies_within_social_psychology> ;
                                                       ccso:coversTopic <https://w3id.org/ccso/ccso#PSY/T_Intergroup_Behaviour> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_Social_Psychology_and_Culture> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_The_Critical_thought_in_Social_Psychology> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_The_Self> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_Attitudes:Personal_and_Social_approaches> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_Identity_theory:A_multilevel_Perspective> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_Social_Psychology:A_Historical_Perspective> ;
                                                       ccso:followsTEMethod ccso:Demonstration ,
                                                                            ccso:Lecture ,
                                                                            ccso:Project ,
                                                                            ccso:WrittenExam ;
                                                       ccso:hasEvent <https://w3id.org/ccso/ccso#PSY1501_s2017-18-L01/PSY_BSc/SoC/Uoc> ;
                                                       ccso:hasInstructor ccso:Kafetsios_Konstantinos ;
                                                       ccso:hasLM ccso:Hogg2010SocialPsychology ,
                                                                  ccso:Papastamou2008EpistimologikoiProvlimatismoi ,
                                                                  ccso:Sapsford2006TheorySocialPsychology ;
                                                       ccso:hasSupervisor ccso:Kafetsios_Konstantinos ;
                                                       ccso:syllabusOf <https://w3id.org/ccso/ccso#PSY1501/PSY_BSc/SoC/Uoc> ;
                                                       ccso:academicYear "Spring" ;
                                                       ccso:code "PSY1501s1/PSY_BSc/SoC/Uoc" ;
                                                       ccso:courseType "Compulsory" ;
                                                       ccso:creditsECTS "4"^^xsd:short ;
                                                       ccso:csName "Syllabus of course PSY1501 Social Psychology I : Introduction to Social Psychology" ;
                                                       ccso:description """Course contents:
•  Social Psychology: An historical perspective
•  Attitudes: Personal and social approaches
•  Stereotypes and Prejudice
•  Social influence: Conformity and obedience
•  Intergroup behavior
•  The Self
•  Identity theory: A multilevel perspective
•  Social Psychology and culture
•  The Critical thought in Social Psychology""" ,
                                                                        """Objectives of the course (preferably expressed in terms of learning outcomes and competences):
1. To acquire basic concepts and theories in social psychology
2. To be able to evaluate critically the major theoretical frameworks in which social psychologists have described and explained human behavior.
3. To demonstrate a critical awareness of the relationship between theoretical perspectives and research methodologies in social psychology
4. To identify and evaluate key issues and controversies within social psychology.
5. To be aware of the applications and implications of social psychological theory for the explanation of real life phenomena""" ;
                                                       ccso:duration "P4M"^^xsd:duration ;
                                                       ccso:endDate "2018-01-29"^^xsd:date ;
                                                       ccso:language "Greek" ;
                                                       ccso:semesterinProgram "1"^^xsd:short ;
                                                       ccso:startDate "2017-10-01"^^xsd:date .


