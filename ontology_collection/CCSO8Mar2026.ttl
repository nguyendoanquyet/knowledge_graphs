@prefix : <https://w3id.org/ccso/ccso> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ccso: <https://w3id.org/ccso/ccso#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/ccso/ccso> .

<https://w3id.org/ccso/ccso> rdf:type owl:Ontology ;
                              <http://purl.org/dc/elements/1.1/creator> "EVangelos Katis, merocknyxta@gmail.com"@en ;
                              <http://purl.org/dc/elements/1.1/rights> """Copyright © 2018, Evangelos Katis, Department of Informatics Engineering, Technological Educational Institute of Crete

This project is under the GNU GPL v3 license.

This ontology is published as free software, aiming to be reused and shareable among institutions, contributing in information sharing and reuse.
Please remove any individuals before reuse the ontology.

This ontology is free software: you can redistribute it and/or modify it under the terms of the GNU General Public License as published by the Free Software Foundation, either version 3 of the License, or (at your option) any later version.

This ontology is distributed in the hope that it will be useful, but WITHOUT ANY WARRANTY; without even the implied warranty of MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  
See the GNU General Public License for more details.
You should have received a copy of the GNU General Public License along with this program.  If not, see https://www.gnu.org/licenses."""@en ;
                              rdfs:comment "This Ontology aims to provide data model for describing the subjects of Curriculum, Course and Syllabus in Higher education."@en ,
                                           """preferred NameSpace URI: https://w3id.org/ccso/ccso
preferred NameSpace Prefix: ccso"""@en ,
                                           "Αυτή η Οντολογία στοχεύει αποσκοπεί στη δημιουργία ενός μοντέλου δεδομένων για την περιγραφή των πλαισίων του Προγράμματος Σπουδών, του Μαθήματος και του Περιγράμματος Μαθήματος στην Τριτοβάθμια εκπαίδευση."@gr ;
                              rdfs:label "Curriculum Course Syllabus Ontology (CCSO)"@en ;
                              owl:versionInfo """Changes in 0.31 from priorVersion 0.30:
    1. Addition of some Disjoints between various types of ProgramofStudy, Events and Persons
    2. Addition of numerous Data properties in classes ProgramofStudy, EducationalOrganization, Syllabus.
    3. Addition of some Restrictions.
    4. Addition of class Employee.
    5. Addition of class Publication.
    6. Fixes in the hierarchy of EducationalOrganization subtree  (using belongsTo     relationship).
    7. Fixes in the hierarchy of FieldofStudy subtree (using partOf relationship).
    8. Addition of Instances
    9. Addition of Rules
    10. Addition of DC-Elements properties in classes Publications & LearningMaterial.
* Changes in 0.4 from 0.3:
    1. Change the ontology URI to a permanentURI:
    http://purl.org/net/CCSO
    2. Change the ontology URI to a stable URI that I own:
        http://xworks.gr/ontologies/ccso
    3. Correct some pitfalls detected by OOPS
* Changes to 0.5 from 0.4:
    1. Merge classes Publication & LearningMaterial into Resource
    2. Tests with SPAQL Queries based on Competency Questions
* Changes to 0.6 from 0.5:
    1. Replace Students names with Greek names.
* Changes in 0.6 from 0.7:
    1. Change the ontology URI to a stable URI: https://w3id.org/ccso/ccso"""@en ,
                                              0.7 .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/rights
<http://purl.org/dc/elements/1.1/rights> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/06/sw-vocab-status/ns#term_status
<http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#duration
xsd:duration rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/dc/elements/1.1/contributor
<http://purl.org/dc/elements/1.1/contributor> rdf:type owl:ObjectProperty ;
                                              rdfs:domain ccso:Resource ;
                                              rdfs:range <http://xmlns.com/foaf/0.1/Person> ;
                                              rdfs:comment """An entity responsible for making contributions to the resource.
Examples of a Contributor include a person, an organization, or a service. Typically, the name of a Contributor should be used to indicate the entity."""@en ,
                                                           """Μία οντότητα που είναι υπεύθυνη στο να συνεισφέρει στην πηγή. 
Παραδείγματα συνεισφοράς μπορεί να περιλαμβάνουν ένα άτομο, έναν οργανισμό, ή μία υπηρεσία. Τυπικά, το όνομα αυτού που συνεισφέρει θα πρέπει να χρησιμοποιείται για να υποδείξει την οντότητα."""@gr .


###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:ObjectProperty ;
                                          rdfs:domain ccso:Resource ;
                                          rdfs:range <http://xmlns.com/foaf/0.1/Person> .


###  https://w3id.org/ccso/ccso#acquiredInCourse
ccso:acquiredInCourse rdf:type owl:ObjectProperty ;
                      owl:inverseOf ccso:aimsToLO ;
                      rdf:type owl:AsymmetricProperty ;
                      rdfs:domain ccso:LearningOutcome ;
                      rdfs:range ccso:Syllabus ;
                      rdfs:comment "A Learning Outcome may expected to be acquired in various Courses."@en ,
                                   "Ένα Μαθησιακό Αποτέλεσμα αναμένεται να αποκτηθεί σε διάφορα Μαθήματα (Courses)."@gr .


###  https://w3id.org/ccso/ccso#affiliatedWith
ccso:affiliatedWith rdf:type owl:ObjectProperty ;
                    rdfs:comment "Super-property of some object properties that represents any kind of affiliation relation between the following classes: EducationalOrganization, Person, ProgramofStudy, Course, Event"@en ,
                                 "Υπερ-ιδιότητα ιδιοτήτων κάποιων αντικειμένων που αναπαριστά κάθε είδους σχέση ένταξης μεταξύ των εξής κλάσεων: EducationalOrganization, Person, ProgramofStudy, Course, Event"@gr .


###  https://w3id.org/ccso/ccso#aimsToLO
ccso:aimsToLO rdf:type owl:ObjectProperty ,
                       owl:AsymmetricProperty ;
              rdfs:domain ccso:Syllabus ;
              rdfs:range ccso:LearningOutcome ;
              rdfs:comment "A Course may aim to several Learning Outcomes in connection with the covered Topics."@en ,
                           "Ένα Μάθημα μπορεί να στοχεύει σε διάφορα Μαθησιακά Αποτελέσματα σε σχέση με τα Αντικείμενα που καλύπτει."@gr .


###  https://w3id.org/ccso/ccso#alumnusOf
ccso:alumnusOf rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf ccso:affiliatedWith ;
               owl:inverseOf ccso:hasAlumnus ;
               rdf:type owl:AsymmetricProperty ;
               rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
               rdfs:range ccso:Department ;
               rdfs:comment "A Person is Alumnus of a Department"@en ,
                            "Ένα πρόσωπο  είναι Απόφοιτος ενός Τμήματος."@gr .


###  https://w3id.org/ccso/ccso#areaOfCourse
ccso:areaOfCourse rdf:type owl:ObjectProperty ;
                  owl:inverseOf ccso:coversKA ;
                  rdfs:domain ccso:KnowledgeArea ;
                  rdfs:range ccso:Course ;
                  rdfs:comment "Knowledge Area is area of a Course"@en ,
                               "Πεδίο Γνώσης είναι το πεδίο ενός Μαθήματος."@gr .


###  https://w3id.org/ccso/ccso#assistsInCourse
ccso:assistsInCourse rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf ccso:affiliatedWith ;
                     owl:inverseOf ccso:hasCourseAssistant ;
                     rdfs:domain ccso:Assistant ;
                     rdfs:range ccso:Syllabus ;
                     owl:propertyDisjointWith ccso:attendsCourse ,
                                              ccso:instructorOf ,
                                              ccso:supervisorOf ;
                     rdfs:comment "An Assistant is (Teaching) Assistant in a Course."@en ,
                                  "Ένας Βοηθός είναι Βοηθός (Διδάσκων) σε ένα Μάθημα."@gr .


###  https://w3id.org/ccso/ccso#assistsInEvent
ccso:assistsInEvent rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf ccso:affiliatedWith ;
                    owl:inverseOf ccso:hasEventAssistant ;
                    rdfs:domain ccso:Assistant ;
                    rdfs:range ccso:Event ;
                    rdfs:comment "An Assistant may assists in a teaching event, an evaluation event or some other stuff and events."@en ,
                                 "Ένας Βοηθός μπορεί να βοηθάει στη διδαασκαλία, στην αξιολόγηση ή σε άλλα πεδία και γεγονότα."@gr .


###  https://w3id.org/ccso/ccso#attendsCourse
ccso:attendsCourse rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ccso:affiliatedWith ;
                   owl:inverseOf ccso:hasAttender ;
                   rdf:type owl:AsymmetricProperty ;
                   rdfs:domain ccso:Student ;
                   rdfs:range ccso:Course ;
                   owl:propertyDisjointWith ccso:hasCompleted ,
                                            ccso:instructorOf ;
                   rdfs:comment "A Student attends some Courses of a study program."@en ,
                                "Ένας Φοιτητής παρακολουθεί κάποια Μαθήματα σε ένα πρόγραμμα σπουδών."@gr .


###  https://w3id.org/ccso/ccso#belongsTo
ccso:belongsTo rdf:type owl:ObjectProperty ,
                        owl:TransitiveProperty ;
               rdfs:domain <http://schema.org/EducationalOrganization> ;
               rdfs:range <http://schema.org/EducationalOrganization> ;
               rdfs:comment """School belongsTo University.
Department belongsTo School."""@en ,
                            """Η Σχολή ανήκει στο Τμήμα.
Το Τμήμα ανήκει στη Σχολή."""@gr .


###  https://w3id.org/ccso/ccso#coveredInCourse
ccso:coveredInCourse rdf:type owl:ObjectProperty ;
                     owl:inverseOf ccso:coversTopic ;
                     rdf:type owl:AsymmetricProperty ;
                     rdfs:domain ccso:Topic ;
                     rdfs:range ccso:Syllabus ;
                     rdfs:comment "A Topic may be covered in several Courses included in different ProgramofStudies."@en ,
                                  "Ένα Θέμα μπορεί να καλύπτεται σε διάφορα Μαθήματα, ακόμα και σε διαφορετικά Προγράμματα Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#coversKA
ccso:coversKA rdf:type owl:ObjectProperty ;
              rdfs:domain ccso:Course ;
              rdfs:range ccso:KnowledgeArea ;
              rdfs:comment "Course covers part of a Knowledge Area"@en ,
                           "Ένα Μάθημα καλύπτει ένα Πεδίο Γνώσης."@gr .


###  https://w3id.org/ccso/ccso#coversTopic
ccso:coversTopic rdf:type owl:ObjectProperty ,
                          owl:AsymmetricProperty ;
                 rdfs:domain ccso:Syllabus ;
                 rdfs:range ccso:Topic ;
                 rdfs:comment """A Course may Cover several Topics. 
The coverage of a Topic is depending from how many hours are being taught; A national or international curriculum guide of the Body of Knowledge can provide information about the coverage, the learning outcomes and the minimum hours."""@en ,
                              """Ένα Μάθημα μπορεί να καλύπτει διάφορα Θέματα. 
Αυτή η κάλυψη εξαρτάται από το πόσες ώρες διδάσκονται. Ένας εθνικός ή διεθνής οδηγός πρόγραμματος σπουδών για το Βασικό Κορμό της Γνώσης μπορεί να δώσει πληροφορίες σχετικά με το πεδίο που καλύπτει, τα μαθησιακά αποτελέσματα και τις ελάχιστες ώρες διδασκαλίας."""@gr .


###  https://w3id.org/ccso/ccso#enrolledIn
ccso:enrolledIn rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf ccso:affiliatedWith ;
                owl:inverseOf ccso:hasRegistered ;
                rdfs:domain ccso:Student ;
                rdfs:range ccso:ProgramofStudy ;
                owl:propertyDisjointWith ccso:hasDegree ;
                rdfs:comment "A Student is enrolled (registered) in a Study Program."@en ,
                             "Ένας Φοιτητής είναι εγγεγραμμένος σε ένα Πρόγραμμα Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#expectsLO
ccso:expectsLO rdf:type owl:ObjectProperty ,
                        owl:AsymmetricProperty ;
               rdfs:domain ccso:TeachingEvent ;
               rdfs:range ccso:LearningOutcome ;
               rdfs:comment "A Teaching Event expects (aims to) one or more Learning Outcomes for the students."@en ,
                            "Μία Διδασκαλία αναμένεται να φέρει ένα ή περισσότερα Μαθησιακά Αποτελέσματα στοyς Φοιτητές."@gr .


###  https://w3id.org/ccso/ccso#focusIn
ccso:focusIn rdf:type owl:ObjectProperty ,
                      owl:AsymmetricProperty ;
             rdfs:domain ccso:ProgramofStudy ;
             rdfs:range ccso:KnowledgeBody ;
             rdfs:comment "A Study Program is focused in a Body of Knowledge, at least."@en ,
                          "Ένα Πρόγραμμα Σπουδών στοχεύει τουλάχιστον σε έναν Βασικό Κορμό Γνώσης."@gr .


###  https://w3id.org/ccso/ccso#followsTEMethod
ccso:followsTEMethod rdf:type owl:ObjectProperty ,
                              owl:AsymmetricProperty ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( ccso:EvaluationEvent
                                                 ccso:Syllabus
                                                 ccso:TeachingEvent
                                               )
                                 ] ;
                     rdfs:range ccso:TeachingEvaluationMethod ;
                     rdfs:comment "An Event in the classroom follows one or more Teaching Methods or either Evaluation Methods."@en ,
                                  "Ένα Γεγονός στην τάξη ακολουθεί μία ή περισσότερες Διδακτικές Μεθόδους ή διάφορες Μεθόδους Αξιολόγησης."@gr .


###  https://w3id.org/ccso/ccso#hasAcademicStaff
ccso:hasAcademicStaff rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf ccso:affiliatedWith ;
                      owl:inverseOf ccso:memberOf ;
                      rdfs:domain ccso:Department ;
                      rdfs:range ccso:AcademicStaff ;
                      rdfs:comment "A Department has staff that is member of the Academic staff (known as Faculty also) like Professors, Researchers and Lecturers."@en ,
                                   "Ένα Τμήμα έχει προσωπικό που αποτελεί μέρος του Ακαδημαϊκού Προσωπικού όπως Καθηγητές, Ερευνητές και Εισηγητές."@gr .


###  https://w3id.org/ccso/ccso#hasAlumnus
ccso:hasAlumnus rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf ccso:affiliatedWith ;
                rdf:type owl:AsymmetricProperty ;
                rdfs:domain ccso:Department ;
                rdfs:range <http://xmlns.com/foaf/0.1/Person> ;
                rdfs:comment "A Department has alumnus, a person who completed successfully a Program of Study."@en ,
                             "Ένα Τμήμα έχει Απόφοιτο, ένα άτομο που έχει ολοκληρώσει επιτυχώς το Πρόγραμμα Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#hasAttender
ccso:hasAttender rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf ccso:affiliatedWith ;
                 rdfs:domain ccso:Course ;
                 rdfs:range ccso:Student ;
                 owl:propertyDisjointWith ccso:hasCourseAssistant ,
                                          ccso:hasInstructor ,
                                          ccso:hasSupervisor ;
                 rdfs:comment "A Course has Student as Attender."@en ,
                              "Ένα Μάθημα έχει Φοιτητή ως Συμμετέχοντα."@gr .


###  https://w3id.org/ccso/ccso#hasCompleted
ccso:hasCompleted rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf ccso:affiliatedWith ;
                  rdfs:domain ccso:Student ;
                  rdfs:range ccso:Course ;
                  rdfs:comment "A Student who has successfully completed a Study Program or either a Course."@en ,
                               "Ένας Φοιτητής που έχει επιτυχώς ολοκληρώσει ένα Πρόγραμμα Σπουδών ή ένα Μάθημα."@gr .


###  https://w3id.org/ccso/ccso#hasCourseAssistant
ccso:hasCourseAssistant rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf ccso:affiliatedWith ;
                        rdfs:domain ccso:Syllabus ;
                        rdfs:range ccso:Assistant ;
                        owl:propertyDisjointWith ccso:hasInstructor ,
                                                 ccso:hasSupervisor ;
                        rdfs:comment "A Course has Assistant."@en ,
                                     "Το Μάθημα έχει έναν Βοηθό."@gr .


###  https://w3id.org/ccso/ccso#hasDegree
ccso:hasDegree rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf ccso:affiliatedWith ;
               rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
               rdfs:range ccso:ProgramofStudy ;
               rdfs:comment "Person has some Degrees from some Departments (e.g. Bachelor Degree, Master Degree, etc)"@en ,
                            "Ένα πρόσωπο που έχει ολοκληρώσει επιτυχώς ένα πρόγραμμα Σπουδών και έχει λάβει τον Τίτλο Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#hasDuration
ccso:hasDuration rdf:type owl:ObjectProperty ,
                          owl:AsymmetricProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( ccso:Course
                                             ccso:ProgramofStudy
                                           )
                             ] ;
                 rdfs:range ccso:DateTimeDuration ;
                 rdfs:comment "A Study Program or either a Course has some Duration in weeks, months or years."@en ,
                              "Ένα Πρόγραμμα Σπουδών ή ένα Μάθημα έχει Διάρκεια που ορίζεται σε εβδομάδες, μήνες ή χρόνια."@gr .


###  https://w3id.org/ccso/ccso#hasEmployee
ccso:hasEmployee rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf ccso:affiliatedWith ;
                 owl:inverseOf ccso:worksFor ;
                 rdfs:domain <http://schema.org/EducationalOrganization> ;
                 rdfs:range ccso:Employee ;
                 rdfs:comment "EducationalOrganization hasEmployee Employee"@en ,
                              "Ένας Εκπαιδευτικός Οργανισμός έχει Απασχολούμενους."@gr .


###  https://w3id.org/ccso/ccso#hasEvent
ccso:hasEvent rdf:type owl:ObjectProperty ,
                       owl:AsymmetricProperty ;
              rdfs:domain ccso:Syllabus ;
              rdfs:range [ rdf:type owl:Class ;
                           owl:unionOf ( ccso:EvaluationEvent
                                         ccso:TeachingEvent
                                       )
                         ] ;
              rdfs:comment "A Course is composed of several Events; most of them are Teaching Events and some are Evaluation Events."@en ,
                           "Ένα Μάθημα αποτελείται από διάφορα Γεγονότα. Τα περισσότερα από αυτά είναι Διδακτικά Γεγονότα και κάποια από αυτά είναι Γεγονότα Αξιολόγησης."@gr .


###  https://w3id.org/ccso/ccso#hasEventAssistant
ccso:hasEventAssistant rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf ccso:affiliatedWith ;
                       rdfs:domain ccso:Event ;
                       rdfs:range ccso:Assistant ;
                       rdfs:comment "An Event may have one or more Assistants."@en ,
                                    "Ένα Γεγονός μπορεί να έχει έναν ή παραπάνω Βοηθούς."@gr .


###  https://w3id.org/ccso/ccso#hasGrader
ccso:hasGrader rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf ccso:affiliatedWith ;
               rdf:type owl:AsymmetricProperty ;
               rdfs:domain ccso:EvaluationEvent ;
               rdfs:range ccso:Professor ;
               rdfs:comment "An Evaluation Event can have at least one Professor as Grader."@en ,
                            "Ένα Γεγονός Αξιολόγησης μπορεί να έχει τουλάχιστον έναν Καθηγητή ως Βοθμολογητή."@gr .


###  https://w3id.org/ccso/ccso#hasInstructor
ccso:hasInstructor rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ccso:affiliatedWith ;
                   owl:inverseOf ccso:instructorOf ;
                   rdf:type owl:AsymmetricProperty ;
                   rdfs:domain ccso:Syllabus ;
                   rdfs:range ccso:Professor ;
                   rdfs:comment "A Course has one or more Professors as Instructors."@en ,
                                "Ένα Μάθημα έχει ένα ή παραπάνω Καθηγητές ως Εισηγητές."@gr .


###  https://w3id.org/ccso/ccso#hasLM
ccso:hasLM rdf:type owl:ObjectProperty ,
                    owl:AsymmetricProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( ccso:Event
                                       ccso:Syllabus
                                     )
                       ] ;
           rdfs:range ccso:Resource ;
           rdfs:comment """A Course may use several Resources as Learning Material.
An Event may use several Resources as Learning Material."""@en ,
                        """Ένα Μάθημα χρησιμοποιεί έναν αριθμό Πηγών ως Μαθησιακό Υλικό.
Ένα Συμβάν Διδασκαλίας χρησιμοποιεί έναν αριθμό Πηγών ως Μαθησιακό Υλικό."""@gr .


###  https://w3id.org/ccso/ccso#hasPrerequisite
ccso:hasPrerequisite rdf:type owl:ObjectProperty ,
                              owl:AsymmetricProperty ;
                     rdfs:domain ccso:Course ;
                     rdfs:range ccso:Course ;
                     rdfs:comment "A Course may require previous knowledge from other Courses."@en ,
                                  "Ένα Μάθημα μπορεί να απαιτεί γνώσεις από άλλα Μαθήματα."@gr .


###  https://w3id.org/ccso/ccso#hasPublication
ccso:hasPublication rdf:type owl:ObjectProperty ,
                             owl:AsymmetricProperty ;
                    rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                    rdfs:range ccso:Resource ;
                    rdfs:comment "A person creates and publishes a work."@en ,
                                 "Ένα άτομο δημιουργεί και εκδίδει μία εργασία."@gr .


###  https://w3id.org/ccso/ccso#hasRegistered
ccso:hasRegistered rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ccso:affiliatedWith ;
                   rdf:type owl:AsymmetricProperty ;
                   rdfs:domain ccso:ProgramofStudy ;
                   rdfs:range ccso:Student ;
                   rdfs:comment "A Study Program can have a lot of Students registered." ,
                                "Ένα Πρόγραμμα Σπουδών μπορεί έχει πολλούς εγγρεγραμμένους Φοιτητές."@gr .


###  https://w3id.org/ccso/ccso#hasSupervisor
ccso:hasSupervisor rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf ccso:affiliatedWith ;
                   owl:inverseOf ccso:supervisorOf ;
                   rdf:type owl:AsymmetricProperty ;
                   rdfs:domain ccso:Syllabus ;
                   rdfs:range ccso:Professor ;
                   rdfs:comment "A Course can have a Professor as Supervisor who manages all the activities within a Course such as the design, the implementation, the lessons, the outcomes, etc."@en ,
                                "Ένα Μάθημα μπορεί να έχει έναν Καθηγητή ως Επιβλέπων ο οποίος διαχειρίζεται όλες τις δραστηριότητες στο Μάθημα όπως το σχεδιασμό, την εφαρμογή, τη διδασκαλία, τα αποτελέσματα κτλ."@gr .


###  https://w3id.org/ccso/ccso#hasSyllabus
ccso:hasSyllabus rdf:type owl:ObjectProperty ;
                 owl:inverseOf ccso:syllabusOf ;
                 rdfs:domain ccso:Course ;
                 rdfs:range ccso:Syllabus ;
                 rdfs:comment "A  Course has Syllabus (maybe more)."@en ,
                              "Ένα Μάθημα έχει ένα Περίγραμμα Σπουδών (μπορεί και περισσότερα)."@gr .


###  https://w3id.org/ccso/ccso#hasTeacher
ccso:hasTeacher rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf ccso:affiliatedWith ;
                owl:inverseOf ccso:teachesIn ;
                rdf:type owl:AsymmetricProperty ;
                rdfs:domain ccso:TeachingEvent ;
                rdfs:range ccso:Professor ;
                rdfs:comment "A Teaching Event has one or more Professors as teachers."@en ,
                             "Μία Διδασκαλία έχει έναν ή παραπάνω Καθηγητές ως δάσκαλο."@gr .


###  https://w3id.org/ccso/ccso#hasTopic
ccso:hasTopic rdf:type owl:ObjectProperty ,
                       owl:AsymmetricProperty ;
              rdfs:domain ccso:TeachingEvent ;
              rdfs:range ccso:Topic ;
              rdfs:comment "A Teaching Event has one or more Topics."@en ,
                           "Μία Διδασκαλία έχει ένα ή περισσότερα Θέματα."@gr .


###  https://w3id.org/ccso/ccso#includedIn
ccso:includedIn rdf:type owl:ObjectProperty ;
                owl:inverseOf ccso:includesCourse ;
                rdf:type owl:AsymmetricProperty ;
                rdfs:domain ccso:Course ;
                rdfs:range ccso:ProgramofStudy ;
                rdfs:comment "A Course can be included in various Study Programs."@en ,
                             "Ένα Μάθημα μπορεί να περιλαμβάνεται σε διάφορα Προγράμματα Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#includesCourse
ccso:includesCourse rdf:type owl:ObjectProperty ,
                             owl:AsymmetricProperty ;
                    rdfs:domain ccso:ProgramofStudy ;
                    rdfs:range ccso:Course ;
                    rdfs:comment "A Study Program can includes many Courses." ,
                                 "Ένα Πρόγραμμα Σπουδών μπορεί να περιλαμβάνει πολλά Μαθήματα."@gr .


###  https://w3id.org/ccso/ccso#instructorOf
ccso:instructorOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf ccso:affiliatedWith ;
                  rdf:type owl:AsymmetricProperty ;
                  rdfs:domain ccso:Professor ;
                  rdfs:range ccso:Syllabus ;
                  rdfs:comment "Professor is Instructor in some Courses"@en ,
                               "Ο Καθηγητής είναι διδάσκων σε κάποια μαθήματα."@gr .


###  https://w3id.org/ccso/ccso#listedInKU
ccso:listedInKU rdf:type owl:ObjectProperty ;
                owl:inverseOf ccso:lists ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( ccso:LearningOutcome
                                            ccso:Topic
                                          )
                            ] ;
                rdfs:range ccso:KnowledgeUnit ;
                rdfs:comment "Each Topic and Learning Outcome that students are expected to achieve, is listed in a Knowledge Unit (KU)"@en ,
                             "Κάθε Θέμα και Μαθησιακό Αποτέλεσμα περιλαμβάνεται σε μια Μονάδα Γνώσης (KU)"@gr .


###  https://w3id.org/ccso/ccso#lists
ccso:lists rdf:type owl:ObjectProperty ;
           rdfs:domain ccso:KnowledgeUnit ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( ccso:LearningOutcome
                                      ccso:Topic
                                    )
                      ] ;
           rdfs:comment "Each KU lists a set of Topics and the Learning Outcomes students are expected to achieve."@en ,
                        "Κάθε KU περιλαμβάνει μία ομάδα από Θέματα και Μαθησιακά Αποτελέσματα που αναμένεται να επιτύχουν οι Φοιτητές."@gr .


###  https://w3id.org/ccso/ccso#memberOf
ccso:memberOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf ccso:affiliatedWith ;
              rdfs:domain ccso:AcademicStaff ;
              rdfs:range ccso:Department ;
              rdfs:comment "The academic staff of an institution, a school or a university such as professors of various ranks, lecturers and/or researchers. In North America the term Faculty is used instead."@en ,
                           "Το Ακαδημαϊκό Προσωπικό ενός ινστιτούτου, ενός σχολείου ή ενός Πανεπιστημίου όπως καθηγητές διαφόρων βαθμίδων, εισηγητές, ερευνητές. Στη Βόρεια Αμερική χρησμοποιείται ο όρος Faculty."@gr .


###  https://w3id.org/ccso/ccso#offeredBy
ccso:offeredBy rdf:type owl:ObjectProperty ;
               owl:inverseOf ccso:offersCourse ;
               rdfs:domain ccso:Course ;
               rdfs:range ccso:Department ;
               rdfs:comment "Course is offered by Department"@en ,
                            "Το μάθημα παρέχεται από ένα Τμήμα."@gr .


###  https://w3id.org/ccso/ccso#offersCourse
ccso:offersCourse rdf:type owl:ObjectProperty ;
                  rdfs:domain ccso:Department ;
                  rdfs:range ccso:Course ;
                  rdfs:comment "A Department offers some Courses available to Students."@en ,
                               "Ένα Τμήμα προσφέρει κάποια Μαθήματα που είναι διαθέσιμα στους Φοιτητές."@gr .


###  https://w3id.org/ccso/ccso#partOfFS
ccso:partOfFS rdf:type owl:ObjectProperty ,
                       owl:TransitiveProperty ;
              rdfs:domain ccso:FieldofStudy ;
              rdfs:range ccso:FieldofStudy ;
              rdfs:comment "A field of study may be part of a broader field of study."@en ,
                           "Ένα πεδίο μελέτης που μπορεί να είναι μέρος ενός ευρύτερου πεδιού μελέτης."@gr .


###  https://w3id.org/ccso/ccso#providedBy
ccso:providedBy rdf:type owl:ObjectProperty ;
                owl:inverseOf ccso:providesProgram ;
                rdf:type owl:AsymmetricProperty ;
                rdfs:domain ccso:ProgramofStudy ;
                rdfs:range ccso:Department ;
                rdfs:comment "A Study Program is provided by an Educational Organization." ,
                             "Ένα Πρόγραμμα Σπουδών παρέχεται από έναν Εκπαιδευτικό Οργανισμό."@gr .


###  https://w3id.org/ccso/ccso#providesProgram
ccso:providesProgram rdf:type owl:ObjectProperty ,
                              owl:AsymmetricProperty ;
                     rdfs:domain ccso:Department ;
                     rdfs:range ccso:ProgramofStudy ;
                     rdfs:comment "An Educational Organization provides a variety of Study Programs in many Disciplines and Knowledge Bodies." ,
                                  "Ένας Εκπαιδευτικός Οργανισμός παρέχει μία ποικιλία από Προγράμματα Σπουδών σε πολλούς Τομείς Γνώσης."@gr .


###  https://w3id.org/ccso/ccso#requiresProgram
ccso:requiresProgram rdf:type owl:ObjectProperty ,
                              owl:AsymmetricProperty ;
                     rdfs:domain ccso:ProgramofStudy ;
                     rdfs:range ccso:ProgramofStudy ;
                     rdfs:comment "Study Program requires a Study Program."@en ,
                                  "Ένα Πρόγραμμα Σπουδών απαιτεί ένα Πρόγραμμα Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#supervisorOf
ccso:supervisorOf rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf ccso:affiliatedWith ;
                  rdf:type owl:AsymmetricProperty ;
                  rdfs:domain ccso:Professor ;
                  rdfs:range ccso:Syllabus ;
                  rdfs:comment "A Professor can supervises and manages all the activities within a Course such as the design, the implementation, the lessons, the outcomes, etc."@en ,
                               "Ένας Καθηγητής μπορεί να επιβλέπει και να διαχειρίζεται όλες τις δραστηριότητες σε ένα Μάθημα όπως το σχεδιασμό, την εφαρμογή, τη διδασκαλία, τα αποτελέσματα κτλ."@gr .


###  https://w3id.org/ccso/ccso#syllabusOf
ccso:syllabusOf rdf:type owl:ObjectProperty ;
                rdfs:domain ccso:Syllabus ;
                rdfs:range ccso:Course ;
                rdfs:comment "It is Syllabus of a Course."@en ,
                             "Είναι το Περίγραμμα Σπουδών ενός Μαθήματος."@gr .


###  https://w3id.org/ccso/ccso#teachesIn
ccso:teachesIn rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf ccso:affiliatedWith ;
               rdf:type owl:AsymmetricProperty ;
               rdfs:domain ccso:Professor ;
               rdfs:range ccso:TeachingEvent ;
               rdfs:comment "A Professor teaches in some Teaching Events within a course."@en ,
                            "Ένας Καθηγητής κάνει κάποιες Διδασκαλίες μέσα σε ένα Μάθημα."@gr .


###  https://w3id.org/ccso/ccso#worksFor
ccso:worksFor rdf:type owl:ObjectProperty ;
              rdfs:domain ccso:Employee ;
              rdfs:range <http://schema.org/EducationalOrganization> ;
              rdfs:comment "An employee works for an organization."@en ,
                           "Ένας υπάλληλος εργάζεται σε έναν Οργανισμό."@gr .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/elements/1.1/date
<http://purl.org/dc/elements/1.1/date> rdf:type owl:DatatypeProperty ;
                                       rdfs:subPropertyOf ccso:dates ;
                                       rdfs:domain ccso:Resource ;
                                       rdfs:range xsd:date ;
                                       rdfs:comment """A point or period of time associated with an event in the lifecycle of the resource.
Date may be used to express temporal information at any level of granularity. Recommended best practice is to use an encoding scheme, such as the W3CDTF profile of ISO 8601 [W3CDTF] (e.g. 2017-03-15)."""@en ,
                                                    """Ένα σημείο ή περιόδος του χρόνου που σχετίζεται με ένα γεγονός στον κύκλο ζωής μίας πηγής. 
Η ημερομηνία μπορεί να χρησιμοποιηθεί για να εκφράσει μία προσωρινή πληροφορία σε οποιδήποτε επίπεδο του επιπέδου ανάλυσης. Προτείνεται να γίνεται χρήση ενός σχήματος κωδικοποίησης, όπως το  W3CDTF profile του ISO 8601 [W3CDTF] (π.χ. 2017-03-15)."""@gr .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain ccso:Resource ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment ""@gr ,
                                                           """An account of the resource.
Description may includes: an abstract, a table of contents, a graphical representation, or a free-text account of the resource."""@en ,
                                                           """Ο Λογαριασμός μία πηγής.
Η περιγραφή μπορεί περιλαμβάνει: μια περίληψη, πίνακα περιεχομένων, γραγική απεικόνιση, ελεύθερο κείμενο."""@gr .


###  http://purl.org/dc/elements/1.1/format
<http://purl.org/dc/elements/1.1/format> rdf:type owl:DatatypeProperty ;
                                         rdfs:domain ccso:Resource ;
                                         rdfs:range xsd:string ;
                                         rdfs:comment """The file format, physical medium, or dimensions of the resource.
Examples of dimensions include size and duration. Recommended best practice is to use a controlled vocabulary such as the list of Internet Media Types."""@en ,
                                                      """Η μορφή του αρχείου, η φυσική του υπόσταση ή οι διαστάσεις της πηγής.
Παραδείγματα από διαστάσεις περιλαμβάνουν το μέγεθος και τη διάρκεια. Προτεινόμενες πρακτικές είναι η χρήση ενός ελεγχόμενου λεξιλογίου όπως η λίστα των Internet Media Types."""@gr ;
                                         rdfs:seeAlso "[MIME] http://www.iana.org/assignments/media-types/"@en .


###  http://purl.org/dc/elements/1.1/language
<http://purl.org/dc/elements/1.1/language> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain ccso:Resource ;
                                           rdfs:range xsd:language ;
                                           rdfs:comment """A language of the resource.
Recommended best practice is to use a controlled vocabulary such as RFC 4646 [RFC4646]."""@en ,
                                                        """Η γλώσσα της πηγής.
Προτεινόμενη καλή πρακτική είναι η χρήση ενός ελεγχόμενου λεξιλογίου όπως το RFC 4646 [RFC4646]."""@gr ;
                                           rdfs:seeAlso "[RFC4646] http://www.ietf.org/rfc/rfc4646.txt"@en .


###  http://purl.org/dc/elements/1.1/publisher
<http://purl.org/dc/elements/1.1/publisher> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain ccso:Resource ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment """An entity responsible for making the resource available.
Examples of a Publisher include a person, an organization, or a service. Typically, the name of a Publisher should be used to indicate the entity."""@en ,
                                                         """Μία οντότητα που είναι υπεύθυνη να κάνει μία πηγή διαθέσιμη/δημοσιευμένη. 
Εκδότης μπορεί να είναι ένα πρόσωπο, ένας οργανισμός, ή μία υπηρεσία. Τυπικά, το όνομα του Εκδότη θα πρέπει να χρησιμοποιείται προκειμένου να υποδεικνύεται η οντότητα."""@gr .


###  http://purl.org/dc/elements/1.1/source
<http://purl.org/dc/elements/1.1/source> rdf:type owl:DatatypeProperty ;
                                         rdfs:domain ccso:Resource ;
                                         rdfs:range xsd:string ;
                                         rdfs:comment """A related resource from which the described resource is derived.
The described resource may be derived from the related resource in whole or in part. Recommended best practice is to identify the related resource by means of a string conforming to a formal identification system.

Here: The various types of media where the work is published.
The most common types are: 
• Book,
• Journal, 
• Workshop, 
• Conference, 
• Proceedings, 
• Thesis, 
• Magazine, 
• Newspaper, 
• Webpage,  
• UnofficialPublication, 
• etc."""@en ,
                                                      """Μία συναφής πηγή από την οποία προέρχεται η περιγραφόμενη πηγή. 
Η περιγραφόμενη πηγή μπορεί να προέρχεται από μία συναφή πηγή συνολικά ή μερικώς. Προτεινόμενη καλή πρακτική είναι να αναγνωριστεί η συναφής πηγή μέσω ενός νήματος που ενσωματώνεται σε ένα επίσημο σύστημα αναγνώρισης.

Εδώ: τα διάφορα είδη μέσων όπου μπορεί να δημοσιευτεί μία δουλειά. 
Τα πιο συνηθισμένα είδη είναι:
• Βιβλία,
• Επιστημονικά Περιοδικά,
• Εργαστήρια,
• Συνέδρια,
• Διαδικασίες,
• Διατριβές, 
• Περιοδικά, 
• Εφημερίδες, 
• Ιστοσελίδες,
• Μη επίσημες Εκδόσεις
• κτλ"""@gr .


###  http://purl.org/dc/elements/1.1/subject
<http://purl.org/dc/elements/1.1/subject> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain ccso:Resource ;
                                          rdfs:range xsd:string ;
                                          rdfs:comment """The topic of the resource.
Typically, the subject will be represented using keywords, key phrases, or classification codes. Recommended best practice is to use a controlled vocabulary."""@en ,
                                                       """Το θέμα μίας Πηγής. 
Τυπικά, το αντικείμενο μπορεί να αναπαραστεί χρησιμοποιώντας λέξεις κλειδιά, φράσεις κλειδιά, ή κωδικοί ταξινόμησης. 
Προτείνεται να γίνεται χρήση ελεγχόμενου λεξιλογίου."""@gr .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain ccso:Resource ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment """A name given to the resource.
Typically, a Title will be a name by which the resource is formally known."""@en ,
                                                     """Το όνομα που δίνεται σε μία πηγή. 
Τυπικά, ένας Τίτλος μπορεί να είναι ένα όνομα με βάση το οποίο η Πηγή είναι επισήμως γνωστή."""@gr .


###  http://purl.org/dc/elements/1.1/type
<http://purl.org/dc/elements/1.1/type> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain ccso:Resource ;
                                       rdfs:range xsd:string ;
                                       rdfs:comment """The nature or genre of the resource.
The various types of the work. The most common types of works are: 
• Article, 
• Chapter, 
• Paper, 
• Booklet, 
• Poster, 
• Thesis, 
• Software, 
• Specification, 
• Report, 
• UnofficialPublication, etc.
A Thesis could be BachelorThesis, MasterThesis or DoctoralThesis."""@en ,
                                                    """Η φύση ή το είδος της Πηγής. 
Οι διάφοροι τύποι του έργου. Οι πιο συνηθισμένοι τύποι έργου είναι:
• Άρθρο,
• Κεφάλαιο, 
• Επιστημονικό Άρθρο, 
• Φυλλάδιο, 
• Αφίσα, 
• Διπλωματική Εργασία,
• Λογισμικό, 
• Εξειδίκευση, 
• Αναφορά, 
• Ανεπίσημη Έκδοση, κτλ.
Η Διπλωματική Εργασία μπορεί να είναι Πτυχιακή Εργασία, Μεταπτυχιακή Εργασία ή Διδακτορική Διατριβή."""@gr .


###  http://schema.org/address
<http://schema.org/address> rdf:type owl:DatatypeProperty ;
                            rdfs:domain <http://schema.org/EducationalOrganization> ;
                            rdfs:range xsd:string ;
                            rdfs:comment "The physical address of an Organization."@en ,
                                         "Η διεύθυνση ενός Οργανισμού."@gr ;
                            rdfs:isDefinedBy <http://schema.org/address> .


###  http://schema.org/email
<http://schema.org/email> rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf ccso:eContactInfo ;
                          rdfs:range xsd:anyURI ;
                          rdfs:comment "H ηλεκτρινική διεύθυνση ενός Οργανισμού ή ενός Προσώπου (το προσωπικό eMail)."@gr ,
                                       "The eMail address of an Organization or a Person (personal eMail)."@en ;
                          rdfs:isDefinedBy <http://schema.org/email> .


###  http://schema.org/faxNumber
<http://schema.org/faxNumber> rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf ccso:phone ;
                              rdfs:domain [ rdf:type owl:Class ;
                                            owl:unionOf ( <http://schema.org/EducationalOrganization>
                                                          <http://xmlns.com/foaf/0.1/Person>
                                                        )
                                          ] ;
                              rdfs:range xsd:string ;
                              rdfs:comment "The fax number of an Organization or a Person."@en ;
                              rdfs:isDefinedBy <http://schema.org/faxNumber> ;
                              <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Ο αριθμός φαξ ενός Οργανισμού ή ενός Προσώπου."@gr .


###  http://schema.org/identifier
<http://schema.org/identifier> rdf:type owl:DatatypeProperty ;
                               rdfs:domain <http://schema.org/EducationalOrganization> ;
                               rdfs:range xsd:string ;
                               rdfs:comment "The organization identifier that uniquely identifies the legal entity of the organization."@en ;
                               rdfs:isDefinedBy "http://schema.org/identifier" ;
                               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Το αναγνωριστικό ενός Οργανισμού που χαρακτηρίζει αποκλειστικά τη νομική οντότητα του οργανισμού."@gr .


###  http://schema.org/legalName
<http://schema.org/legalName> rdf:type owl:DatatypeProperty ;
                              rdfs:domain <http://schema.org/EducationalOrganization> ;
                              rdfs:range xsd:string ;
                              rdfs:comment "The official name of the organization."@en ;
                              rdfs:isDefinedBy <http://schema.org/legalName> ;
                              <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Το επίσημο όνομα ενός οργανισμού."@gr .


###  http://schema.org/location
<http://schema.org/location> rdf:type owl:DatatypeProperty ;
                             rdfs:domain <http://schema.org/EducationalOrganization> ;
                             rdfs:range xsd:string ;
                             rdfs:comment "The location an organization is located."@en ,
                                          "Η τοποθεσία ενός οργανισμού."@gr ;
                             rdfs:isDefinedBy "http://schema.org/location" .


###  http://schema.org/logo
<http://schema.org/logo> rdf:type owl:DatatypeProperty ;
                         rdfs:domain <http://schema.org/EducationalOrganization> ;
                         rdfs:range xsd:anyURI ;
                         rdfs:comment "An associated image as the logo of an Organization."@en ,
                                      "Μία σχετική εικόνα ως λογότυπο ενός Οργανισμού."@gr ;
                         rdfs:isDefinedBy <http://schema.org/logo> .


###  http://schema.org/url
<http://schema.org/url> rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf ccso:eContactInfo ;
                        rdfs:domain [ rdf:type owl:Class ;
                                      owl:unionOf ( <http://schema.org/EducationalOrganization>
                                                    <http://xmlns.com/foaf/0.1/Person>
                                                    ccso:Resource
                                                  )
                                    ] ;
                        rdfs:range xsd:anyURI ;
                        rdfs:comment "The address of the webpage of an Organization, a Person or a Publication"@en ,
                                     "Η διεύθυνση μίας ιστοσελίδας ενός Οργανισμού ή ενός Προσώπου."@gr ;
                        rdfs:isDefinedBy <http://schema.org/url> ;
                        <http://www.w3.org/2004/02/skos/core#altLabel> "homepage"@en .


###  http://xmlns.com/foaf/0.1/age
<http://xmlns.com/foaf/0.1/age> rdf:type owl:DatatypeProperty ,
                                         owl:FunctionalProperty ;
                                rdfs:domain <http://xmlns.com/foaf/0.1/Agent> ;
                                rdfs:range rdfs:Literal ;
                                rdfs:comment "The age in years of some agent." ,
                                             "Η ηλικία σε έτη ενός εκπροσώπου."@gr ;
                                rdfs:isDefinedBy <http://xmlns.com/foaf/0.1/> ;
                                rdfs:label "age" ;
                                <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "unstable" .


###  http://xmlns.com/foaf/0.1/familyName
<http://xmlns.com/foaf/0.1/familyName> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                                       rdfs:range rdfs:Literal ;
                                       rdfs:comment "The family name of a person." ,
                                                    "Το Επώνυμο ενός Προσώπου."@gr ;
                                       rdfs:isDefinedBy <http://xmlns.com/foaf/0.1/> ;
                                       rdfs:label "familyName" ;
                                       <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "testing" .


###  http://xmlns.com/foaf/0.1/firstName
<http://xmlns.com/foaf/0.1/firstName> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                                      rdfs:range rdfs:Literal ;
                                      rdfs:comment "The first name of a person." ,
                                                   "Το κυρίως όνομα ενός Προσώπου."@gr ;
                                      rdfs:isDefinedBy <http://xmlns.com/foaf/0.1/> ;
                                      rdfs:label "firstName" ;
                                      <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "testing" .


###  http://xmlns.com/foaf/0.1/gender
<http://xmlns.com/foaf/0.1/gender> rdf:type owl:DatatypeProperty ,
                                            owl:FunctionalProperty ;
                                   rdfs:domain <http://xmlns.com/foaf/0.1/Agent> ;
                                   rdfs:range rdfs:Literal ;
                                   rdfs:comment "The gender of this Agent (typically but not necessarily 'male' or 'female')." ,
                                                "Το γένος (φύλο) ενός εκπροσώπου (τυπικά αλλά όχι απαραίτητα \"άνδρας\" ή \"γυναίκα\")."@gr ;
                                   rdfs:isDefinedBy <http://xmlns.com/foaf/0.1/> ;
                                   rdfs:label "gender" ;
                                   <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "testing" .


###  http://xmlns.com/foaf/0.1/lastName
<http://xmlns.com/foaf/0.1/lastName> rdf:type owl:DatatypeProperty ;
                                     rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                                     rdfs:range rdfs:Literal ;
                                     rdfs:comment "The last name of a person." ,
                                                  "Το επώνυμο ενός Προσώπου."@gr ;
                                     rdfs:isDefinedBy <http://xmlns.com/foaf/0.1/> ;
                                     rdfs:label "lastName" ;
                                     <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "testing" .


###  http://xmlns.com/foaf/0.1/title
<http://xmlns.com/foaf/0.1/title> rdf:type owl:DatatypeProperty ;
                                  rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                                  rdfs:range xsd:string ;
                                  rdfs:comment "Title (Mr, Mrs, Ms, Dr. etc)" ;
                                  rdfs:isDefinedBy <http://xmlns.com/foaf/0.1/> ;
                                  rdfs:label "title" ;
                                  <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "testing" ,
                                                                                             "Ο τίτλος (Κος, Κα, Δρ, κτλ)."@gr .


###  https://w3id.org/ccso/ccso#abbreviation
ccso:abbreviation rdf:type owl:DatatypeProperty ;
                  rdfs:domain ccso:Discipline ;
                  rdfs:range xsd:string ;
                  rdfs:comment """The shorten form of the Name of a Discipline.
The shorten form of the Name of Body of Knowledge (inherited property).
The shorten form of the Name of Area of Knowledge (inherited property).
The shorten form of the Name of Unit of Knowledge (inherited property)."""@en ,
                               """Η συντομευμένη μορφή του Ονόματους του Τομέα.
Η συντομευμένη μορφή του Ονόματος του Βασικού Κορμού της Γνώσης. 
Η συντομευμένη μορφή του Ονόματος του Πεδίου Γνώσης. 
Η συντομευμένη μορφή του Ονόματος της Μονάδας Γνώσης."""@gr .


###  https://w3id.org/ccso/ccso#academicYear
ccso:academicYear rdf:type owl:DatatypeProperty ;
                  rdfs:domain ccso:Syllabus ;
                  rdfs:range xsd:string ;
                  rdfs:comment "The academic year where the Course is offered and starts (e.g. 2015-16 or 2017-2018)."@en ,
                               "To Ακαδημαϊκό Έτος στο οποίο διδάσκεται το μάθημα (π.χ. 2015-16 ή 2017-2018)."@gr .


###  https://w3id.org/ccso/ccso#code
ccso:code rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:range rdfs:Literal ;
          rdfs:comment "The identifier that uniquely identifies a Study Programme in the national curriculum or either a Course or Syllabus in an Institute."@en ,
                       "Το αναγνωριστικό που χαρακτηρίζει ενιαία ένα Πρόγραμμα Σπουδών στο εθνικό πρόγραμμα μαθημάτων ή ένα Μάθημα ή ένα Περίγραμμα Σπουδών σε ένα Φορέα."@gr .


###  https://w3id.org/ccso/ccso#courseType
ccso:courseType rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( ccso:Course
                                            ccso:Syllabus
                                          )
                            ] ;
                rdfs:range [ rdf:type rdfs:Datatype ;
                             owl:oneOf [ rdf:type rdf:List ;
                                         rdf:first "Compulsory" ;
                                         rdf:rest [ rdf:type rdf:List ;
                                                    rdf:first "Core" ;
                                                    rdf:rest [ rdf:type rdf:List ;
                                                               rdf:first "Elective" ;
                                                               rdf:rest rdf:nil
                                                             ]
                                                  ]
                                       ]
                           ] ;
                rdfs:comment """The type of the Course. There are two types of course available:
•  Core: Courses that cover core topics and are deemed essential for an academic degree. 
•  Compulsory: A term with the same meaning as “Core” which is used in syllabuses. It’s also expresses the Courses that cover core topics and are deemed essential for an academic degree. 
•  Elective: a Course that the student can select from other alternative courses."""@en ,
                             """Ο τύπος ενός Μαθήματος. Υπάρχουν δύο διαθέσιμοι τύποι μαθημάτων. 
- Κορμού: Τα μαθήματα που καλύπτουν βασικά θέματα και κρίνονται απαραίτητα για την απόκτηση ακαδημαϊκού πτυχίου. 
- Υποχρεωτικά: Ένας όρος με το ίδιο νόημα όπως τα μαθήματα Κορμού που χρησιμοποιείται στα Περιγράμματα Σπουδών. Χαρακτηρίζει επίσης τα Μαθήματα που καλύπτουν βασικά θεμάτα και κρίνοντια απαραίτητα για την απόκτηση ακαδημαϊκού πτυχίου. 
- Επιλογής: ένα Μάθημα που ο φοιτητής μπορεί να επιλέξει από μία λίστα άλλων μαθημάτων."""@gr .


###  https://w3id.org/ccso/ccso#courseURL
ccso:courseURL rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf ccso:webaddressURL ;
               rdfs:domain ccso:Syllabus ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "The webpage of a Course where someone can find useful information about the Course, the Syllabus, the Assignments, etc."@en ;
               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Η ιστοσελίδα ενός Μαθήματος όπου μπορεί να βρει κανείς χρήσιμες πληροφορίες σχετικά με το Μάθημα, το Περίγραμμο Σπουδών, τις Εργασίες κτλ."@gr .


###  https://w3id.org/ccso/ccso#creditsECTS
ccso:creditsECTS rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain [ rdf:type owl:Class ;
                               owl:unionOf ( ccso:ProgramofStudy
                                             ccso:Syllabus
                                           )
                             ] ;
                 rdfs:range xsd:decimal ;
                 rdfs:comment "The credits that corresponds to a Study Program or a Course, according to European Credit Transfer and Accumulation System (ECTS)."@en ,
                              "Οι μονάδες που ανταποκρίνονται στο Πρόγραμμα Σπουδών ή σε ένα Μάθημα, σύμφωνα με το Ευρωπαϊκό σύστημα μεταφοράς και συσσώρευσης ακαδημαϊκών μονάδων (ECTS)."@gr .


###  https://w3id.org/ccso/ccso#csName
ccso:csName rdf:type owl:DatatypeProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                          owl:unionOf ( ccso:Course
                                        ccso:Syllabus
                                      )
                        ] ;
            rdfs:range xsd:string ;
            rdfs:comment "The official Name of a Course or a Syllabus."@en ,
                         "Το επίσημο Όνομα ενός Μαθήματος ή ενός Προγράμματος Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#dates
ccso:dates rdf:type owl:DatatypeProperty ;
           rdfs:comment """Super-property for properties related to date:
•  startDate 
•  endDate 
•  EnrollmentDate
•  graduationDate 
•  pubDate"""@en ,
                        """Υπερ-ιδιότητα για ιδιότητες σχετικές με ημερομηνίες:
•  Ημερομηνία Έναρξης
•  Ημερομηνία Λήξης
•  Ημερομηνία Εγγραφής
•  Ημερομηνία Αποφοίτησης
•  Ημερομηνία pub"""@gr .


###  https://w3id.org/ccso/ccso#degreeTitle
ccso:degreeTitle rdf:type owl:DatatypeProperty ;
                 rdfs:domain ccso:ProgramofStudy ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The official title of the Degree that awarded to the students upon a successful completion of Study Program in an educational institution."@en ,
                              "Ο επίσημος τίτλος του Πτυχίου που έχει απονεμηθεί στους φοιτητές με την επιτυχή ολοκήρωση του Προγράμματος Σπουδών σε ένα εκπαιδευτικό ίδρυμα."@gr .


###  https://w3id.org/ccso/ccso#degreeType
ccso:degreeType rdf:type owl:DatatypeProperty ;
                rdfs:domain ccso:ProgramofStudy ;
                rdfs:range xsd:string ;
                rdfs:comment """The various types of studies and degrees.
A specific list of allowed values  in this property can also be used:
•  Bachelor of Science
•  Bachelor of Arts
•  Bachelor of Business Administration
•  Master of Science
•  Master of Arts
•  Master of Business Administration
•  Doctor of Philosophy"""@en ,
                             """Οι διάφοροι τύποι σπουδών και πτυχίων. 
Μπορεί επίσης να χρησιμοποιηθεί μία συγκεκριμένη λίστα με στοιχεία για αυτή την ιδιότητα:
•  Bachelor (Πτυχίο) στις Επιστήμες
•  Bachelor (Πτυχίο) στις Τέχνες
•  Bachelor (Πτυχίο) στη Διοίκηση Επιχειρήσεων
•  Μεταπτυχιακό στις Επιστήμες
•  Μεταπτυχιακό στις Τέχνες
•  Μεταπτυχιακό στη Διοίκηση Επιχειρήσεων
•  Διδακτορικός Τίτλος"""@gr .


###  https://w3id.org/ccso/ccso#degreeURL
ccso:degreeURL rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf ccso:webaddressURL ;
               rdfs:domain ccso:ProgramofStudy ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "The URL of the official webpage with information about the Degree."@en ;
               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Το URL της επίσημης ιστοσελίδας με πληροφορίες σχετικά με το Πτυχίο."@gr .


###  https://w3id.org/ccso/ccso#description
ccso:description rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:comment """Description of a concept such as:
•  Course
•  Syllabus
•  Event
•  Publication
•  TeachingEvaluationMethod"""@en ,
                              """Περιγραφή μίας έννοιας όπως:
•  Μάθημα
•  Περίγραμμα Σπουδών
•  Γεγονός
•  Έκδοση
•  Μέθοδος Εκπαιδευτικής Αξιολόγησης"""@gr .


###  https://w3id.org/ccso/ccso#duration
ccso:duration rdf:type owl:DatatypeProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( ccso:Event
                                          ccso:ProgramofStudy
                                          ccso:Syllabus
                                          ccso:Topic
                                        )
                          ] ;
              rdfs:range xsd:duration ;
              rdfs:comment """The type represents the duration of time of the following concepts:
•  ProgramofStudy
•  Syllabus
•  Event: represents the minimum amount of time that is required in order to reach the sufficient depth of coverage.
•  Topic.
It is expressed as a number of years, months, days, hours, minutes, and seconds. Valid examples: P4Y=4 years, P6M=6 months, PT2H45M=2 hours and 45 minutes, PT50M=50 minutes."""@en ,
                           """Αυτός ο τύπος αναπαριστά τη διάρκεια των παρακάτω εννοιών:
•  Πρόγραμμα Σπουδών 
•  Περίγραμμα Σπουδών 
•  Γεγονός: αναπαριστά τον ελάχιστο χρόνο που απαιτείται προκειμένου να καλυφθεί επαρκώς
Αποτυπώνεται ως ένας αριθμός σε χρόνια, μήνες, μέρες, ώρες, λεπτά και δευτερόλεπτα. Παραδείγμα που ισχύουν: P4Y=4 χρόνια, P6M=6 μήνες, PT2H45M=2 ώρες και 45 λεπτά, PT50M=50 λεπτά."""@gr ;
              rdfs:seeAlso <http://www.datypic.com/sc/xsd11/t-xsd_duration.html> .


###  https://w3id.org/ccso/ccso#eClassURL
ccso:eClassURL rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf ccso:webaddressURL ;
               rdfs:domain ccso:Syllabus ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "The URL of the Course’s eClass platform."@en ;
               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "To URL της πλατφόρμας eClass του Μαθήματος."@gr .


###  https://w3id.org/ccso/ccso#eContactInfo
ccso:eContactInfo rdf:type owl:DatatypeProperty ;
                  rdfs:comment "Contact Information of a Person or an Organization for Electonic communication."@en ,
                               "Στοιχεία επαφής ενός Προσώπου ή ενός Οργανισμού για Ηλεκτρονική Επικοινωνία."@gr .


###  https://w3id.org/ccso/ccso#endDate
ccso:endDate rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf ccso:dates ;
             rdfs:domain ccso:Syllabus ;
             rdfs:range xsd:date ;
             rdfs:comment "The date that the course lessons end (e.g. 2018-01-29)."@en ,
                          "Η ημερομηνία που λήγουν τα μαθήματα."@gr ;
             rdfs:seeAlso <http://www.datypic.com/sc/xsd11/t-xsd_date.html> .


###  https://w3id.org/ccso/ccso#enrollmentDate
ccso:enrollmentDate rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf ccso:dates ;
                    rdfs:domain ccso:Student ;
                    rdfs:range xsd:date ;
                    rdfs:comment "The exact date that student has enrolled in a Study Program (e.g. 2016-09-01)."@en ,
                                 "Η ακριβής ημερομηνία όπου ο Φοιτητής εγγράφεται στο Πρόγραμμα Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#evaluationInfo
ccso:evaluationInfo rdf:type owl:DatatypeProperty ;
                    rdfs:domain ccso:Syllabus ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Information about Evaluation and Performance of the Course."@en ,
                                 "Πληροφορίες σχετικά με την Αξιολόγηση και Επίδοση σε ένα Μάθημα."@gr .


###  https://w3id.org/ccso/ccso#eventClassroom
ccso:eventClassroom rdf:type owl:DatatypeProperty ;
                    rdfs:domain ccso:Event ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The classroom, laboratory or any other location that the Event takes place."@en ,
                                 "Η αίθουσα, το εργαστήριο ή οποιοσδήποτε άλλος χώρος που ένα Γεγονός λαμβάνει χώρα."@gr .


###  https://w3id.org/ccso/ccso#eventDateTime
ccso:eventDateTime rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf ccso:dates ;
                   rdfs:domain ccso:Event ;
                   rdfs:range xsd:dateTime ;
                   rdfs:comment "H ημερομηνία και η ώρα που το γεγονός λαμβάνει χώρα. Αν το γεγονός διαρκεί περισσότερες από μια φορές, τότε η τιμή αφορά την ημερομηνία έναρξης του γεγονότος  (π.χ. 2018-03-14T12:30:00 σημαίνει 12:30 μμ στις 14 Μαρτίου, 2018)."@gr ,
                                "The date and time the Event occurs. If the event lasts more one time then the value is the date the event is starting (e.g. 2018-03-14T12:30:00 means 12:30 pm at 14 March, 2018)."@en ;
                   rdfs:seeAlso <http://www.datypic.com/sc/xsd11/t-xsd_dateTime.html> .


###  https://w3id.org/ccso/ccso#eventWeekNo
ccso:eventWeekNo rdf:type owl:DatatypeProperty ;
                 rdfs:domain ccso:Event ;
                 rdfs:range xsd:short ;
                 rdfs:comment "The number of the week in the semester of the Course that the Event occurs."@en ,
                              "Ο αριθμός της εβδομάδας σε ένα εξάμηνο ενός Μαθήματος που το γεγονός λαμβάνει χώρα."@gr .


###  https://w3id.org/ccso/ccso#eventWorkload
ccso:eventWorkload rdf:type owl:DatatypeProperty ;
                   rdfs:domain ccso:Event ;
                   rdfs:range xsd:duration ;
                   rdfs:comment "The workload in hours that required for the learning activities of an Event; the duration of the Event is not included (e.g. PT4H30M=4 hours and 30 minutes, PT90M=90 minutes)."@en ,
                                "Η δουλειά σε ώρες που απαιτείται για τις μαθησιακές δραστηριότητες ενός Γεγονότος. Η διάρκεια του γεγονότος δε περιλαμβάνεται (Π.χ. PT4H30M=4 ώρες και 30 λεπτά, PT90M=90 λεπτά)."@gr .


###  https://w3id.org/ccso/ccso#fsName
ccso:fsName rdf:type owl:DatatypeProperty ;
            rdfs:domain ccso:FieldofStudy ;
            rdfs:range xsd:string ;
            rdfs:comment """Name of a Discipline.
Name of Body of Knowledge (inherited property).
Name of Area of Knowledge (inherited property).
Name of Unit of Knowledge  (inherited property)."""@en ,
                         """Το όνομα ενός Τομέα. 
Το όνομα ενός Βασικού Κορμού Γνώσης (inherited property). 
Το όνομα μίας Περιοχής Γνώσης (inherited property). 
Το όνομα μίας Μονάδας Γνώσης (inherited property)."""@gr .


###  https://w3id.org/ccso/ccso#fsTopic
ccso:fsTopic rdf:type owl:DatatypeProperty ;
             rdfs:domain [ rdf:type owl:Class ;
                           owl:unionOf ( ccso:KnowledgeArea
                                         ccso:KnowledgeBody
                                         ccso:KnowledgeUnit
                                       )
                         ] ;
             rdfs:range xsd:string ;
             rdfs:comment """Topic of Body of Knowledge.
Topic of Area of Knowledge.
Topic of Unit of Knowledge."""@en ,
                          """Το θέμα ενός Βασικού Κορμού Γνώσης.
Το θέμα μίας Περιοχής Γνώσης. 
Το θέμα μίας Μονάδας Γνώσης."""@gr .


###  https://w3id.org/ccso/ccso#graduationDate
ccso:graduationDate rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf ccso:dates ;
                    rdfs:domain ccso:Student ;
                    rdfs:range xsd:date ;
                    rdfs:comment "The exact date that student has graduated a Study Program (e.g. 2017-03-15)."@en ,
                                 "Η ακριβής ημερομηνία που ο Φοιτητής έχει αποφοιτήσει από ένα Πρόγραμμα Σπουδών  (π.χ. 2017-03-15)."@gr .


###  https://w3id.org/ccso/ccso#homePhone
ccso:homePhone rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf ccso:phone ;
               rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
               rdfs:range xsd:string ;
               rdfs:comment "The phone number at the home of a person."@en ;
               rdfs:isDefinedBy <http://schema.org/telephone> ;
               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Ο αριθμός τηλεφώνου στο σπίτι ενός Προσώπου."@gr .


###  https://w3id.org/ccso/ccso#label
ccso:label rdf:type owl:DatatypeProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( ccso:Event
                                       ccso:LearningOutcome
                                       ccso:Topic
                                     )
                       ] ;
           rdfs:range xsd:string ;
           rdfs:comment "The Name of an Event, a Topic or a LearningOutcome."@en ,
                        "Το Όνομα ενός Γεγονότος, ενός Θέματος ή ενός Μαθησιακού Αποτελέσματος."@gr .


###  https://w3id.org/ccso/ccso#language
ccso:language rdf:type owl:DatatypeProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( ccso:Event
                                          ccso:Syllabus
                                        )
                          ] ;
              rdfs:range xsd:language ;
              rdfs:comment "The Language that used during the lessons, at the assignments and at the evaluation tests of a Course.(e.g. 'en' for English, 'gr' for Greek)."@en ,
                           "Η Γλώσσα που χρησιμοποιείται στη διάρκεια των μαθημάτων, στις εργασίες και στα τεστ αξιολόγησης ενός Μαθήματος (π.χ. 'en' για Αγγλικά, 'gr' για Ελληνικά)."@gr ;
              rdfs:seeAlso <http://www.datypic.com/sc/xsd11/t-xsd_language.html> .


###  https://w3id.org/ccso/ccso#levelofMastery
ccso:levelofMastery rdf:type owl:DatatypeProperty ;
                    rdfs:domain ccso:LearningOutcome ;
                    rdfs:range [ rdf:type rdfs:Datatype ;
                                 owl:oneOf [ rdf:type rdf:List ;
                                             rdf:first "Assessment" ;
                                             rdf:rest [ rdf:type rdf:List ;
                                                        rdf:first "Familiarity" ;
                                                        rdf:rest [ rdf:type rdf:List ;
                                                                   rdf:first "Usage" ;
                                                                   rdf:rest rdf:nil
                                                                 ]
                                                      ]
                                           ]
                               ] ;
                    rdfs:comment """Each Learning Outcome has an associated Level of Mastery students are expected to achieve with respect to the Topics specified.
There are three Level of Mastery:
•  Familiarity:  student understands what a concept is or what it means.
•  Usage:  student is able to use and apply a concept.
•  Assessment:  student is able to consider a concept from multiple viewpoints and select the appropriate approach for a problem."""@en ,
                                 """Κάθε Μαθησιακό Αποτέλεσμα συνδέεται με ένα Επίπεδο Κεκτημένης Γνώσης που αναμένεται να έχουν οι φοιτητές σε τρεις συγκεκριμένους τομείς:
•  Εξοικείωση: όταν ο φοιτητής καταλαβαίνει τι είναι ή τι σημαίνει μία έννοια. 
•  Χρήση/Εφαρμογή: όταν ο φοιτητής μπορεί να χρησιμοποιήσει ή να εφαρμόσει μία έννοια. 
•  Αξιολόγηση: όταν ο φοιτητής μπορεί να εξετάσει μία έννοια από διάφορες οπτικές και να διαλέξει την κατάλληλη προσέγγιση για ένα πρόβλημα."""@gr .


###  https://w3id.org/ccso/ccso#mediaUsed
ccso:mediaUsed rdf:type owl:DatatypeProperty ;
               rdfs:domain ccso:TeachingEvaluationMethod ;
               rdfs:range xsd:string ;
               rdfs:comment "The devices, tools and objects that are used to store and deliver teaching and learning content and data."@en ,
                            "Οι συσκευές, τα εργαλεία και τα αντικείμενα που χρησιμοποιούνται για να αποθηκεύεται και να διανέμεται το μαθησιακό περιεχόμενο και τα σχετικά με αυτό δεδομένα."@gr .


###  https://w3id.org/ccso/ccso#methodName
ccso:methodName rdf:type owl:DatatypeProperty ;
                rdfs:domain ccso:TeachingEvaluationMethod ;
                rdfs:range [ rdf:type rdfs:Datatype ;
                             owl:oneOf [ rdf:type rdf:List ;
                                         rdf:first "Demonstration" ;
                                         rdf:rest [ rdf:type rdf:List ;
                                                    rdf:first "Discussion" ;
                                                    rdf:rest [ rdf:type rdf:List ;
                                                               rdf:first "Homework" ;
                                                               rdf:rest [ rdf:type rdf:List ;
                                                                          rdf:first "Laboratory" ;
                                                                          rdf:rest [ rdf:type rdf:List ;
                                                                                     rdf:first "Lecture" ;
                                                                                     rdf:rest [ rdf:type rdf:List ;
                                                                                                rdf:first "OralExamination" ;
                                                                                                rdf:rest [ rdf:type rdf:List ;
                                                                                                           rdf:first "Project" ;
                                                                                                           rdf:rest [ rdf:type rdf:List ;
                                                                                                                      rdf:first "Seminar" ;
                                                                                                                      rdf:rest [ rdf:type rdf:List ;
                                                                                                                                 rdf:first "Study" ;
                                                                                                                                 rdf:rest [ rdf:type rdf:List ;
                                                                                                                                            rdf:first "WrittenExamination" ;
                                                                                                                                            rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                       rdf:first "other" ;
                                                                                                                                                       rdf:rest rdf:nil
                                                                                                                                                     ]
                                                                                                                                          ]
                                                                                                                               ]
                                                                                                                    ]
                                                                                                         ]
                                                                                              ]
                                                                                   ]
                                                                        ]
                                                             ]
                                                  ]
                                       ]
                           ] ;
                rdfs:comment """The name of the Method that is followed in a Teaching or Evaluation Event.
There is a specific list of allowed values, for this property: 
•  Lecture: the instructor oral presents the subject or teaches people with little interaction.
•  Demonstration: involves showing by reason or proof, explaining or making clear by use of examples or experiments.
•  Discussion: the subject is being examined and discussed  in the classroom where each student has equal opportunity to interact and put forth his views.
•  Seminar: the students prepare by themselves and present their work for discussion and critique.
•  Study: the instructor assigns readings for each session which are then discussed in a meeting or a conference.
•  Homework: students are writing short or long papers or essays about a topic, solving problem sets, etc.
•  Laboratory: most of the work is taken place in a laboratory.
•  Project: students are organized in one or more groups, work on a topic and meet with the instructor weekly for discussion and guidance.
•  OralExam: the examiner poses questions to the student or group of students who have to answer in order to demonstrate sufficient knowledge about the subject.
•  WrittenExam: the students participate in a written examination which intended to measure student’s knowledge, skills and attitude."""@en ,
                             """Το όνομα της μεθόδου που ακολουθείται σε μια διδασκαλία ή σε μία αξιολόγηση.
Υπάρχει ένας συγκεκριμένος κατάλογος επιτρεπόμενων τιμών, για αυτήν την ιδιότητα:
•  Διάλεξη: ο εκπαιδευτής παρουσιάζει προφορικά το θέμα ή διδάσκει άτομα με ένα μικρό επίπεδο αλληλεπίδρασης.
•  Επίδειξη: περιλαμβάνει την επίδειξη με βάση τα αιτία ή με αποδείξεις, εξηγώντας ή διευκρινίζοντας με τη χρήση παραδειγμάτων ή πειραμάτων.
•  Συζήτηση: το θέμα εξετάζεται και συζητείται στην τάξη, όπου ο κάθε φοιτητής έχει ίσες ευκαιρίες με τους υπόλοιπους να αλληλεπιδράσει και να εκθέσει τις απόψεις του.
•  Σεμινάριο: οι φοιτητές προετοιμάζονται από μόνοι τους και παρουσιάζουν το έργο τους για συζήτηση και κριτική.
•  Μελέτη: ο εκπαιδευτής αναθέτει κείμενα/εργασίες για κάθε συνάντηση, τα οποία στη συνέχεια συζητούνται σε μια συνάντηση ή σε μια διάσκεψη.
•  Εργασία στο σπίτι: οι φοιτητές γράφουν μικρά ή μεγάλα κείμενα ή δοκίμια για ένα θέμα, επιλύουν προβλήματα κ.λπ.
•  Εργαστήριο: το μεγαλύτερο μέρος των εργασιών πραγματοποιείται σε εργαστήριο.
•  Έργο: οι φοιτητές οργανώνονται σε μία ή περισσότερες ομάδες, εργάζονται πάνω σε ένα θέμα και συναντώνται με τον εκπαιδευτή εβδομαδιαίως για συζήτηση και καθοδήγηση.
•  OralExam: ο εξεταστής θέτει ερωτήσεις στον φοιτητή ή την ομάδα των φοιτητών που πρέπει να απαντήσουν για να δείξουν την επαρκή γνώση σχετικά με το εξεταζόμενο θέμα.
•  WrittenExam: οι φοιτητές συμμετέχουν σε γραπτή εξέταση που αποσκοπεί στη αριθμητική αξιολόγηση των γνώσεων, δεξιοτήτων και ικανοτήτων τους."""@gr .


###  https://w3id.org/ccso/ccso#mobilePhone
ccso:mobilePhone rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf ccso:phone ;
                 rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The mobile’s phone number of a person."@en ;
                 rdfs:isDefinedBy <http://schema.org/telephone> ;
                 <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Ο αριθμός του κινητού τηλεφώνου ενός Προσώπου."@gr .


###  https://w3id.org/ccso/ccso#offeredtoErasmus
ccso:offeredtoErasmus rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain ccso:Syllabus ;
                      rdfs:range xsd:boolean ;
                      rdfs:comment "A Course can be offered to Erasmus students or not."@en ,
                                   "Το Μάθημα μπορεί να προσφερθεί σε φοιτητές Erasmus ή όχι."@gr .


###  https://w3id.org/ccso/ccso#officeHours
ccso:officeHours rdf:type owl:DatatypeProperty ;
                 rdfs:domain ccso:Employee ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Dates and time that the Person is available at his office"@en ,
                              "Οι ημερομηνίες και οι ώρες που ένα Πρόσωπο είναι διαθέσιμο στο γραφείο του."@gr .


###  https://w3id.org/ccso/ccso#officeNo
ccso:officeNo rdf:type owl:DatatypeProperty ;
              rdfs:domain ccso:Employee ;
              rdfs:range xsd:string ;
              rdfs:comment "The number and building of employee’s office."@en ,
                           "Ο αριθμός και το κτήριο όπου βρίσκεται το γραφείο ενός εργαζόμενου."@gr .


###  https://w3id.org/ccso/ccso#personID
ccso:personID rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
              rdfs:range rdfs:Literal ;
              rdfs:comment "Person’s identifier that uniquely identifies a person."@en ;
              <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Το αναγνωριστικό ενός προσώπου που χαρακτηρίζει ένα πρόσωπο."@gr .


###  https://w3id.org/ccso/ccso#phone
ccso:phone rdf:type owl:DatatypeProperty ;
           rdfs:comment "Contact numbers of a Person or an Organization for phonetic communication."@en ;
           <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Οι αριθμοί επικοινωνίας ενός Προσώπου ή ενός Οργανισμού για τηλεφωνική επικοινωνία."@gr .


###  https://w3id.org/ccso/ccso#profilePic
ccso:profilePic rdf:type owl:DatatypeProperty ;
                rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
                rdfs:range xsd:anyURI ;
                rdfs:comment "An associated profile picture of a person."@en ;
                <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Μία σχετική φωτογραφία προφίλ ενός προσώπου."@gr .


###  https://w3id.org/ccso/ccso#psName
ccso:psName rdf:type owl:DatatypeProperty ;
            rdfs:domain ccso:ProgramofStudy ;
            rdfs:range xsd:string ;
            rdfs:comment "The official Name of Program of Study."@en ;
            <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Το επίσημο όνομα ενός Πρoγράμματος Σπουδών."@gr .


###  https://w3id.org/ccso/ccso#pubURL
ccso:pubURL rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf ccso:webaddressURL ;
            rdfs:range xsd:string ;
            rdfs:comment "The URL of the published work."@en ;
            <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "To URL των έργων που έχουν εκδοθεί."@gr .


###  https://w3id.org/ccso/ccso#resourceCitation
ccso:resourceCitation rdf:type owl:DatatypeProperty ;
                      rdfs:domain ccso:Resource ;
                      rdfs:range xsd:string ;
                      rdfs:comment "The official cited reference for the published learning material or  unofficial in case it isn’t published."@en ;
                      <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Η επίσημη αναφορά που έχει παρατεθεί σε ένα μαθησιακό υλικό που έχει εκδοθεί ή η ανεπίσημη σε περίπτωση που δεν έχει εκδοθεί."@gr .


###  https://w3id.org/ccso/ccso#semesterinProgram
ccso:semesterinProgram rdf:type owl:DatatypeProperty ;
                       rdfs:domain ccso:Syllabus ;
                       rdfs:range xsd:short ;
                       rdfs:comment "The number of semester within the ProgramofStudy where the Course is offered and starts (e.g. 3)."@en ;
                       <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Ο αριθμός του εξαμήνου στο Πρόγραμμα Σπουδών όπου το Μάθημα προσφέρεται και ξεκινά (π.χ. 3)."@gr .


###  https://w3id.org/ccso/ccso#staffPosition
ccso:staffPosition rdf:type owl:DatatypeProperty ;
                   rdfs:domain ccso:Employee ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The position where a person is being employed in the organization."@en ;
                   <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Η θέση στην οποία ένα πρόσωπο απασχολείται μέσα σε έναν οργανισμό."@gr .


###  https://w3id.org/ccso/ccso#staffSpecialization
ccso:staffSpecialization rdf:type owl:DatatypeProperty ;
                         rdfs:domain ccso:Employee ;
                         rdfs:range xsd:string ;
                         rdfs:comment "The subject that a person is specialist and practices in."@en ;
                         <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Το αντικείμενο στο οποίο ένα πρόσωπο είναι εξειδικευμένο και εξασκεί."@gr .


###  https://w3id.org/ccso/ccso#startDate
ccso:startDate rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf ccso:dates ;
               rdfs:domain ccso:Syllabus ;
               rdfs:range xsd:date ;
               rdfs:comment "The date that the course lessons start (e.g. 2017-10-01)."@en ,
                            "Η ημερομηνία που ένα μάθημα ξεκινά."@gr ;
               rdfs:seeAlso <http://www.datypic.com/sc/xsd11/t-xsd_date.html> .


###  https://w3id.org/ccso/ccso#topicType
ccso:topicType rdf:type owl:DatatypeProperty ;
               rdfs:domain ccso:Topic ;
               rdfs:range [ rdf:type rdfs:Datatype ;
                            owl:oneOf [ rdf:type rdf:List ;
                                        rdf:first "Core" ;
                                        rdf:rest [ rdf:type rdf:List ;
                                                   rdf:first "Core-Tier-1" ;
                                                   rdf:rest [ rdf:type rdf:List ;
                                                              rdf:first "Core-Tier-2" ;
                                                              rdf:rest [ rdf:type rdf:List ;
                                                                         rdf:first "Elective" ;
                                                                         rdf:rest rdf:nil
                                                                       ]
                                                            ]
                                                 ]
                                      ]
                          ] ;
               rdfs:comment """The type of the Topic defines the importance of the topic for inclusion in a study programme.
The types of a topic could be the values: 
•  Core
•  Core-Tier-1
•  Core-Tier-2
•  Elective"""@en ;
               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> """Ο τύπος ενός Θέματος καθορίζει τη σημασία ενός θέματος προκειμένου να συμπεριληφθεί σε ένα πρόγραμμα σπουδών. 
Οι τύπου ενός θέματος μπορεί να έχει τις εξής τιμές:
•  Κορμού
•  Κορμού - Βαθμίδα 1
•  Κορμού - Βαθμίδα 2
•  Επιλογής"""@gr .


###  https://w3id.org/ccso/ccso#versionNo
ccso:versionNo rdf:type owl:DatatypeProperty ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( ccso:Resource
                                           ccso:Syllabus
                                         )
                           ] ;
               rdfs:range xsd:decimal ;
               rdfs:comment """The version number of a Publication.
The version number of a Syllabus."""@en ;
               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> """Ο αριθμός έκδοσης μίας Δημοσίευσης. 
Ο αριθμός έκδοσης ενός Περιγράμματος Σπουδών."""@gr .


###  https://w3id.org/ccso/ccso#webaddressURL
ccso:webaddressURL rdf:type owl:DatatypeProperty ;
                   rdfs:comment """Super-property for properties related to URL:
•  degreeURL
•  courseURL
•  eClassURL
•  pubURL"""@en ;
                   <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> """Υπερ-ιδιότητα για ιδιότητες που σχετίζονται με ένα URL:
• degreeURL
• courseURL
• eClassURL
• pubURL"""@gr .


###  https://w3id.org/ccso/ccso#weeklyClassSchedule
ccso:weeklyClassSchedule rdf:type owl:DatatypeProperty ;
                         rdfs:domain ccso:Syllabus ;
                         rdfs:range xsd:string ;
                         rdfs:comment "The weekly class schedule presents the time, day and dates that the events of the Course are scheduled."@en ;
                         <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Το εβδομαδιαίο πρόγραμμα που περιλαμβάνει την ώρα, την ημέρα και τις ημερομηνίες του Μαθήματος όπως έχουν προγραμματιστεί."@gr .


###  https://w3id.org/ccso/ccso#weeklyHours
ccso:weeklyHours rdf:type owl:DatatypeProperty ;
                 rdfs:domain ccso:Syllabus ;
                 rdfs:range xsd:duration ;
                 rdfs:comment "The weekly teaching hours of the course."@en ;
                 <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Οι διδακτικές ώρες ενός μαθήματος μέσα σε μία εβδομάδα."@gr .


###  https://w3id.org/ccso/ccso#weeklyWorkload
ccso:weeklyWorkload rdf:type owl:DatatypeProperty ;
                    rdfs:domain ccso:Syllabus ;
                    rdfs:range xsd:duration ;
                    rdfs:comment "The workload in hours that required for the learning activities and assignments of a Course in weekly basis. The hours of the lessons are not included (e.g. PT3H50M=3 hours and 50 minutes, PT60M=60 minutes)."@en ;
                    <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Η δουλειά σε ώρες που απαιτούνται για τις μαθησιακές δραστηριότητες και τις εργασίες σε ένα Μάθημα σε εβδομαδιαία βάση. Οι ώρες των μαθημάτων δεν συμπεριλαμβάνονται (π.χ.  PT3H50M=3 ώρες και 50 λεπτά, PT60M=60 λεπτά)."@gr .


###  https://w3id.org/ccso/ccso#workEmail
ccso:workEmail rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf ccso:eContactInfo ;
               rdfs:domain <http://xmlns.com/foaf/0.1/Person> ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "The work eMail address of a person."@en ,
                            "Η ηλεκτρονική διεύθυνση εργασίας ενός Προσώπου."@gr ;
               rdfs:isDefinedBy <http://schema.org/email> .


###  https://w3id.org/ccso/ccso#workPhone
ccso:workPhone rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf ccso:phone ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( <http://schema.org/EducationalOrganization>
                                           <http://xmlns.com/foaf/0.1/Person>
                                         )
                           ] ;
               rdfs:range xsd:string ;
               rdfs:comment "The main phone number of an Organization or at the work of a Person."@en ;
               rdfs:isDefinedBy <http://schema.org/telephone> ;
               <http://www.w3.org/2003/06/sw-vocab-status/ns#term_status> "Ο κύριος αριθμός τηλεφώνου ενός οργανισμού ή της εργασίας ενός Προσώπου."@gr .


#################################################################
#    Classes
#################################################################

###  http://schema.org/EducationalOrganization
<http://schema.org/EducationalOrganization> rdf:type owl:Class ;
                                            rdfs:subClassOf <http://schema.org/Organization> ;
                                            owl:disjointWith ccso:Discipline ,
                                                             ccso:FieldofStudy ;
                                            rdfs:comment "An Organization designed to provide educational services and learning environments."@en ,
                                                         "Ένας Οργανισμός που έχει σχεδιαστεί για την παροχή εκπαιδευτικών υπηρεσιών και μαθησιακών περιβαλλόντων."@gr ;
                                            rdfs:isDefinedBy <http://schema.org/EducationalOrganization> ;
                                            rdfs:label "Εκπαιδευτικός Οργανισμός"@gr .


###  http://schema.org/Organization
<http://schema.org/Organization> rdf:type owl:Class ;
                                 rdfs:comment "An organization is an entity comprising multiple people, such as an institution or an association, that has a collective goal and is linked to an external environment."@en .


###  http://xmlns.com/foaf/0.1/Agent
<http://xmlns.com/foaf/0.1/Agent> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Person
<http://xmlns.com/foaf/0.1/Person> rdf:type owl:Class ;
                                   owl:disjointWith ccso:Discipline ,
                                                    ccso:FieldofStudy ;
                                   rdfs:comment "A person, a human being."@en ,
                                                "Ένας άνθρωπος."@gr ;
                                   rdfs:label "Άνθρωπος"@gr ,
                                              "Πρόσωπο"@gr .


###  https://w3id.org/ccso/ccso#AcademicStaff
ccso:AcademicStaff rdf:type owl:Class ;
                   rdfs:subClassOf ccso:Employee ;
                   owl:disjointWith ccso:Assistant ,
                                    ccso:Student ,
                                    ccso:TechnicalStaff ;
                   rdfs:comment "The academic staff of an institution, a school or a university such as professors of various ranks, lecturers and/or researchers. In North America the term Faculty is used instead."@en ,
                                "Το ακαδημαϊκό/εκπαιδευτικό προσωπικό ενός ιδρύματος, ενός σχολείου ή ενός πανεπιστημίου, όπως καθηγητές διαφόρων τάξεων, λέκτορες ή / και ερευνητές."@gr ;
                   rdfs:label "Aκαδημαϊκό προσωπικό"@gr ,
                              "Eκπαιδευτικό προσωπικό"@gr ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "Academic Staff"@en ,
                                                                  "Faculty"@en .


###  https://w3id.org/ccso/ccso#AdministrativeStaff
ccso:AdministrativeStaff rdf:type owl:Class ;
                         rdfs:subClassOf ccso:Employee ;
                         owl:disjointWith ccso:Assistant ,
                                          ccso:Student ,
                                          ccso:TechnicalStaff ;
                         rdfs:comment "An employee who conducts of the administrating of an educational organization."@en ,
                                      "Ένας εργαζόμενος που ασκεί τη διοίκηση ενός εκπαιδευτικού οργανισμού."@gr ;
                         rdfs:label "Διοικητικό Προσωπικό"@gr ;
                         <http://www.w3.org/2004/02/skos/core#altLabel> "Administrative Staff"@en .


###  https://w3id.org/ccso/ccso#Assistant
ccso:Assistant rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( <http://xmlns.com/foaf/0.1/Person>
                                                          [ rdf:type owl:Class ;
                                                            owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                            owl:onProperty ccso:assistsInCourse ;
                                                                            owl:someValuesFrom ccso:Syllabus
                                                                          ]
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty ccso:assistsInEvent ;
                                                                            owl:someValuesFrom ccso:Event
                                                                          ]
                                                                        )
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf ccso:Employee ;
               owl:disjointWith ccso:TechnicalStaff ,
                                ccso:UndergraduateStudent ;
               rdfs:comment "A person, usually an postgraduate student, who helps by assuming duties in lessons (TeachingAssistant), projects (ProjectAssistant), research (ResearchAssistant), etc."@en ,
                            "Κάποιο άτομο, συνήθως ένας μεταπτυχιακός φοιτητής, ο οποίος βοηθά με την ανάληψη καθηκόντων σε μαθήματα (βοηθός διδασκαλίας), σε έργα (βοηθός έργου), σε έρευνα (βοηθός έρευνας) κλπ."@gr ;
               rdfs:label "Βοηθός"@gr .


###  https://w3id.org/ccso/ccso#Bachelor
ccso:Bachelor rdf:type owl:Class ;
              rdfs:subClassOf ccso:ProgramofStudy ;
              owl:disjointWith ccso:Certificate ,
                               ccso:Doctorate ,
                               ccso:Master ,
                               ccso:SchoolDiploma ;
              rdfs:comment "The undergraduate academic degree awarded by universities and colleges, known as Bachelor’s degree."@en ,
                           "Το προπτυχιακό ακαδημαϊκό δίπλωμα που απονέμεται από πανεπιστήμια και κολέγια."@gr ;
              rdfs:label "Προπτυχιακό Ακαδημαϊκό Δίπλωμα"@gr ,
                         "Πτυχίο"@gr .


###  https://w3id.org/ccso/ccso#Certificate
ccso:Certificate rdf:type owl:Class ;
                 rdfs:subClassOf ccso:ProgramofStudy ;
                 owl:disjointWith ccso:Doctorate ,
                                  ccso:Master ,
                                  ccso:SchoolDiploma ;
                 rdfs:comment "The diplomas that cannot be classified to the other subclasses such as Vocation diploma, Teaching diploma, Languages diploma, etc."@en ,
                              "Τα διπλώματα που δεν μπορούν να ταξινομηθούν στις άλλες υποκατηγορίες, όπως το δίπλωμα Επαγγελματικής Κατάρτισης, το δίπλωμα Διδακτικής Επάρκειας, το δίπλωμα Ξένων Γλωσσών, κ.α."@gr ;
                 rdfs:label "Πιστοποιητικό Γνώσεων"@gr ,
                            "Πιστοποιητικό Ικανοτήτων"@gr ,
                            "Πιστοποιητικό Σπουδών"@gr .


###  https://w3id.org/ccso/ccso#Course
ccso:Course rdf:type owl:Class ;
            rdfs:comment "An institutional unit of teaching that lasts one academic term with a specific subject, usually is led by one or more instructors and has a fixed group of students."@en ,
                         "Μια μονάδα διδασκαλίας εκπαιδευτικού ιδρύματος που διαρκεί έναν ακαδημαϊκό εξάμηνο με ένα συγκεκριμένο θέμα, συνήθως διδάσκεται από έναν ή περισσότερους εκπαιδευτές και απευθύνεται σε μια σταθερή ομάδα μαθητών."@gr ;
            rdfs:label "Μάθημα"@gr ,
                       "Σεμινάριο"@gr .


###  https://w3id.org/ccso/ccso#DateTimeDuration
ccso:DateTimeDuration rdf:type owl:Class .


###  https://w3id.org/ccso/ccso#Department
ccso:Department rdf:type owl:Class ;
                rdfs:subClassOf <http://schema.org/EducationalOrganization> ;
                owl:disjointWith ccso:School ,
                                 ccso:University ;
                rdfs:comment "A division of a School (or College) devoted to a particular academic degree."@en ,
                             "Ένα τμήμα μίας Σχολής (ή Kολλεγίου) που προσφέρει ένα συγκεκριμένο ακαδημαϊκό πτυχίο."@gr ;
                rdfs:label "Τμήμα"@gr .


###  https://w3id.org/ccso/ccso#Discipline
ccso:Discipline rdf:type owl:Class ;
                rdfs:subClassOf ccso:FieldofStudy ;
                rdfs:comment "An ‘Academic Discipline' (here 'Discipline') is a branch of knowledge or a field of study."@en ,
                             "Μία Επιστήμη ή 'Aκαδημαϊκή Επιστήμη' αντιπροσωπεύει ένα κλάδο γνώσης ή πεδίο σπουδών."@gr ;
                rdfs:label "Επιστήμη"@gr ;
                rdfs:seeAlso <https://en.wikipedia.org/wiki/Outline_of_academic_disciplines> ;
                <http://www.w3.org/2004/02/skos/core#altLabel> "Academic Discipline"@en .


###  https://w3id.org/ccso/ccso#Doctorate
ccso:Doctorate rdf:type owl:Class ;
               rdfs:subClassOf ccso:ProgramofStudy ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty ccso:requiresProgram ;
                                 owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass ccso:Master
                               ] ;
               owl:disjointWith ccso:Master ,
                                ccso:SchoolDiploma ;
               rdfs:comment "The academic and research degree, also known as Doctor’s degree, awarded by universities that certifies the person as an expert of art or sciences in a field and qualifies to teach at the university level."@en ,
                            "Ο ακαδημαϊκός και ερευνητικός τίτλος, επίσης γνωστός ως Διδακτορικό δίπλωμα, απονέμεται από πανεπιστήμια που πιστοποιούν το άτομο ως ειδικός της τέχνης ή των επιστημών σε έναν τομέα και είναι ικανός να διδάσκει σε πανεπιστημιακό επίπεδο."@gr ;
               rdfs:label "Διδακτορικό"@gr ,
                          "Διδακτορικό Aκαδημαϊκό Δίπλωμα"@gr .


###  https://w3id.org/ccso/ccso#Employee
ccso:Employee rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( <http://xmlns.com/foaf/0.1/Person>
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty ccso:worksFor ;
                                                           owl:someValuesFrom <http://schema.org/EducationalOrganization>
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
              rdfs:comment "Employee of an organization."@en ,
                           "Εργαζόμενος σε κάποιον οργανισμό."@gr ;
              rdfs:label "Εργαζόμενος"@gr ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "Worker"@en .


###  https://w3id.org/ccso/ccso#EvaluationEvent
ccso:EvaluationEvent rdf:type owl:Class ;
                     rdfs:subClassOf ccso:Event ;
                     owl:disjointWith ccso:TeachingEvent ;
                     rdfs:comment "Events included in evaluation procedure."@en ,
                                  "Γεγονότα που συμπεριλαμβάνονται στη διαδικασία αξιολόγησης."@gr ;
                     rdfs:label "Εξέταση"@gr ,
                                "Συμβάν Εξετάσεων"@gr ;
                     <http://www.w3.org/2004/02/skos/core#altLabel> "Evaluation"@en ,
                                                                    "Examination"@en .


###  https://w3id.org/ccso/ccso#Event
ccso:Event rdf:type owl:Class ;
           rdfs:comment "All events that happen in a class within a course."@en ,
                        "Όλα τα γεγονότα που συμβαίνουν σε μια τάξη κατά τη διάρκεια του προγράμματος μαθημάτων."@gr ;
           rdfs:label "Συμβάν"@gr .


###  https://w3id.org/ccso/ccso#FieldofStudy
ccso:FieldofStudy rdf:type owl:Class ;
                  rdfs:comment "The root class of knowledge structure. It refers to the Academic Disciplines."@en ,
                               "Η κλάση-ρίζα της οργανωτικής δομής με τις έννοιες που αφορούν τη γνώση και αφορά όλες τις Ακαδημαϊκές επιστήμες."@gr ;
                  rdfs:label "Πεδίο Γνώσης"@gr ;
                  <http://www.w3.org/2004/02/skos/core#altLabel> "Field of Study"@en .


###  https://w3id.org/ccso/ccso#Institute
ccso:Institute rdf:type owl:Class ;
               rdfs:subClassOf <http://schema.org/EducationalOrganization> ;
               rdfs:comment "An autonomous educational institution which provides learning services in areas of Non-Formal Education."@en ,
                            "Ένα αυτόνομο εκπαιδευτικό ίδρυμα που παρέχει υπηρεσίες μάθησης σε περιοχές της Μη-Τυπικής Εκπαίδευσης."@gr ;
               rdfs:label "Ινστιτούτο"@gr .


###  https://w3id.org/ccso/ccso#KnowledgeArea
ccso:KnowledgeArea rdf:type owl:Class ;
                   rdfs:subClassOf ccso:FieldofStudy ;
                   rdfs:comment "Subjects of a Body of Knowledge."@en ,
                                "Θέματα ενός Σώματος Γνώσης (KnowledgeBody)."@gr ;
                   rdfs:label "Περιοχή Γνώσης"@gr ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "Area of Knowledge"@en .


###  https://w3id.org/ccso/ccso#KnowledgeBody
ccso:KnowledgeBody rdf:type owl:Class ;
                   rdfs:subClassOf ccso:FieldofStudy ;
                   rdfs:comment "Main knowledge body of a Discipline, a specification of the content to be covered in a curriculum."@en ,
                                "Το κύριο σώμα γνώσης μιας Επιστήμης, μια προδιαγραφή του περιεχομένου που πρέπει να καλύπτεται σε ένα πρόγραμμα σπουδών."@gr ;
                   rdfs:label "Κύριο Σώμα Γνώσης"@gr ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "Body of Knowledge"@en .


###  https://w3id.org/ccso/ccso#KnowledgeUnit
ccso:KnowledgeUnit rdf:type owl:Class ;
                   rdfs:subClassOf ccso:FieldofStudy ;
                   rdfs:comment "Part of a Knowledge Area."@en ,
                                "Μέρος μιας Περιοχής Γνώσης (KnowledgeArea)."@gr ;
                   rdfs:label "Μέρος Γνώσης μιας Περιοχής Γνώσης"@gr ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "Unit of Knowledge"@en .


###  https://w3id.org/ccso/ccso#LearningOutcome
ccso:LearningOutcome rdf:type owl:Class ;
                     rdfs:comment "The learning outcomes, specific knowledge, skills and competences, which the students will acquire with the successful completion of the course."@en ,
                                  "Τα μαθησιακά αποτελέσματα, οι ειδικές γνώσεις, δεξιότητες και ικανότητες, τις οποίες οι σπουδαστές θα αποκτήσουν με την επιτυχή ολοκλήρωση του μαθήματος."@gr ;
                     rdfs:label "Μαθησιακό Αποτέλεσμα"@gr ;
                     <http://www.w3.org/2004/02/skos/core#altLabel> "Learning Objective"@en .


###  https://w3id.org/ccso/ccso#Lecturer
ccso:Lecturer rdf:type owl:Class ;
              rdfs:subClassOf ccso:AcademicStaff ;
              rdfs:comment "An academic person at an early career stage with open-ended or tenured position in a university who teaches and conducts research."@en ,
                           "Ένα ακαδημαϊκό άτομο το οποίο βρίσκεται στο αρχικό στάδιο της σταδιοδρομίας του με αορίστου ή μόνιμη θέση σε ένα πανεπιστήμιο που διδάσκει και διεξάγει έρευνα."@gr ;
              rdfs:label "Λέκτορας"@gr .


###  https://w3id.org/ccso/ccso#Master
ccso:Master rdf:type owl:Class ;
            rdfs:subClassOf ccso:ProgramofStudy ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty ccso:requiresProgram ;
                              owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onClass ccso:Bachelor
                            ] ;
            owl:disjointWith ccso:SchoolDiploma ;
            rdfs:comment "The postgraduate academic degree, known as Master’s degree, awarded by universities or colleges upon completion of a course of study demonstrating mastery of a specific field of study or area of professional practice."@en ,
                         "Το μεταπτυχιακό ακαδημαϊκό δίπλωμα που απονέμεται από πανεπιστήμια ή κολέγια μετά την ολοκλήρωση ενός κύκλου σπουδών που αποδεικνύει την απόκτηση ειδικού πεδίου σπουδών ή τομέα επαγγελματικής πρακτικής."@gr ;
            rdfs:label "Μεταπτυχιακό"@gr ,
                       "Μεταπτυχιακό Aκαδημαϊκό Δίπλωμα"@gr .


###  https://w3id.org/ccso/ccso#PostgraduateStudent
ccso:PostgraduateStudent rdf:type owl:Class ;
                         owl:equivalentClass [ owl:intersectionOf ( ccso:Student
                                                                    [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty ccso:enrolledIn ;
                                                                                             owl:someValuesFrom ccso:Master
                                                                                           ]
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty ccso:hasDegree ;
                                                                                             owl:someValuesFrom ccso:Bachelor
                                                                                           ]
                                                                                         ) ;
                                                                      rdf:type owl:Class
                                                                    ]
                                                                  ) ;
                                               rdf:type owl:Class
                                             ] ;
                         rdfs:subClassOf ccso:Student ,
                                         [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                  owl:complementOf [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty ccso:enrolledIn ;
                                                                                     owl:someValuesFrom ccso:Bachelor
                                                                                   ]
                                                                ]
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty ccso:hasDegree ;
                                                                  owl:someValuesFrom ccso:Bachelor
                                                                ]
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty ccso:enrolledIn ;
                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass ccso:Master
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                         rdfs:comment "A student who own a Bachelor’s degree and studying for an academic or professional certificate."@en ,
                                      "Ένας φοιτητής που κατέχει πτυχίο Bachelor και σπουδάζει για ακαδημαϊκό ή επαγγελματικό πιστοποιητικό σπουδών."@gr ;
                         rdfs:label "Μεταπτυχιακός Φοιτητής"@gr ;
                         <http://www.w3.org/2004/02/skos/core#altLabel> "Postgraduate Student"@en .


###  https://w3id.org/ccso/ccso#Professor
ccso:Professor rdf:type owl:Class ;
               rdfs:subClassOf ccso:AcademicStaff ;
               rdfs:comment "An instructor that is an expert of art or sciences and participates in a program of study of an educational institution."@en ,
                            "Ο εκπαιδευτής που είναι ειδικός της τέχνης ή της επιστήμης και συμμετέχει σε πρόγραμμα σπουδών ενός εκπαιδευτικού ιδρύματος."@gr ;
               rdfs:label "Καθηγητής"@gr .


###  https://w3id.org/ccso/ccso#ProgramofStudy
ccso:ProgramofStudy rdf:type owl:Class ;
                    rdfs:comment "The degrees awarded to students upon a successful completion of a course of study in an educational institution."@en ,
                                 "Τα πτυχία που απονέμονται στους φοιτητές μετά την επιτυχή ολοκλήρωση ενός κύκλου σπουδών σε ένα εκπαιδευτικό ίδρυμα."@gr ;
                    rdfs:label "Τίτλος Προγράμματος Σπουδών"@gr ;
                    <http://www.w3.org/2004/02/skos/core#altLabel> "Institutional Degree"@en ,
                                                                   "Program of Study"@en ,
                                                                   "Programme of Study"@en .


###  https://w3id.org/ccso/ccso#Researcher
ccso:Researcher rdf:type owl:Class ;
                rdfs:subClassOf ccso:AcademicStaff ;
                rdfs:comment "An academic person that conducts research, participates in research projects or leads research groups."@en ,
                             "Μέλος του ακαδημαϊκού προσωπικού που διεξάγει έρευνα, συμμετέχει σε ερευνητικά έργα ή είναι υπεύθυνος ερευνητικών ομάδων."@gr ;
                rdfs:label "Ερευνητής"@gr .


###  https://w3id.org/ccso/ccso#Resource
ccso:Resource rdf:type owl:Class ;
              rdfs:comment """The teaching and learning resources that are being used during a course. Books, academic articles, notes as well as webpages, videos, images, audios and other stuff with educational interest for a course can be included to the learning material for a course.

The resource could be an official Publication.
A work of a person which its content is available to the general public. The content may vary; usually it refers to text, images, audio or visual content, software programs, etc. The text includes papers and articles in newspapers, magazines, books, journals, etc."""@en ,
                           """Οι πηγές διδασκαλίας και εκμάθησης που χρησιμοποιούνται κατά τη διάρκεια ενός μαθήματος. Βιβλία, ακαδημαϊκά άρθρα, σημειώσεις καθώς και ιστοσελίδες, βίντεο, εικόνες, ηχητικά και άλλα στοιχεία με εκπαιδευτικό ενδιαφέρον μπορούν να συμπεριληφθούν στο εκπαιδευτικό υλικό για ένα μάθημα.

Η πηγή ενδέχεται να αποτελεί επίησημη Δημοσίευση.
Ένα έργο ενός προσώπου, το περιεχόμενο του οποίου είναι διαθέσιμο στο ευρύ κοινό. Το περιεχόμενο ποικίλει. συνήθως αναφέρεται σε κείμενο, εικόνες, ηχητικό ή οπτικό περιεχόμενο, προγράμματα λογισμικού, κλπ. Το κείμενο περιλαμβάνει άρθρα και άρθρα σε εφημερίδες, περιοδικά, βιβλία, περιοδικά κλπ."""@gr ;
              rdfs:label "Πηγή"@gr ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "Learning Material"@en .


###  https://w3id.org/ccso/ccso#School
ccso:School rdf:type owl:Class ;
            rdfs:subClassOf <http://schema.org/EducationalOrganization> ;
            owl:disjointWith ccso:University ;
            rdfs:comment """A division within a university comprising one subject area, or a number of related subject areas. 
The American usage is followed where such divisions are referred to as Colleges or Schools rather than using the term Faculty which is used in other countries in order to avoid misunderstandings because the same term (Faculty) refers to the Academic staff of a University in American usage."""@en ,
                         "An institution that belongs to the Formal Education system of a country and is designed to provide learning environment for teaching students."@en ,
                         "Ένα ίδρυμα που ανήκει στο σύστημα τυπικής εκπαίδευσης μιας χώρας και έχει σχεδιαστεί για να παρέχει περιβάλλον μάθησης για τη διδασκαλία των μαθητών."@gr ,
                         """Ένα τμήμα ενός πανεπιστημίου που περιλαμβάνει ένα θεματικό πεδίο ή έναν αριθμό σχετικών θεματικών πεδίων. 
Ακολουθήθηκε η αμερικάνικη προσέγγιση όπου τέτοια τμήματα αναφέρονται ως Κολλέγια ή Σχολεία αντί να χρησιμοποιηθεί ο όρος Faculty που χρησιμοποιείται σε άλλες χώρες για να αποφευχθούν παρεξηγήσεις, επειδή ο ίδιος όρος (Faculty) στην Αμερική αναφέρεται στο Ακαδημαϊκό Προσωπικό ενός Πανεπιστημίου."""@gr ;
            rdfs:label "School"@en ,
                       "Κολλέγιο"@gr ,
                       "Σχολή"@gr ;
            <http://www.w3.org/2004/02/skos/core#altLabel> "College"@en .


###  https://w3id.org/ccso/ccso#SchoolDiploma
ccso:SchoolDiploma rdf:type owl:Class ;
                   rdfs:subClassOf ccso:ProgramofStudy ;
                   rdfs:comment "The graduation degrees provided by Primary and Secondary schools (Primary School, Secondary School and High School)."@en ,
                                "Τα πτυχία αποφοίτησης που δίδονται από σχολεία της Πρωτοβάθμιας και Δευτεροβάθμιας εκπαίδευσης (Δημοτικό, Γυμνάσιο και Λύκειο)."@gr ;
                   rdfs:label "Πτυχίο Αποφοίτησης"@gr .


###  https://w3id.org/ccso/ccso#Student
ccso:Student rdf:type owl:Class ;
             rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> ;
             rdfs:comment "A learner who attends an educational programme"@en ,
                          "O εκπαιδευόμενος που παρακολουθεί κάποιο εκπαιδευτικό πρόγραμμα."@gr ;
             rdfs:label "Εκπαιδευόμενος"@gr ,
                        "Μαθητής"@gr ,
                        "Σπουδαστής"@gr ,
                        "Φοιτητής"@gr ;
             <http://www.w3.org/2004/02/skos/core#altLabel> "Learner"@en .


###  https://w3id.org/ccso/ccso#Syllabus
ccso:Syllabus rdf:type owl:Class ;
              rdfs:comment "A document that addresses course information, expectations and responsibilities to students."@en ,
                           "Ένα έγγραφο που επικοινωνεί προς τους φοιτητές τις πληροφορίες του μαθήματος, τις προσδοκίες καθώς και τις υποχρεώσεις τους."@gr ;
              rdfs:label "Περίγραμμα Μαθήματος"@gr ;
              <http://www.w3.org/2004/02/skos/core#altLabel> "Course Syllabus"@en .


###  https://w3id.org/ccso/ccso#TeachingEvaluationMethod
ccso:TeachingEvaluationMethod rdf:type owl:Class ;
                              rdfs:comment "The manner and the different kinds of teaching methods and learning activities within a course."@en ,
                                           "Ο τρόπος και τα είδη μεθόδων διδασκαλίας και μαθησιακών δραστηριοτήτων που χρησιμοποιούνται κατά τη διάρκεια των μαθημάτων."@gr ;
                              rdfs:label "Μέθοδος Διδασκαλίας"@gr ;
                              <http://www.w3.org/2004/02/skos/core#altLabel> "Teaching Evaluation Method"@en .


###  https://w3id.org/ccso/ccso#TeachingEvent
ccso:TeachingEvent rdf:type owl:Class ;
                   rdfs:subClassOf ccso:Event ;
                   rdfs:comment "Events that happen in a class which are related to teaching."@en ,
                                "Γεγονότα που συμβαίνουν σε μια τάξη και σχετίζονται με τη διδασκαλία."@gr ;
                   rdfs:label "Διδασκαλία"@gr ,
                              "Συμβάν Διδασκαλίας"@gr ;
                   <http://www.w3.org/2004/02/skos/core#altLabel> "Teaching Event"@en ,
                                                                  "Teaching Lesson"@en .


###  https://w3id.org/ccso/ccso#TechnicalStaff
ccso:TechnicalStaff rdf:type owl:Class ;
                    rdfs:subClassOf ccso:Employee ;
                    rdfs:comment "An employee who is specialized and related to provide practical, mechanical and applied services (e.g. electrician, plumber, etc)."@en ,
                                 "Ο εργαζόμενος ο οποίος είναι ειδικευμένος στην παροχή πρακτικών, μηχανικών και εφαρμοσμένων υπηρεσιών (π.χ. ηλεκτρολόγος, υδραυλικός κ.λπ.)."@gr ;
                    rdfs:label "Τεχνικό Προσωπικό"@gr ,
                               "Τεχνικός"@gr ;
                    <http://www.w3.org/2004/02/skos/core#altLabel> "Technical Staff"@en .


###  https://w3id.org/ccso/ccso#Topic
ccso:Topic rdf:type owl:Class ;
           rdfs:comment "A subject of study, small piece from Body of Knowledge that could be organized into course and covered during lessons."@en ,
                        "Ένα θέμα μελέτης, ένα μικρό κομμάτι από το Σώμα της Γνώσης που θα μπορούσε να οργανωθεί σε πορεία και να καλυφθεί κατά τη διάρκεια των μαθημάτων."@gr ;
           rdfs:label "Θέμα"@gr ;
           <http://www.w3.org/2004/02/skos/core#altLabel> "Subject"@en .


###  https://w3id.org/ccso/ccso#UndergraduateStudent
ccso:UndergraduateStudent rdf:type owl:Class ;
                          owl:equivalentClass [ owl:intersectionOf ( ccso:Student
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty ccso:enrolledIn ;
                                                                       owl:someValuesFrom ccso:Bachelor
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                          rdfs:subClassOf ccso:Student ,
                                          [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                   owl:complementOf [ rdf:type owl:Class ;
                                                                                      owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty ccso:enrolledIn ;
                                                                                                      owl:someValuesFrom ccso:Doctorate
                                                                                                    ]
                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                      owl:onProperty ccso:enrolledIn ;
                                                                                                      owl:someValuesFrom ccso:Master
                                                                                                    ]
                                                                                                  )
                                                                                    ]
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty ccso:enrolledIn ;
                                                                   owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                   owl:onClass ccso:Bachelor
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                          rdfs:comment "A student who attends a university program up to the level to the Bachelor’s degree."@en ,
                                       "Ένας φοιτητής που παρακολουθεί κάποιο προπτυχιακό πανεπιστημιακό πρόγραμμα σπουδών."@gr ;
                          rdfs:label "Προπτυχιακός Φοιτητής"@gr ;
                          <http://www.w3.org/2004/02/skos/core#altLabel> "Undergraduate Student"@en .


###  https://w3id.org/ccso/ccso#University
ccso:University rdf:type owl:Class ;
                rdfs:subClassOf <http://schema.org/EducationalOrganization> ;
                rdfs:comment "An institution of Higher Education and research which awards academic degrees in a set of academic disciplines."@en ,
                             "Ένα ίδρυμα Τριτοβάθμιας Εκπαίδευσης και Έρευνας που απονέμει ακαδημαϊκούς τίτλους σε ένα σύνολο ακαδημαϊκών κλάδων."@gr ;
