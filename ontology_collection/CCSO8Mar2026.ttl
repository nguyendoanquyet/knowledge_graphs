                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> ccso:aimsToLO ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#SYL> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#LO>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment """A Person (PER), who has Degree (PS) that provided by a Department (DPT) 
