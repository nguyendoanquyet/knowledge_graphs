<urn:swrl#RSC> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#PER> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#DPT> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#PS> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#CS> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#SL> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

