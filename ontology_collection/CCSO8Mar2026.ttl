<urn:swrl#EV> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#LO> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#SYL> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#PF> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<urn:swrl#TP> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ rdfs:comment "When a Resource that has a Person as Creator, then this Person hasPublication that Resource"@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://purl.org/dc/elements/1.1/creator> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#RSC> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#PER>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> ccso:hasPublication ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#PER> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#RSC>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment """An Assistant (AST) that is instructor in a course (CS) which is included in a program of study (PS) which is provided by a Department (DPT) 
THEN
the Department (DPT) has employee the Professor (PF)"""@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> ccso:providesProgram ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#DPT> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#PS>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> ccso:hasSyllabus ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#CS> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#SL>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> ccso:assistsInCourse ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#AST> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#SL>
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#propertyPredicate> ccso:includesCourse ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#PS> ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#CS>
                                                                                      ] ;
                                                                            rdf:rest rdf:nil
                                                                          ]
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> ccso:hasEmployee ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <urn:swrl#DPT> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <urn:swrl#AST>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ rdfs:comment """When a Syllabus (Course)(SYL) has an Event (EV) that expects a LearningOutcome (LO)
THEN the Syllabus (Course)(SYL) aims to that LearningOutcome (LO)"""@en ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
