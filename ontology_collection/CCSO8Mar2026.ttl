###  https://w3id.org/ccso/ccso#PSY3601s1/PSY_BSc/SoC/Uoc
<https://w3id.org/ccso/ccso#PSY3601s1/PSY_BSc/SoC/Uoc> rdf:type owl:NamedIndividual ,
                                                                ccso:Syllabus ;
                                                       ccso:aimsToLO <https://w3id.org/ccso/ccso#PSY/LO_Achieved_a_basic_understanding_of_how_programmes_for_the_promotion_of_health_are_implemented> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Comprehended_the_psychological_factors_involved_in_the_experience_of_illness> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Realized_the_importance_of_the_link_between_theory_and_practice> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Seen_the_importance_of_multidisciplinary_collaboration_in_health_and_health_care_services> ,
                                                                     <https://w3id.org/ccso/ccso#PSY/LO_Understood_the_interplay_between_biological,_psychological_and_social_determinants_of_health_and_illness> ;
                                                       ccso:coversTopic <https://w3id.org/ccso/ccso#PSY/T_Respect_for_difference_and_multiculturalism> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_Production_of_free,creative_and_inductive_thinking> ,
                                                                        <https://w3id.org/ccso/ccso#PSY/T_Search_for,Analysis_and_Synthesis_of_data_and_information,with_the_use_of_the_necessary_technology> ;
                                                       ccso:followsTEMethod ccso:Demonstration ,
                                                                            ccso:Lecture ;
                                                       ccso:hasInstructor ccso:Kafetsios_Konstantinos ;
                                                       ccso:hasLM ccso:Friedman2011OxfordHandbook ;
                                                       ccso:syllabusOf <https://w3id.org/ccso/ccso#PSY3601/PSY_BSc/SoC/Uoc> ;
                                                       ccso:code "PSY3601s1/PSY_BSc/SoC/Uoc" ;
                                                       ccso:courseType "Compulsory" ;
                                                       ccso:courseURL "https://elearn.uoc.gr/course/view.php?id=110"^^xsd:anyURI ;
                                                       ccso:creditsECTS "5"^^xsd:short ;
                                                       ccso:csName "Syllabus of course PSY3601 Health Psychology" ;
                                                       ccso:description """This course aims to introduce students in the field of health psychology, which refers to the study of the biopsychosocial mechanisms and processes that determine health, illness and health care.
Specifically, the course focuses on important aspects of health and illness, including the definitions of these two concepts, the psychosocial factors and the interactions that determine health and illness, health behaviour prediction and change, the experience of illness and its determinants. The overall aim of this course is to help students achieve a general understanding of the above concepts and of their relation to other fields in psychology as well as to clinical practice.""" ;
                                                       ccso:evaluationInfo """Erasmus Students: Individualized reading material assessed with two extended written reports (in English).

Final exams (70% of the final grade), including:
• multiple choice questions,
• open-ended questions.
Mid-term exam (30% of the final grade), including open-ended questions.
Evaluation criteria are accessible to students via the web-site of course on the UoC e-learn platform.""" ;
                                                       ccso:language "Greek" ;
                                                       ccso:offeredtoErasmus "true"^^xsd:boolean ;
                                                       ccso:semesterinProgram "5"^^xsd:short ;
                                                       ccso:weeklyHours "PT3H"^^xsd:duration ;
                                                       ccso:weeklyWorkload "PT12H"^^xsd:duration .


