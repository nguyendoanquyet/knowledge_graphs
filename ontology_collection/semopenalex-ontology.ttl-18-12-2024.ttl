    ], [ a sh:PropertyShape;
      sh:path foaf:depiction;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path soa:ror;
      sh:datatype xsd:anyURI
    ], [ a sh:PropertyShape;
      sh:path dct:created;
      sh:datatype xsd:date
