skos:ConceptShape a sh:NodeShape;
  sh:property [ a sh:PropertyShape;
      sh:path skos:broader;
      sh:class skos:Concept
    ], [ a sh:PropertyShape;
      sh:path rdfs:seeAlso;
      sh:class fabio:WikipediaEntry
    ], [ a sh:PropertyShape;
      sh:path skos:prefLabel;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path skos:note;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path skos:related;
      sh:class skos:Concept
    ];
  sh:targetClass skos:Concept .

soa:AuthorShape a sh:NodeShape;
  sh:property [ a sh:PropertyShape;
      sh:path soa:2YrMeanCitedness;
      sh:datatype xsd:float
    ], [ a sh:PropertyShape;
      sh:path <http://purl.org/spar/bido/h-index>;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path dct:created;
      sh:datatype xsd:date
    ], [ a sh:PropertyShape;
      sh:path soa:worksCount;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path soa:alternativeName;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path dbprop:twitter;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path foaf:name;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path soa:i10Index;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path dbprop:scopus;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path soa:citedByCount;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path dbpedia-owl:orcidId;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path soa:countsByYear;
      sh:class soa:CountsByYear
    ], [ a sh:PropertyShape;
      sh:path soa:magId;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path dct:modified;
      sh:datatype xsd:date
    ], [ a sh:PropertyShape;
      sh:path <http://www.w3.org/ns/org#memberOf>;
      sh:class soa:Institution
    ], [
      sh:path soa:hasAffiliation;
      sh:class soa:Institution
    ];
  sh:targetClass soa:Author .

soa:AuthorshipShape a sh:NodeShape;
  sh:property [ a sh:PropertyShape;
      sh:path soa:hasOrganization;
      sh:class soa:Institution
    ], [ a sh:PropertyShape;
      sh:path soa:isCorresponding;
      sh:datatype xsd:boolean
    ], [ a sh:PropertyShape;
      sh:path soa:hasAuthor;
      sh:class soa:Author
    ], [ a sh:PropertyShape;
      sh:path soa:position;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path soa:rawAffiliation;
      sh:datatype xsd:string
    ];
  sh:targetClass soa:Authorship .

soa:ConceptShape a sh:NodeShape;
  sh:property [ a sh:PropertyShape;
      sh:path soa:countsByYear;
      sh:class soa:CountsByYear
    ], [ a sh:PropertyShape;
      sh:path foaf:depiction;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path soa:magId;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path soa:umlsCui;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path soa:worksCount;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path soa:level;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path soa:umlsAui;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path soa:citedByCount;
      sh:datatype xsd:integer
    ], [ a sh:PropertyShape;
      sh:path dct:created;
      sh:datatype xsd:date
    ], [ a sh:PropertyShape;
      sh:path soa:imageThumbnail;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path dct:modified;
      sh:datatype xsd:date
    ];
  sh:targetClass soa:Concept .

soa:CountsByYearShape a sh:NodeShape;
  sh:property [
      sh:path soa:citedByCount;
      sh:datatype xsd:integer
    ], [
      sh:path soa:worksCount;
      sh:datatype xsd:integer
    ], [
      sh:path soa:year;
      sh:datatype xsd:integer
    ];
  sh:targetClass soa:CountsByYear .

soa:FunderShape a sh:NodeShape;
  sh:property [
      sh:path soa:alternativeName;
      sh:datatype xsd:string
    ], [
      sh:path dct:created;
      sh:datatype xsd:date
    ], [
      sh:path soa:ror;
      sh:datatype xsd:anyURI
    ], [
      sh:path dbprop:countryCode;
      sh:datatype xsd:string
    ], [
      sh:path soa:worksCount;
      sh:datatype xsd:integer
    ], [
      sh:path foaf:name;
      sh:datatype xsd:string
    ], [
      sh:path soa:citedByCount;
      sh:datatype xsd:integer
    ], [
      sh:path dct:description;
      sh:datatype xsd:string
    ], [
      sh:path soa:2YrMeanCitedness;
      sh:datatype xsd:float
    ], [
      sh:path <http://prismstandard.org/namespaces/basic/2.0/doi>;
      sh:datatype xsd:anyURI
    ], [
      sh:path soa:crossref;
      sh:datatype xsd:string
    ], [
      sh:path <http://purl.org/spar/bido/h-index>;
      sh:datatype xsd:integer
    ], [
      sh:path soa:i10Index;
      sh:datatype xsd:integer
    ], [
      sh:path soa:countsByYear;
      sh:class soa:CountsByYear
    ], [
      sh:path soa:grantsCount;
      sh:datatype xsd:integer
    ], [
      sh:path dct:modified;
      sh:datatype xsd:date
    ], [
      sh:path foaf:homepage;
      sh:datatype xsd:anyURI
    ];
  sh:targetClass soa:Funder .

soa:GeoShape a sh:NodeShape;
  sh:property [ a sh:PropertyShape;
      sh:path dbprop:city;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path dbprop:region;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path wgs:long;
      sh:datatype xsd:float
    ], [ a sh:PropertyShape;
      sh:path dbprop:countryCode;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path dbprop:country;
      sh:datatype xsd:string
    ], [ a sh:PropertyShape;
      sh:path wgs:lat;
      sh:datatype xsd:float
    ];
  sh:targetClass soa:Geo .

