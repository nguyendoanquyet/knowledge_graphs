###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerConsumer
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerConsumer> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem> ,
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/consumedElectricPower> ;
                                                                                        owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                      ] ;
                                                                      rdfs:comment "An electric power consumer is an electric power system that is capable of consuming electricity."@en ;
                                                                      rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                      rdfs:label "Electric Power Consumer"@en ;
                                                                      vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerDistributionNetwork
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerDistributionNetwork> rdf:type owl:Class ;
                                                                                 rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem> ;
                                                                                 rdfs:comment """ Electric Power Distribution Network is a network used to distribute the electric power. 
                      Figure below shows the taxonomy of Electric Power Distribution Network according to the installation mode of Electric Line or cable.
                       [![ElectricPowerDistributionNetworkTaxonomy](https://w3id.org/seas/ElectricPowerDistributionNetwork-1.png)](https://w3id.org/seas/ElectricPowerDistributionNetwork-1.png)
                      """@en ;
                                                                                 rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                                 rdfs:label "Electric Power Distribution Network."@en ;
                                                                                 vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerEvaluation
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerEvaluation> rdf:type owl:Class ;
                                                                        owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                              owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerProperty>
                                                                                            ] ;
                                                                        rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Evaluation> ,
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                          owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerProperty>
                                                                                        ] ;
                                                                        rdfs:comment "The class of evaluations for electric power properties."@en ;
                                                                        rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                        rdfs:label "Electric Power Evaluation" ;
                                                                        vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerLine
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerLine> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerTransmissionSystem> ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/electricReactance> ;
                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/electricResistance> ;
                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/electricSusceptance> ;
                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/failure> ;
                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/length> ;
                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/temperature> ;
                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                  ] ;
                                                                  rdfs:comment """An electric power line is an electric transmission system that is capable of transmitting electricity on a certain distance within an electric power network.

    An electric power line must be connected to two power connections, although this requirement cannot be modeled using OWL axioms if we want to remain in a decidable fragment."""@en ;
                                                                  rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                  rdfs:label "Electric Power Line"@en ;
                                                                  vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerProducer
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerProducer> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem> ,
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/producedElectricPower> ;
                                                                                        owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                      ] ;
                                                                      rdfs:comment "An electric power producer is an electric power system that is capable of producing electricity."@en ;
                                                                      rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                      rdfs:label "Electric Power Producer"@en ;
                                                                      vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerProperty
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerProperty> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Property> ;
                                                                      rdfs:comment "The class of properties that are quantifiable and have a quantity kind of electric power."@en ;
                                                                      rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                      rdfs:label "Electric Power Property" ;
                                                                      vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerStorageSystem
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerStorageSystem> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem> ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/storageElectricPower> ;
                                                                                             owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                           ] ;
                                                                           rdfs:comment "An electric power storage system is an electric power system that is capable of storing electricity. Usually a battery, an electric vehicle, or a microgrid"@en ;
                                                                           rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                           rdfs:label "Electric Power Storage System"@en ;
                                                                           vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/System> ;
                                                                    owl:disjointWith <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection> ,
                                                                                     <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint> ;
                                                                    rdfs:comment """The class of electric power systems, i.e., systems that exchange electricity (i.e., electric power) with other systems.

Electric power systems may consume, produce, or store electricity. Such systems are defined by subclasses of electric power system.
Electric power systems that dissipate energy are thermodynamic systems (i.e., they can then dissipate heat).

  Electric power systems can exchange electricity with other electric power systems. 
  These exchange are only possible through electrical connections between electric power systems.

  Electric power systems can have sub power systems:

- The consumed or produced electricity of subsystems contribute to the consumed or produced electricity of the supersystem;
- the stored electricity of subsystems contribute to the stored electricity of super systems."""@en ;
                                                                    rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                    rdfs:label "Electric Power System"@en ;
                                                                    vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerTransformer
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerTransformer> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerTransmissionSystem> ,
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/connectsPrimarilyAt> ;
                                                                                           owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint>
                                                                                         ] ,
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/connectsSecondarilyAt> ;
                                                                                           owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint>
                                                                                         ] ,
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/primarilyConnectedThrough> ;
                                                                                           owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection>
                                                                                         ] ,
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/secondarilyConnectedThrough> ;
                                                                                           owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection>
                                                                                         ] ;
                                                                         rdfs:comment "An electric power transformer is an electric power system that is capable of transforming electricity within a power network, between a primary connection point and a secondary connection point."@en ;
                                                                         rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                         rdfs:label "Electric Power Transformer"@en ;
                                                                         vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricPowerTransmissionSystem
<file:/D:/knowledge_graphs/ontology_collection/ElectricPowerTransmissionSystem> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem> ;
                                                                                rdfs:comment """An electric power transmission system is an electric power system that is capable of transmitting electricity. 
  Usually to transmit electricity on a certain distance within an electric power network, or to transform it."""@en ;
                                                                                rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                                rdfs:label "Electric Power Transmission System"@en ,
                                                                                           "Sistema de Transmissão"@pt ;
                                                                                vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricReactanceEvaluation
<file:/D:/knowledge_graphs/ontology_collection/ElectricReactanceEvaluation> rdf:type owl:Class ;
                                                                            owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                                  owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricReactanceProperty>
                                                                                                ] ;
                                                                            rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Evaluation> ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                              owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricReactanceProperty>
                                                                                            ] ;
                                                                            rdfs:comment "The class of evaluations for electric reactance properties."@en ;
                                                                            rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                            rdfs:label "Electric Reactance Evaluation" ;
                                                                            vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricReactanceProperty
<file:/D:/knowledge_graphs/ontology_collection/ElectricReactanceProperty> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Property> ;
                                                                          rdfs:comment "The class of properties that are quantifiable and have a quantity kind of electric reactance."@en ;
                                                                          rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                          rdfs:label "Electric Reactance Property" ;
                                                                          vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricResistanceEvaluation
<file:/D:/knowledge_graphs/ontology_collection/ElectricResistanceEvaluation> rdf:type owl:Class ;
                                                                             owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                                   owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricResistanceProperty>
                                                                                                 ] ;
                                                                             rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Evaluation> ,
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                               owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricResistanceProperty>
                                                                                             ] ;
                                                                             rdfs:comment "The class of evaluations for electric resistance properties."@en ;
                                                                             rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                             rdfs:label "Electric Resistance Evaluation" ;
                                                                             vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricResistanceProperty
<file:/D:/knowledge_graphs/ontology_collection/ElectricResistanceProperty> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Property> ;
                                                                           rdfs:comment "The class of properties that are quantifiable and have a quantity kind of electric resistance."@en ;
                                                                           rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                           rdfs:label "Electric Resistance Property" ;
                                                                           vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricSusceptanceEvaluation
<file:/D:/knowledge_graphs/ontology_collection/ElectricSusceptanceEvaluation> rdf:type owl:Class ;
                                                                              owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricSusceptanceProperty>
                                                                                                  ] ;
                                                                              rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Evaluation> ,
                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                                owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricSusceptanceProperty>
                                                                                              ] ;
                                                                              rdfs:comment "The class of evaluations for electric susceptance properties."@en ;
                                                                              rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                              rdfs:label "Electric Susceptance Evaluation" ;
                                                                              vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricSusceptanceProperty
<file:/D:/knowledge_graphs/ontology_collection/ElectricSusceptanceProperty> rdf:type owl:Class ;
                                                                            rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Property> ;
                                                                            rdfs:comment "The class of properties that are quantifiable and have a quantity kind of electric susceptance."@en ;
                                                                            rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                            rdfs:label "Electric Susceptance Property" ;
                                                                            vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricalBallast
<file:/D:/knowledge_graphs/ontology_collection/ElectricalBallast> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem> ;
                                                                  rdfs:comment """An electrical ballast is a device placed in line with the load to limit the amount of current in an electrical circuit. 
                      It may be a fixed or variable resistor.
                      A familiar and widely used example is the inductive ballast used in fluorescent lamps to limit the current through the tube, 
                      which would otherwise rise to a destructive level due to the negative differential resistance artifact in the tube's voltage-current 
                      characteristic. Ballasts vary greatly in complexity. They may be as simple as a resistor, inductor or capacitor (or a combination of these) 
                      wired in series with the lamp; or as complex as the electronic ballasts used in compact fluorescent lamps and high-intensity discharge lamps. 
                      (source:wikipedia)"""@en ;
                                                                  rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                  rdfs:label "Electrical Ballast"@en ;
                                                                  vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection
<file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Connection> ,
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/voltage> ;
                                                                                       owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                     ] ,
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/connectsSystem> ;
                                                                                       owl:allValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem>
                                                                                     ] ,
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/connectsSystemAt> ;
                                                                                       owl:allValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint>
                                                                                     ] ;
                                                                     rdfs:comment """The class of electrical connections between electric power systems.
  An electrical connection describes potential electricity flows between the electric power systems it connects.
  For example, the following RDF graph states that a power bus connects two power lines and a transformer:

```
  <power_bus> a seas:ElectricalConnection ;
    seas:connectsSystem <power_line_1> , <transformer> , <power_line_2> .
```

  Only electric power systems and electrical connection points are connected through an electrical connection.
  A connection between electric power systems is not necessarily an electrical connection.

  Any electric power system that exchanges electricity through an electrical connection is connected at least through one of its power connection points to the electrical connection:
  if:

```
  <power_system> a seas:ElectricPowerSystem .
  <power_connection> a seas:ElectricalConnection .
  <power_system> seas:connectedThrough <power_connection> .
```

  then there exists `_:powerConnectionPoint` such that:

```
  _:powerConnectionPoint a seas:ElectricalConnectionPoint ;
    seas:connectionPointOf <power-system> ;
    seas:connectsSystemThrough <power_connection> .
```"""@en ;
                                                                     rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                     rdfs:label "Electrical Connection"@en ;
                                                                     vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint
<file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ConnectionPoint> ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/electricCurrent> ;
                                                                                            owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                          ] ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/voltage> ;
                                                                                            owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/Property>
                                                                                          ] ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/connectionPointOf> ;
                                                                                            owl:allValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystem>
                                                                                          ] ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/connectsSystemThrough> ;
                                                                                            owl:allValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection>
                                                                                          ] ;
                                                                          rdfs:comment """The class of electrical connection points of electric power systems, at which they may be electricaly connected to other systems.
  For example, an electric vehicle service equipment may have three electric power connection points: two different kinds of plugs that enable to charge electric vehicles, and a three-phase power bus connection point to the grid:

```
  <electric_vehicle> a seas:ElectricPowerSystem ;
    seas:connectsAt <plug_high_voltage> , <normal_plug> , <three_phase_connection_point> .
  <plug_high_voltage> a seas:ElectricalConnectionPoint .
  <normal_plug> a seas:ElectricalConnectionPoint .
  <three_phase_connection_point> a seas:ElectricalConnectionPoint .
```

  Any system connected through an electrical connection is connected at one of its electrical connection points to the electrical connection:
  if:

```
  <system> a seas:System .
  <system> seas:connectedThrough <connection> .
  <connection> a seas:ElectricalConnection .
```

  then there exists `_:connectionPoint` such that:

```
  _:connectionPoint a seas:ElectricalConnection Point ;
    seas:connectionPointOf <system> ;
    seas:connectsSystemAt <connection> .
```

  An electrical connection point describes an electric signal, and the electricity that enters/leaves the electric power system.
  An electrical connection point only belongs to an electric power system, and connects it through electrical connections.
  A connection point of an electric power system is not necessarily an electrical connection."""@en ;
                                                                          rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                          rdfs:label "Electrical Connection Point"@en ;
                                                                          vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ElectronicBallast
<file:/D:/knowledge_graphs/ontology_collection/ElectronicBallast> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricalBallast> ;
                                                                  rdfs:comment """An electronic ballast uses solid state electronic circuitry to provide the proper starting and operating electrical conditions to power discharge lamps.
                      An electronic ballast can be smaller and lighter than a comparably-rated magnetic one. An electronic ballast is usually quieter than a magnetic one,
                      which produces a line-frequency hum by vibration of the transformer laminations. 
                      (source:wikipedia)"""@en ;
                                                                  rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                  rdfs:label "Electronic ballast"@en ;
                                                                  vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/Evaluation
<file:/D:/knowledge_graphs/ontology_collection/Evaluation> rdf:type owl:Class .


###  file:/D:/knowledge_graphs/ontology_collection/ExtraHighVoltage
<file:/D:/knowledge_graphs/ontology_collection/ExtraHighVoltage> rdf:type owl:Class ;
                                                                 rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/VoltageProperty> ;
                                                                 rdfs:comment "The voltage is Extra-High according to IEC 60038."@en ;
                                                                 rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                 rdfs:label "Extra-High Voltage "@en ;
                                                                 vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/ExtraHighVoltageEvaluation
<file:/D:/knowledge_graphs/ontology_collection/ExtraHighVoltageEvaluation> rdf:type owl:Class ;
