                                                                                              [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                                owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/ElectricConductanceProperty>
                                                                                              ] ;
                                                                              rdfs:comment "The class of evaluations for electric conductance properties."@en ;
                                                                              rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                              rdfs:label "Electric Conductance Evaluation" ;
