###  file:/D:/knowledge_graphs/ontology_collection/AlternatingCurrentConnection
<file:/D:/knowledge_graphs/ontology_collection/AlternatingCurrentConnection> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection> ,
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/voltage> ;
                                                                                               owl:allValuesFrom <file:/D:/knowledge_graphs/ontology_collection/PeriodicProperty>
                                                                                             ] ;
                                                                             owl:disjointWith <file:/D:/knowledge_graphs/ontology_collection/DirectCurrentConnection> ;
                                                                             rdfs:comment "The class of electric power connections through which energy flows using alternating current."@en ;
                                                                             rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                             rdfs:label "Alternating Current Connection"@en ;
                                                                             vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/AlternatingCurrentConnectionPoint
<file:/D:/knowledge_graphs/ontology_collection/AlternatingCurrentConnectionPoint> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint> ,
                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                    owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/voltage> ;
                                                                                                    owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/PeriodicProperty>
                                                                                                  ] ;
                                                                                  owl:disjointWith <file:/D:/knowledge_graphs/ontology_collection/DirectCurrentConnectionPoint> ;
                                                                                  rdfs:comment "The class of electric power connection points through which energy flows using alternating current."@en ;
                                                                                  rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                                  rdfs:label "Alternating Current Connection Point"@en ;
                                                                                  vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/AlternatingCurrentPowerProperty
<file:/D:/knowledge_graphs/ontology_collection/AlternatingCurrentPowerProperty> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerProperty> ;
                                                                                rdfs:comment """The class of electric power properties for alternating current.

An alternating current power property cannot be directly quantified. One must quantify its individual power properties."""@en ;
                                                                                rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                                rdfs:label "Alternating Current Power Property" ;
                                                                                vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/AngleEvaluation
<file:/D:/knowledge_graphs/ontology_collection/AngleEvaluation> rdf:type owl:Class ;
                                                                owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                      owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/AngleProperty>
                                                                                    ] ;
                                                                rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Evaluation> ,
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                  owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/AngleProperty>
                                                                                ] ;
                                                                rdfs:comment "The class of evaluations for angle properties."@en ;
                                                                rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                rdfs:label "Angle Evaluation" ;
                                                                vs:term_status "testing" .


