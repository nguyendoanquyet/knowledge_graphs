###  file:/D:/knowledge_graphs/ontology_collection/voltage
<file:/D:/knowledge_graphs/ontology_collection/voltage> rdf:type owl:ObjectProperty ;
                                                        rdfs:subPropertyOf <file:/D:/knowledge_graphs/ontology_collection/hasProperty> ;
                                                        rdfs:domain [ rdf:type owl:Class ;
                                                                      owl:unionOf ( <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnection>
                                                                                    <file:/D:/knowledge_graphs/ontology_collection/ElectricalConnectionPoint>
                                                                                  )
                                                                    ] ;
                                                        rdfs:range <file:/D:/knowledge_graphs/ontology_collection/VoltageProperty> ;
                                                        rdfs:comment """Links an electrical connection or an electrical connection point to one of its voltage properties.

There may be many voltage properties of an electrical connection or an electrical connection point, so this property is not functional.
  """@en ;
                                                        rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                        rdfs:label "voltage" ;
                                                        vs:term_status "testing" .


