###  file:/D:/knowledge_graphs/ontology_collection/EfficiencyEvaluation
<file:/D:/knowledge_graphs/ontology_collection/EfficiencyEvaluation> rdf:type owl:Class ;
                                                                     owl:equivalentClass [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                           owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/EfficiencyProperty>
                                                                                         ] ;
                                                                     rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Evaluation> ,
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <file:/D:/knowledge_graphs/ontology_collection/evaluationOf> ;
                                                                                       owl:someValuesFrom <file:/D:/knowledge_graphs/ontology_collection/EfficiencyProperty>
                                                                                     ] ;
                                                                     rdfs:comment "The class of evaluations for efficiency properties."@en ;
                                                                     rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                     rdfs:label "Efficiency Evaluation" ;
                                                                     vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/EfficiencyProperty
<file:/D:/knowledge_graphs/ontology_collection/EfficiencyProperty> rdf:type owl:Class ;
                                                                   rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/Property> ;
                                                                   rdfs:comment """Efficiency signifies a level of performance that describes a process that uses the lowest amount of inputs to create the greatest 
                amount of outputs. Efficiency relates to the use of all inputs in producing any given 
                output, including personal time and energy. Efficiency is a measurable concept that can be 
                determined by determining the ratio of useful output to total input. It minimizes the waste 
                of resources such as physical materials, energy and time, while successfully achieving the 
                desired output."""@en ;
                                                                   rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                   rdfs:label "Efficiency Property" ;
                                                                   vs:term_status "testing" .


