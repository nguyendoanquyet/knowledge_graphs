###  file:/D:/knowledge_graphs/ontology_collection/RNConductance
<file:/D:/knowledge_graphs/ontology_collection/RNConductance> rdf:type owl:ObjectProperty ;
                                                              rdfs:subPropertyOf <file:/D:/knowledge_graphs/ontology_collection/electricCurrent> ;
                                                              rdf:type owl:FunctionalProperty ;
                                                              rdfs:domain <file:/D:/knowledge_graphs/ontology_collection/ThreePhaseConnectionPoint> ;
                                                              rdfs:range <file:/D:/knowledge_graphs/ontology_collection/ElectricConductanceProperty> ;
                                                              rdfs:comment "Links a three-phase connection point to the conductance between its R and its N wires."@en ;
                                                              rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                              rdfs:label "R-to-N conductance"@en ;
                                                              vs:term_status "testing" .


