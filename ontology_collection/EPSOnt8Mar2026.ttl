###  file:/D:/knowledge_graphs/ontology_collection/ExtraLowVoltageEvaluation
<file:/D:/knowledge_graphs/ontology_collection/ExtraLowVoltageEvaluation> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/VoltageEvaluation> ;
                                                                          rdfs:comment "The voltage is Extra-Low according to IEC 60038."@en ;
                                                                          rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                          rdfs:label "Extra-Low Voltage Evaluation"@en ;
                                                                          vs:term_status "testing" .


###  file:/D:/knowledge_graphs/ontology_collection/FacadeElectricPowerDistributionNetwork
<file:/D:/knowledge_graphs/ontology_collection/FacadeElectricPowerDistributionNetwork> rdf:type owl:Class ;
                                                                                       rdfs:subClassOf <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerDistributionNetwork> ;
                                                                                       rdfs:comment "A Facade Electric Power DistributionNetwork is an ElectricPowerDistributionNetwork which is hanging along a facade."@en ;
                                                                                       rdfs:isDefinedBy <file:/D:/knowledge_graphs/ontology_collection/ElectricPowerSystemOntology> ;
                                                                                       rdfs:label "Facade Electric Power Distribution Network"@en ;
