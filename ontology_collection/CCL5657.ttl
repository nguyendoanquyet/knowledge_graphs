    VLegalO:hasClause VLegalKMaps:DCR0665_c0_s0_sp0_a2_cl1,
        VLegalKMaps:DCR0665_c0_s0_sp0_a2_cl2 ;
    VLegalO:rawText "Điều 2. Hiệu lực và trách nhiệm thi hành" .

