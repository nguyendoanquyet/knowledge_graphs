        VLegalO:Document ;
    rdfs:label "Thông tư 123/2021/TT-BTC sửa đổi Khoản 2 Điều 4 Điều lệ tổ chức và hoạt động của Công ty trách nhiệm hữu hạn một thành viên Mua bán nợ Việt Nam kèm theo Thông tư 42/2021/TT-BTC do Bộ trưởng Bộ Tài chính ban hành" ;
    VLegalO:docCode "123/2021/TT-BTC" ;
    VLegalO:effectiveDate "2022-01-01"^^xsd:date ;
    VLegalO:hasArticle VLegalKMaps:DCR0665_c0_s0_p0_a1,
        VLegalKMaps:DCR0665_c0_s0_p0_a2 ;
    VLegalO:issuedDate "2021-12-30"^^xsd:date ;
    VLegalO:pursuantsOn VLegalKMaps:DCR0640,
        VLegalKMaps:DCR0665,
        VLegalKMaps:DCR0880,
        VLegalKMaps:DCR1123 ;
    VLegalO:relatedLocation VLegalKMaps:KhobacNhanuoc,
        VLegalKMaps:VietNam ;
    VLegalO:relatedOrganization VLegalKMaps:CCL07091 ;
    VLegalO:relatedTo VLegalKMaps:CCL07091 .

VLegalKMaps:DCR0665_c0_s0_p0_a2 a VLegalO:Article ;
