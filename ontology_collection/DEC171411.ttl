VLegalKMaps:DCR1136_c0_s0_p0_a1 a VLegalO:Article ;
    VLegalO:articleOf VLegalKMaps:DEC171411 ;
    VLegalO:rawText "Điều 1. Ban hành kèm theo Quyết định này Hướng dẫn chẩn đoán và điều trị sau nhiễm COVID-19 ở trẻ em." .

VLegalKMaps:DCR1136_c0_s0_p0_a2 a VLegalO:Article ;
    VLegalO:articleOf VLegalKMaps:DEC171411 ;
    VLegalO:rawText "Điều 2. Hướng dẫn chẩn đoán và điều trị sau nhiễm COVID-19 ở trẻ em áp dụng tại các cơ sở khám bệnh, chữa bệnh Nhà nước và tư nhân trên cả nước." .

VLegalKMaps:DCR1136_c0_s0_p0_a3 a VLegalO:Article ;
    VLegalO:articleOf VLegalKMaps:DEC171411 ;
    VLegalO:rawText "Điều 3. Quyết định này có hiệu lực kể từ ngày ký, ban hành." .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl1 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "1. GS.TS. Nguyễn Gia Bình, Chủ tịch Hội Hồi sức cấp cứu Việt Nam" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl10 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "10. BSCKII. Nguyễn Thanh Trường, Phó Giám đốc Bệnh viện Bệnh Nhiệt đới, TP.HCM" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl11 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "11. BSCKII. Nguyễn Minh Tiến, Phó Giám đốc Bệnh viện Nhi đồng thành phố, TP.HCM" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl12 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "12. TTND. BS. Bạch Văn Cam, Cố vấn chuyên môn Bệnh viện Nhi đồng 1, TP.HCM" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl13 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "13. PGS.TS. Phùng Nguyễn Thế Nguyên, Chủ nhiệm bộ môn Nhi, Đại học Y Dược TP. Hồ Chí Minh, Trưởng khoa COVID-19 Bệnh viện Nhi đồng 1, TP.HCM" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl14 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "14. BSCKII. Dư Tuấn Quy, Trưởng khoa nhiễm Bệnh viện Nhi đồng 1, TP.HCM" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl15 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "15. BSCK2. Đỗ Châu Việt, Trưởng khoa Nhiễm Bệnh viện Nhi đồng 2, TP.HCM" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl16 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "16. TS.BS. Phan Tứ Quí, Trưởng khoa Hồi sức Nhi Bệnh viện Bệnh Nhiệt đới, TP.HCM" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl17 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "17. PGS.TS. Nguyễn Văn Tuấn, Viện trưởng Viện Sức khỏe Tâm thần, Bệnh viện Bạch Mai" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl18 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "18. BSCKII. Nguyễn Hồng Hà, Phó Chủ tịch Hội truyền nhiễm Việt Nam, nguyên Phó Giám đốc Bệnh viện Bệnh nhiệt đới TW" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl19 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "19. PGS.TS. Tạ Anh Tuấn, Trưởng khoa Điều trị tích cực Nội khoa, Bệnh viện Nhi TW" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl2 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "2. PGS.TS. Lương Ngọc Khuê, Cục trưởng Cục Quản lý Khám, chữa bệnh" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl20 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "20. PGS.TS. Nguyễn Hoàng Anh, Giám đốc Trung tâm Quốc gia về Thông tin thuốc và Theo dõi phản ứng có hại của thuốc, Phó trưởng khoa Dược, Bệnh viện Bạch Mai" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl21 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "21. TS.BS. Phan Hữu Phúc, Viện trưởng Viện Đào tạo và Nghiên cứu Sức khỏe Trẻ em, Bệnh viện Nhi TW" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl22 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "22. ThS.BS. Nguyễn Thị Thanh Ngọc, Phụ trách phòng Nghiệp vụ - Thanh tra - Bảo vệ sức khỏe cán bộ, Cục Quản lý Khám, chữa bệnh" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl23 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "23. ThS.BS. Trương Lê Vân Ngọc, Phó trưởng phòng Nghiệp vụ - Thanh tra - Bảo vệ sức khỏe cán bộ, Cục Quản lý Khám, chữa bệnh" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl24 a VLegalO:Article ;
    VLegalO:clauseOf VLegalKMaps:DCR1136_c0_s0_p0_a4 ;
    VLegalO:rawText "24. ThS. Cao Đức Phương, Chuyên viên chính phòng Nghiệp vụ - Thanh tra và Bảo vệ sức khỏe cán bộ, Cục Quản lý KCB" .

VLegalKMaps:DCR1136_c0_s0_sp0_a4_cl25 a VLegalO:Article ;
