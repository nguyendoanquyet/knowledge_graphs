    VLegalO:hasClause VLegalKMaps:CCL09118_c0_s0_sp0_a4_cl8,
        VLegalKMaps:CCL09118_c0_s0_sp0_a4_cl9 ;
    VLegalO:rawText "Điều 4. Trách nhiệm xây dựng Thông cáo báo chí và hợp nhất văn bản" .

VLegalKMaps:CCL09118_c0_s0_p0_a3 a VLegalO:Article ;
    VLegalO:articleOf VLegalKMaps:DOC05547 ;
    VLegalO:hasClause VLegalKMaps:CCL09118_c0_s0_sp0_a3_cl5,
        VLegalKMaps:CCL09118_c0_s0_sp0_a3_cl6,
        VLegalKMaps:CCL09118_c0_s0_sp0_a3_cl7 ;
    VLegalO:rawText "Điều 3. Điều chỉnh đưa ra khỏi Chương trình đối với các văn bản QPPL theo Quyết định số 2158/QĐ-BGTVT ngày 17 tháng 02 năm 2021 của Bộ trưởng Bộ GTVT ban hành Chương trình xây dựng văn bản QPPL năm 2022 của Bộ:" .

