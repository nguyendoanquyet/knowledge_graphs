                 rdfs:label "CRF sector (IPCC 2006): agriculture - other"@en ;
                 oeo:OEO_00010037 "CRF 3.J" ;
                 oeo:OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/858
