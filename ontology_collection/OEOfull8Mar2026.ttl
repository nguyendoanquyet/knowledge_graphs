[ rdf:type owl:Axiom ;
   owl:annotatedSource obo:RO_0002501 ;
   owl:annotatedProperty obo:IAO_0000115 ;
   owl:annotatedTarget "p is causally related to q if and only if p or any part of p and q or any part of q are linked by a chain of events where each event pair is one where the execution of p influences the execution of q. p may be upstream, downstream, part of, or a container of q." ;
   prov:wasDerivedFrom <http://purl.obolibrary.org/obo/ro/releases/2023-02-22/ro.owl>
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource obo:RO_0002501 ;
   owl:annotatedProperty obo:IAO_0000117 ;
   owl:annotatedTarget <https://orcid.org/0000-0002-6601-2165> ;
   prov:wasDerivedFrom <http://purl.obolibrary.org/obo/ro/releases/2023-02-22/ro.owl>
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource obo:RO_0002501 ;
   owl:annotatedProperty obo:IAO_0000119 ;
   owl:annotatedTarget <http://purl.obolibrary.org/obo/ro/docs/causal-relations> ;
   prov:wasDerivedFrom <http://purl.obolibrary.org/obo/ro/releases/2023-02-22/ro.owl>
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource obo:RO_0002501 ;
   owl:annotatedProperty obo:IAO_0000232 ;
   owl:annotatedTarget "Do not use this relation directly. It is intended as a grouping for a diverse set of relations, all involving cause and effect." ;
   prov:wasDerivedFrom <http://purl.obolibrary.org/obo/ro/releases/2023-02-22/ro.owl>
 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource obo:RO_0002501 ;
   owl:annotatedProperty rdfs:label ;
   owl:annotatedTarget "causal relation between processes" ;
   prov:wasDerivedFrom <http://purl.obolibrary.org/obo/ro/releases/2023-02-22/ro.owl>
 ] .


