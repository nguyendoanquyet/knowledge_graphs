oeo:OEO_00010058 rdf:type owl:NamedIndividual ,
                          oeo:OEO_00000367 ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty oeo:OEO_00010312 ;
                            owl:someValuesFrom [ owl:intersectionOf ( oeo:OEO_00010140
                                                                      [ owl:intersectionOf ( oeo:OEO_00140003
                                                                                             [ rdf:type owl:Restriction ;
