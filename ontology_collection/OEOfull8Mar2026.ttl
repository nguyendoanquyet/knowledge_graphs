                                 ] ;
                 obo:IAO_0000115 "An electricity grid voltage level is a quantity value reflecting the normative voltage value that an electricity grid is operating on."@en ;
                 rdfs:label "electricity grid voltage level"@en ;
                 oeo:OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1960
