                                     ] ;
                 rdfs:subClassOf oeo:OEO_00240019 ;
                 obo:IAO_0000115 "A final energy consumption value is an energy consumption value expressing the magnitude of the energy delivered to and consumed by end users."@en ;
                 obo:IAO_0000118 "Endenergieverbrauch"@de ,
                                 "final energy consumption"@en ;
                 rdfs:label "final energy consumption value"@en ;
                 oeo:OEO_00020425 "study descriptor tag" ;
                 oeo:OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/576
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/613

Make 'energy consumption value'
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1322
