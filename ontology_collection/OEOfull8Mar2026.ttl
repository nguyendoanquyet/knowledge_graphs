 ] .

[ rdf:type owl:Axiom ;
   owl:annotatedSource obo:IAO_0000033 ;
   owl:annotatedProperty obo:IAO_0000116 ;
   owl:annotatedTarget "Werner pushed back on calling it realizable information entity as it isn't realizable. However this name isn't right either. An example would be a recipe. The realizable entity would be a plan, but the information entity isn't about the plan, it, once concretized, *is* the plan. -Alan"@en ;
   prov:wasDerivedFrom <https://openenergyplatform.org/ontology/oeo/releases/2.9.0/imports/iao-extracted.owl>
