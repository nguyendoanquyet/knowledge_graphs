oeo:OEO_00410068 rdf:type owl:Class ;
                 rdfs:subClassOf www:ont00000127 ;
                 obo:IAO_0000115 "Rated voltage is a Performance Specification that prescribes the intended operating voltage of some electrical artifact."@en ;
                 obo:IAO_0000118 "maximum voltage"@en ;
                 obo:IAO_0000119 "definition adapted from: https://dlr-ve-esy.github.io/charging-ontology/CHIO_00000091.html" ;
                 rdfs:comment "Rated voltage usually means maximum voltage."@en ;
                 rdfs:label "rated voltage"@en ;
                 oeo:OEO_00020426 """first implementation
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2107
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2108""" .


###  https://openenergyplatform.org/ontology/oeo/OEO_00410070
oeo:OEO_00410070 rdf:type owl:Class ;
                 rdfs:subClassOf oeo:OEO_00410068 ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty www:ont00001942 ;
                                   owl:hasValue oeo:OEO_00410051
                                 ] ;
                 obo:IAO_0000115 "A low rated voltage is a rated voltage usually used for the local distribution of electricity. Electricity at this voltage can be converted to a medium rated voltage. The usual producers feeding electricity into the grid at this voltage are smaller wind farms and solar installations. Households are the usual consumers receiving electricity at this voltage."@en ;
                 obo:IAO_0000119 "https://www.smard.de/page/en/wiki-article/5884/214026" ;
                 rdfs:label "low rated voltage"@en ;
                 oeo:OEO_00020426 """first implementation
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2107
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2108""" .


###  https://openenergyplatform.org/ontology/oeo/OEO_00410071
oeo:OEO_00410071 rdf:type owl:Class ;
                 rdfs:subClassOf oeo:OEO_00410068 ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty www:ont00001942 ;
                                   owl:hasValue oeo:OEO_00410052
                                 ] ;
                 obo:IAO_0000115 "A medium rated voltage is a rated voltage usually used for the regional distribution of electricity. Electricity at this voltage can be converted to a high or low rated voltage. The usual producers feeding electricity into the grid at this voltage are wind and solar farms. Industries can be consumers receiving electricity at this voltage."@en ;
                 obo:IAO_0000119 "https://www.smard.de/page/en/wiki-article/5884/214026" ;
                 rdfs:label "medium rated voltage"@en ;
                 oeo:OEO_00020426 """first implementation
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2107
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2108""" .


###  https://openenergyplatform.org/ontology/oeo/OEO_00410072
oeo:OEO_00410072 rdf:type owl:Class ;
                 rdfs:subClassOf oeo:OEO_00410068 ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty www:ont00001942 ;
                                   owl:hasValue oeo:OEO_00410053
                                 ] ;
                 obo:IAO_0000115 "A high rated voltage is a rated voltage usually used for the interregional distribution of electricity. Electricity at this voltage can be converted to an extra high or medium rated voltage. The usual producers feeding electricity into the grid at this voltage are natural gas and hydro power plants. Large-scale industries can be consumers receiving electricity at this voltage."@en ;
                 obo:IAO_0000119 "https://www.smard.de/page/en/wiki-article/5884/214026" ;
                 rdfs:label "high rated voltage"@en ;
                 oeo:OEO_00020426 """first implementation
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2107
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2108""" .


###  https://openenergyplatform.org/ontology/oeo/OEO_00410073
oeo:OEO_00410073 rdf:type owl:Class ;
                 rdfs:subClassOf oeo:OEO_00410068 ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty www:ont00001942 ;
                                   owl:hasValue oeo:OEO_00410054
                                 ] ;
                 obo:IAO_0000115 "An extra high rated voltage is a rated voltage usually used for the transmission of electricity. This is the usual voltage for electricity imports and exports. Electricity at this voltage can be converted to a high rated voltage. The usual producers feeding electricity into the grid at this voltage are coal and nuclear power plants, as well as offshore wind farms and hydro power plants."@en ;
                 obo:IAO_0000119 "https://www.smard.de/page/en/wiki-article/5884/214026" ;
                 rdfs:label "extra high rated voltage"@en ;
                 oeo:OEO_00020426 """first implementation
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2107
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2108""" .


###  https://raw.githubusercontent.com/stap-m/midlevel-energy-ontology/main/ontology/src/midlevel-energy.owl/MENO_01002
<https://raw.githubusercontent.com/stap-m/midlevel-energy-ontology/main/ontology/src/midlevel-energy.owl/MENO_01002> rdf:type owl:Class ;
                                                                                                                     rdfs:subClassOf <https://raw.githubusercontent.com/stap-m/midlevel-energy-ontology/main/ontology/src/midlevel-energy.owl/MENO_01038> ,
                                                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                                                       owl:onProperty obo:BFO_0000051 ;
                                                                                                                                       owl:someValuesFrom <https://raw.githubusercontent.com/stap-m/midlevel-energy-ontology/main/ontology/src/midlevel-energy.owl/MENO_01013>
                                                                                                                                     ] ,
                                                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                                                       owl:onProperty obo:BFO_0000051 ;
                                                                                                                                       owl:someValuesFrom <https://raw.githubusercontent.com/stap-m/midlevel-energy-ontology/main/ontology/src/midlevel-energy.owl/MENO_01014>
                                                                                                                                     ] ;
                                                                                                                     obo:IAO_0000115 "Energy transfer is a quality process in which a kind of energy is decreased in one bearer and the same kind of energy is increased in another bearer." ;
                                                                                                                     obo:IAO_0000602 """(forall (?et) (iff (EnergyTransfer ?et)  
  (exists (?ed ?ei ?en1 ?en2 ?me1 ?me2) 
    (and (EnergyDecrease ?ed) (has_part ?et ?ed) 
      (EnergyIncrease ?ei) (has_part ?et ?ei)
      (causally_related_to ?ed ?ei)            
      (Quality ?en1) (negatively_regulates ?ed ?en1) 
      (Quality ?en2) (positively_regulates ?ei ?en2)  
      (MaterialEntity ?me1) (MaterialEntity ?me2) 
      (not (= ?me1 ?me2)) (not (= ?en1 ?en2))
      (has_participant ?ed ?me1) (inheres_in ?en1 ?me1) 
      (has_participant ?ei ?me2) (inheres_in ?en2 ?me2) ))))""" ;
                                                                                                                     rdfs:isDefinedBy <https://openenergyplatform.org/ontology/oeo/imports/meno-extracted.owl> ;
                                                                                                                     rdfs:label "energy transfer" ;
                                                                                                                     oeo:OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/1959
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2022

readd axioms
issue: https://github.com/OpenEnergyPlatform/ontology/issues/2058
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/2061""" .

