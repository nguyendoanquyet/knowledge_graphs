                            owl:someValuesFrom oeo:OEO_00010126
                          ] ;
                 obo:BFO_0000050 oeo:OEO_00010129 ;
                 obo:IAO_0000115 "The Effort Sharing Decision (ESD) is the European effort sharing for the years 2013-2020. It covers the European Union, Norway, Iceland and Liechtenstein and the following greenhouse gases: carbon dioxide, methane, nitrous oxide, hydrofluorocarbons, perfluorocarbons and sulphur hexafluoride. Emission quantities under the ESD are calculated using global warming potentials from the Fourth IPCC Assessment Report." ;
                 obo:IAO_0000118 "ESD" ,
                                 "Lastenteilungsentscheidung"@de ;
                 rdfs:label "Effort Sharing Decision"@en ;
                 oeo:OEO_00020426 """issue: https://github.com/OpenEnergyPlatform/ontology/issues/834
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/857""" .


