                 obo:IAO_0000118 "falsch"@de ;
                 rdfs:label "false"@en ;
                 oeo:OEO_00020426 """definition:
issue: https://github.com/OpenEnergyPlatform/ontology/issues/1148
pull request: https://github.com/OpenEnergyPlatform/ontology/pull/1255""" .


