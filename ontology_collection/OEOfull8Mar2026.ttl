   owl:annotatedSource obo:BFO_0000050 ;
   owl:annotatedProperty obo:IAO_0000118 ;
   owl:annotatedTarget "part_of"@en ;
   prov:wasDerivedFrom <http://purl.obolibrary.org/obo/ro/releases/2023-02-22/ro.owl>
 ] .

